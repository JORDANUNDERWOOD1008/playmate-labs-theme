{% comment %} PLAYMATE LABS — Event Detail Page Template {% endcomment %}
{{ 'event-detail.css' | asset_url | stylesheet_tag }}
{{ 'event-detail.js' | asset_url | script_tag }}

{%- comment -%} Expects page handle format: event-[slug] e.g. event-velvet-hour-live {%- endcomment -%}

{%- assign event_data = page.metafields.event -%}

<!-- EVENT HERO -->
<section class="event-detail-hero">
  <div class="event-detail-hero-bg">
    {%- if page.metafields.event.image != blank -%}
      <img src="{{ page.metafields.event.image | image_url: width: 1600 }}" alt="{{ page.title }}" loading="eager" class="event-detail-hero-img-bg">
    {%- endif -%}
  </div>
  <div class="event-detail-hero-overlay"></div>

  <div class="container event-detail-hero-inner">
    <div class="breadcrumb breadcrumb-light">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="breadcrumb-sep">›</span>
      <a href="{{ routes.root_url }}pages/events">Events</a>
      <span class="breadcrumb-sep">›</span>
      <span>{{ page.title }}</span>
    </div>

    <div class="event-detail-hero-grid">
      <!-- Left: Event Info -->
      <div class="event-detail-info animate-fadeInUp">
        <div class="event-detail-badges">
          {%- if page.metafields.event.type != blank -%}
            <span class="badge badge-burgundy">{{ page.metafields.event.type.value }}</span>
          {%- else -%}
            <span class="badge badge-burgundy">{{ settings.event_detail_default_type | default: 'Sensory Date Night' }}</span>
          {%- endif -%}
          {%- if page.metafields.event.sold_out == true -%}
            <span class="badge badge-dark">Sold Out</span>
          {%- else -%}
            <span class="badge badge-gold">{{ settings.event_detail_availability_badge | default: 'Selling Fast' }}</span>
          {%- endif -%}
        </div>

        <h1 class="event-detail-title">{{ page.title }}</h1>

        <div class="event-detail-meta-row">
          {%- if page.metafields.event.date != blank -%}
            <span class="event-meta-item">
              <i class="far fa-calendar" style="color:var(--gold);"></i>
              {{ page.metafields.event.date.value | date: '%A %d %B %Y' }}
            </span>
          {%- else -%}
            <span class="event-meta-item">
              <i class="far fa-calendar" style="color:var(--gold);"></i>
              {{ settings.event_detail_date | default: 'Date TBC' }}
            </span>
          {%- endif -%}
          {%- if page.metafields.event.time != blank -%}
            <span class="event-meta-item">
              <i class="far fa-clock" style="color:var(--gold);"></i>
              {{ page.metafields.event.time.value }}
            </span>
          {%- endif -%}
          {%- if page.metafields.event.city != blank -%}
            <span class="event-meta-item">
              <i class="fas fa-map-marker-alt" style="color:var(--gold);"></i>
              {{ page.metafields.event.city.value }}
            </span>
          {%- endif -%}
        </div>

        <p class="event-detail-desc">{{ page.content | strip_html | truncate: 300 }}</p>

        <div class="event-detail-cta-row">
          <div class="event-detail-price">
            {%- if page.metafields.event.price != blank -%}
              <span class="event-price-amount">{{ page.metafields.event.price.value }}</span>
            {%- else -%}
              <span class="event-price-amount">{{ settings.event_detail_price | default: '£85' }}</span>
            {%- endif -%}
            <span class="event-price-label">/couple</span>
          </div>
          {%- if page.metafields.event.sold_out == true -%}
            <a href="#waitlist-form" class="btn btn-secondary btn-xl">Join the Waitlist</a>
          {%- else -%}
            <a href="#rsvp-form" class="btn btn-gold btn-xl">
              RSVP Now
              {%- if page.metafields.event.capacity != blank -%}
                — Only {{ page.metafields.event.capacity.value }} left
              {%- endif -%}
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Right: Event Card -->
      <div class="event-detail-card animate-fadeIn animate-delay-2">
        <h3 class="event-card-heading">Event Details</h3>
        <div class="event-card-details">
          <div class="event-card-detail-row">
            <i class="far fa-calendar" style="color:var(--gold);"></i>
            <div>
              <strong>Date &amp; Time</strong>
              <p>
                {%- if page.metafields.event.date != blank -%}
                  {{ page.metafields.event.date.value | date: '%A %d %B %Y' }}<br>
                {%- else -%}
                  {{ settings.event_detail_date | default: 'Date to be confirmed' }}<br>
                {%- endif -%}
                {%- if page.metafields.event.time != blank -%}
                  Doors open · {{ page.metafields.event.time.value }}
                {%- endif -%}
              </p>
            </div>
          </div>
          <div class="event-card-detail-row">
            <i class="fas fa-map-marker-alt" style="color:var(--gold);"></i>
            <div>
              <strong>Venue</strong>
              <p>
                {%- if page.metafields.event.venue != blank -%}
                  {{ page.metafields.event.venue.value }}<br>
                {%- endif -%}
                {%- if page.metafields.event.city != blank -%}
                  {{ page.metafields.event.city.value }}<br>
                {%- endif -%}
                <span style="color:var(--gold);font-size:0.8125rem;">Exact address sent after booking</span>
              </p>
            </div>
          </div>
          <div class="event-card-detail-row">
            <i class="fas fa-users" style="color:var(--gold);"></i>
            <div>
              <strong>Capacity</strong>
              <p>{{ settings.event_detail_capacity_text | default: 'Limited intimate event for couples' }}</p>
            </div>
          </div>
          <div class="event-card-detail-row">
            <i class="fas fa-tag" style="color:var(--gold);"></i>
            <div>
              <strong>Price</strong>
              <p>
                {%- if page.metafields.event.price != blank -%}
                  {{ page.metafields.event.price.value }} per couple
                {%- else -%}
                  {{ settings.event_detail_price | default: '£85' }} per couple
                {%- endif -%}
                {%- if settings.event_detail_price_includes != blank -%}
                  <br><span style="font-size:0.8125rem;color:rgba(245,239,230,0.5);">{{ settings.event_detail_price_includes }}</span>
                {%- endif -%}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- EVENT DESCRIPTION / FULL CONTENT -->
<section class="event-detail-body section">
  <div class="container">
    <div class="event-detail-body-grid">

      <!-- Full Content -->
      <div class="event-detail-content">
        {%- if page.content != blank -%}
          <div class="event-detail-rich-text rte">{{ page.content }}</div>
        {%- else -%}
          <h2>{{ settings.event_detail_about_heading | default: 'About This Event' }}</h2>
          <p>{{ settings.event_detail_about_text | default: 'An intimate sensory evening designed for modern couples. Details below.' }}</p>
        {%- endif -%}

        <!-- What to Expect -->
        {%- if settings.event_detail_show_itinerary -%}
        <div class="event-itinerary">
          <h3>{{ settings.event_itinerary_heading | default: 'The Evening Itinerary' }}</h3>
          <div class="event-itinerary-list">
            {%- for i in (1..5) -%}
              {%- assign time_key = 'event_itinerary_time_' | append: i -%}
              {%- assign item_key = 'event_itinerary_item_' | append: i -%}
              {%- if settings[item_key] != blank -%}
                <div class="event-itinerary-item">
                  <span class="event-itinerary-time">{{ settings[time_key] }}</span>
                  <span class="event-itinerary-desc">{{ settings[item_key] }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
        {%- endif -%}
      </div>

      <!-- RSVP / Booking Sidebar -->
      <aside class="event-detail-sidebar">

        {%- if page.metafields.event.sold_out == true -%}
        <!-- WAITLIST FORM -->
        <div class="event-form-card" id="waitlist-form">
          <h3>Join the Waitlist</h3>
          <p>This event is sold out — join the waitlist to be first to know about the next one.</p>
          {%- form 'customer', id: 'event-waitlist-form' -%}
            <input type="hidden" name="contact[tags]" value="event-waitlist,{{ page.handle }}">
            <div class="form-group">
              <label class="form-label">Your Name</label>
              <input type="text" name="contact[first_name]" placeholder="First name" class="form-input" required>
            </div>
            <div class="form-group">
              <label class="form-label">Email</label>
              <input type="email" name="contact[email]" placeholder="your@email.com" class="form-input" required>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">{{ settings.event_waitlist_cta | default: 'Join Waitlist' }}</button>
          {%- endform -%}
        </div>

        {%- else -%}
        <!-- RSVP / BOOKING FORM -->
        <div class="event-form-card" id="rsvp-form">
          <h3>{{ settings.event_rsvp_heading | default: 'Reserve Your Spot' }}</h3>
          <p class="event-form-subtext">{{ settings.event_rsvp_subtext | default: 'Secure your place for this intimate event. Spaces are limited.' }}</p>

          {%- form 'customer', id: 'event-rsvp-form' -%}
            {%- if form.posted_successfully? -%}
              <div class="event-form-success">
                <span style="font-size:2rem;">🎉</span>
                <h4>{{ settings.event_rsvp_success_heading | default: "You're on the list!" }}</h4>
                <p>{{ settings.event_rsvp_success_text | default: "We'll be in touch with confirmation and venue details." }}</p>
              </div>
            {%- else -%}
              <input type="hidden" name="contact[tags]" value="event-rsvp,{{ page.handle }}">
              <div class="event-form-grid-2">
                <div class="form-group">
                  <label class="form-label">First Name</label>
                  <input type="text" name="contact[first_name]" placeholder="First name" class="form-input" required>
                </div>
                <div class="form-group">
                  <label class="form-label">Partner's Name</label>
                  <input type="text" name="contact[last_name]" placeholder="Partner's name" class="form-input">
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">Email</label>
                <input type="email" name="contact[email]" placeholder="your@email.com" class="form-input" required>
              </div>
              <div class="form-group">
                <label class="form-label">Phone (optional)</label>
                <input type="tel" name="contact[phone]" placeholder="+44 7700 000000" class="form-input">
              </div>
              {%- if settings.event_rsvp_show_dietary -%}
              <div class="form-group">
                <label class="form-label">Dietary Requirements</label>
                <textarea name="contact[body]" placeholder="Let us know of any dietary requirements..." class="form-input" rows="2"></textarea>
              </div>
              {%- endif -%}
              <button type="submit" class="btn btn-gold btn-lg" style="width:100%;justify-content:center;margin-top:0.5rem;">{{ settings.event_rsvp_cta | default: 'Reserve My Spot' }}</button>
              <p class="event-form-disclaimer">{{ settings.event_rsvp_disclaimer | default: 'No payment required now. We will contact you with payment details.' }}</p>
            {%- endif -%}
          {%- endform -%}
        </div>
        {%- endif -%}

        <!-- Trust Signals -->
        <div class="event-trust-list">
          {%- assign trust_items = '🔒 Secure & confidential,📧 Instant confirmation,🔄 Full refund up to 48hrs before,💎 Intimate couples event' | split: ',' -%}
          {%- for trust in trust_items -%}
            <div class="event-trust-item">{{ trust }}</div>
          {%- endfor -%}
        </div>

      </aside>
    </div>
  </div>
</section>

<!-- SOCIAL PROOF -->
{%- if settings.event_detail_show_testimonials -%}
<section class="event-testimonials section bg-ivory">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow" style="color:var(--gold);">{{ settings.event_testimonials_eyebrow | default: 'From past events' }}</span>
      <h2>{{ settings.event_testimonials_heading | default: 'What couples say' }}</h2>
    </div>
    <div class="event-testimonials-grid">
      {%- for i in (1..3) -%}
        {%- assign quote_key = 'event_testimonial_quote_' | append: i -%}
        {%- assign author_key = 'event_testimonial_author_' | append: i -%}
        {%- if settings[quote_key] != blank -%}
          <div class="testimonial-card">
            <div class="testimonial-stars">★★★★★</div>
            <p class="testimonial-text">"{{ settings[quote_key] }}"</p>
            <p class="testimonial-author">— {{ settings[author_key] }}</p>
          </div>
        {%- else -%}
          {%- assign default_quotes = '"Honestly one of the best nights we've had together. The atmosphere was perfect." — Sarah & Tom,A date night that actually made us feel like strangers again (in the best way). — James & Claire,"The guided tasting was incredible. We had no idea chocolate could be that sensory." — Alex & Jordan' | split: ',' -%}
          {%- if default_quotes[forloop.index0] != blank -%}
          <div class="testimonial-card">
            <div class="testimonial-stars">★★★★★</div>
            <p class="testimonial-text">{{ default_quotes[forloop.index0] }}</p>
          </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

<!-- MORE EVENTS CTA -->
<section class="event-more-cta">
  <div class="container">
    <div class="event-more-cta-inner">
      <h2>{{ settings.event_more_heading | default: 'More events coming soon' }}</h2>
      <p>{{ settings.event_more_subtext | default: 'We host intimate sensory evenings, couples mixers and pop-ups across the UK.' }}</p>
      <div class="event-more-actions">
        <a href="{{ routes.root_url }}pages/events" class="btn btn-primary">All Events</a>
        <a href="{{ routes.root_url }}pages/5-day-experience" class="btn btn-secondary">Free 5-Day Experience</a>
      </div>
    </div>
  </div>
</section>
