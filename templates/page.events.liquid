{% comment %}
  PLAYMATE LABS — EVENTS PAGE TEMPLATE
  File: templates/page.events.liquid
  Assign to page handle: events
{% endcomment %}

{{ 'events.css' | asset_url | stylesheet_tag }}

{%- comment -%} EVENTS HERO {%- endcomment -%}
<section class="events-hero">
  <div class="events-hero-bg">
    <div class="events-hero-gradient"></div>
  </div>
  <div class="container events-hero-content animate-fadeInUp">
    <span class="section-eyebrow" style="color:var(--gold);">IRL Experiences</span>
    <h1 style="font-family:var(--font-display);font-size:clamp(2.75rem,5.5vw,5rem);font-weight:300;line-height:1.05;color:var(--cream);margin:1rem 0 1.5rem;">
      Experiences worth<br><em style="color:var(--gold-light);">dressing up for.</em>
    </h1>
    <p style="font-size:1rem;color:rgba(245,239,230,0.65);max-width:500px;margin-bottom:2.5rem;">
      Sensory date nights, intimate pop-ups and couples mixers across the UK. Beautifully produced. Always limited.
    </p>
    <a href="#events-grid" class="btn btn-gold btn-xl">Browse Events</a>
  </div>
</section>

{%- comment -%} FILTER BAR {%- endcomment -%}
<section class="events-filters" style="padding:2rem 0;border-bottom:1px solid var(--border-color);">
  <div class="container">
    <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
      <button class="filter-btn active" data-filter="all">All Events</button>
      <button class="filter-btn" data-filter="date-night">Date Nights</button>
      <button class="filter-btn" data-filter="pop-up">Pop-Ups</button>
      <button class="filter-btn" data-filter="mixer">Mixers</button>
      <button class="filter-btn" data-filter="workshop">Workshops</button>
      <div style="margin-left:auto;display:flex;gap:0.5rem;">
        <button class="filter-btn" data-city="all">All Cities</button>
        <button class="filter-btn" data-city="london">London</button>
        <button class="filter-btn" data-city="manchester">Manchester</button>
      </div>
    </div>
  </div>
</section>

{%- comment -%} EVENTS GRID — Shopify metaobjects or page metafields {%- endcomment -%}
<section class="section" id="events-grid" style="padding:4rem 0 6rem;">
  <div class="container">

    {%- comment -%}
      Events are managed as Shopify Metaobjects (type: "event").
      Each event metaobject has fields:
        - name (text)
        - date (date)
        - time (text)
        - city (text)
        - venue (text)
        - type (text: date-night/pop-up/mixer/workshop)
        - short_desc (text)
        - price (text)
        - capacity (number)
        - sold_out (boolean)
        - image (file/image)
        - slug (text — used as URL anchor)
    {%- endcomment -%}

    {%- assign events_metaobjects = shop.metaobjects.event.values -%}

    {%- if events_metaobjects != blank and events_metaobjects.size > 0 -%}
      <div class="events-grid" id="events-grid-inner">
        {%- for event in events_metaobjects -%}
          <article class="event-card"
                   data-filter="{{ event.type.value | handleize }}"
                   data-city="{{ event.city.value | handleize }}">
            <div class="event-card-img">
              {%- if event.image.value -%}
                <img src="{{ event.image.value | image_url: width: 800 }}"
                     alt="{{ event.name.value | escape }}"
                     width="800" height="500"
                     loading="lazy"
                     style="width:100%;height:100%;object-fit:cover;">
              {%- else -%}
                <div class="img-placeholder" style="height:100%;font-size:4rem;">✨</div>
              {%- endif -%}
              {%- if event.sold_out.value -%}
                <div class="event-sold-out-badge">Sold Out</div>
              {%- else -%}
                <div class="event-availability-badge">Booking Open</div>
              {%- endif -%}
            </div>
            <div class="event-card-body">
              <div class="event-card-meta">
                <span class="badge badge-burgundy">{{ event.type.value | capitalize }}</span>
                <span class="event-city">📍 {{ event.city.value }}</span>
              </div>
              <h3 class="event-card-title">{{ event.name.value }}</h3>
              <div class="event-card-date">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.75"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {{ event.date.value | date: "%A, %d %B %Y" }} · {{ event.time.value }}
              </div>
              <p class="event-card-desc">{{ event.short_desc.value | truncate: 120 }}</p>
              <div class="event-card-footer">
                <span class="event-price">{{ event.price.value }}</span>
                <a href="/pages/event-{{ event.slug.value }}" class="btn btn-primary btn-sm">
                  {%- if event.sold_out.value -%}Join Waitlist{%- else -%}Book Now{%- endif -%}
                </a>
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      {%- comment -%} Placeholder when no metaobjects exist yet {%- endcomment -%}
      <div class="events-grid" id="events-grid-inner">
        {%- assign placeholder_events = "The Velvet Hour — A Sensory Dinner for Two|The Curiosity Lab — A Couples Mixer|The Ritual Workshop — At Home Intimacy|The After Hours — Late-Night Pop-Up" | split: '|' -%}
        {%- assign event_icons = "🍷|🎭|🕯️|🌙" | split: '|' -%}
        {%- assign event_cities = "London|Manchester|London|Manchester" | split: '|' -%}
        {%- assign event_types = "Date Night|Mixer|Workshop|Pop-Up" | split: '|' -%}
        {%- assign event_prices = "£65 per couple|£35 per person|£45 per couple|£55 per couple" | split: '|' -%}

        {%- for event in placeholder_events -%}
          <article class="event-card">
            <div class="event-card-img">
              <div class="img-placeholder" style="height:100%;font-size:4rem;">{{ event_icons[forloop.index0] }}</div>
              <div class="event-availability-badge">Booking Open</div>
            </div>
            <div class="event-card-body">
              <div class="event-card-meta">
                <span class="badge badge-burgundy">{{ event_types[forloop.index0] }}</span>
                <span class="event-city">📍 {{ event_cities[forloop.index0] }}</span>
              </div>
              <h3 class="event-card-title">{{ event }}</h3>
              <div class="event-card-date">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.75"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                February 14, 2025 · 7:00pm
              </div>
              <p class="event-card-desc">An intimate, beautifully curated evening experience for modern couples.</p>
              <div class="event-card-footer">
                <span class="event-price">{{ event_prices[forloop.index0] }}</span>
                <a href="#event-rsvp" class="btn btn-primary btn-sm">Book Now</a>
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{%- comment -%} EVENT RSVP / EMAIL CAPTURE {%- endcomment -%}
<section class="section bg-dark" id="event-rsvp" style="padding:5rem 0;">
  <div class="container">
    <div style="max-width:540px;margin:0 auto;text-align:center;" class="reveal">
      <span class="section-eyebrow" style="color:var(--gold);">Never Miss an Event</span>
      <h2 style="font-family:var(--font-serif);font-size:clamp(2rem,3.5vw,2.75rem);color:var(--cream);margin:1rem 0 1rem;">
        Get first access to every event.
      </h2>
      <p style="color:rgba(245,239,230,0.6);margin-bottom:2rem;">
        Our events sell out fast. Join the events list for pre-sale access, city announcements and exclusive members-only nights.
      </p>
      {%- form 'customer', id: 'events-signup-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,events-list">
        <div style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;margin:0 auto;">
          <input type="email" name="contact[email]" placeholder="Email address" class="form-input form-input-dark" required autocomplete="email">
          <select name="contact[note]" class="form-input form-input-dark" aria-label="Your city">
            <option value="">Nearest city</option>
            <option value="London">London</option>
            <option value="Manchester">Manchester</option>
            <option value="Birmingham">Birmingham</option>
            <option value="Bristol">Bristol</option>
            <option value="Edinburgh">Edinburgh</option>
            <option value="Other">Other</option>
          </select>
          <button type="submit" class="btn btn-gold btn-lg" style="width:100%;justify-content:center;">
            Get First Access
          </button>
        </div>
        {%- if form.posted_successfully? -%}
          <p style="color:var(--gold);font-size:0.875rem;margin-top:1rem;">
            ✓ You're on the list! We'll be in touch before tickets go live.
          </p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

<script>
  // Events filter
  document.querySelectorAll('[data-filter]').forEach(btn => {
    btn.addEventListener('click', function() {
      const filter = this.dataset.filter;
      document.querySelectorAll('[data-filter]').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      document.querySelectorAll('.event-card').forEach(card => {
        if (filter === 'all' || card.dataset.filter === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
  document.querySelectorAll('[data-city]').forEach(btn => {
    btn.addEventListener('click', function() {
      const city = this.dataset.city;
      document.querySelectorAll('[data-city]').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      document.querySelectorAll('.event-card').forEach(card => {
        if (city === 'all' || card.dataset.city === city) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
