{% comment %}
  PLAYMATE LABS — JOURNAL / BLOG TEMPLATE
  File: templates/blog.liquid
  Used for all blog listings: /blogs/journal
{% endcomment %}

{%- comment -%} JOURNAL HERO {%- endcomment -%}
<section style="padding:calc(var(--nav-height)+3rem) 0 3rem;background:var(--ivory);">
  <div class="container">
    <span class="section-eyebrow" style="color:var(--burgundy);">Ideas, Rituals &amp; Perspectives</span>
    <h1 style="font-family:var(--font-serif);font-size:clamp(2.5rem,5vw,4rem);color:var(--espresso);margin:0.75rem 0 1rem;max-width:700px;line-height:1.1;">
      The Playmate Journal
    </h1>
    <p style="font-size:1rem;color:var(--text-muted);max-width:560px;">
      The science of connection, the art of intimacy and ideas for modern relationships — written for curious couples.
    </p>
  </div>
</section>

{%- comment -%} TOPIC FILTERS {%- endcomment -%}
<div style="padding:1.5rem 0;border-bottom:1px solid var(--border-color);background:var(--ivory);">
  <div class="container">
    <div style="display:flex;gap:0.625rem;flex-wrap:wrap;">
      <a href="{{ blog.url }}"
         class="filter-btn{% unless current_tags %} active{% endunless %}">
        All Articles
      </a>
      {%- for tag in blog.all_tags -%}
        <a href="{{ blog.url }}/tagged/{{ tag | url_encode }}"
           class="filter-btn{% if current_tags contains tag %} active{% endif %}">
          {{ tag }}
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{%- comment -%} ARTICLES GRID {%- endcomment -%}
{%- paginate blog.articles by 9 -%}
<section style="padding:4rem 0 6rem;background:var(--ivory);">
  <div class="container">
    {%- if blog.articles_count > 0 -%}
      {%- comment -%} Featured article {%- endcomment -%}
      {%- assign featured = blog.articles.first -%}
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;margin-bottom:4rem;" class="reveal responsive-grid">
        <div style="border-radius:16px;overflow:hidden;aspect-ratio:4/3;">
          {%- if featured.image -%}
            <img src="{{ featured.image | image_url: width: 900 }}"
                 alt="{{ featured.image.alt | default: featured.title | escape }}"
                 width="900" height="675"
                 loading="eager"
                 style="width:100%;height:100%;object-fit:cover;">
          {%- else -%}
            <div class="img-placeholder" style="height:100%;font-size:4rem;">✨</div>
          {%- endif -%}
        </div>
        <div>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;">
            {%- for tag in featured.tags -%}
              <span class="badge badge-burgundy">{{ tag }}</span>
            {%- endfor -%}
          </div>
          <h2 style="font-family:var(--font-serif);font-size:clamp(1.5rem,2.5vw,2.25rem);color:var(--espresso);margin-bottom:1rem;line-height:1.2;">
            <a href="{{ featured.url }}" style="color:inherit;text-decoration:none;">{{ featured.title }}</a>
          </h2>
          <p style="color:var(--text-muted);margin-bottom:1.5rem;line-height:1.7;">
            {{ featured.excerpt | default: featured.content | strip_html | truncate: 180 }}
          </p>
          <div style="display:flex;align-items:center;gap:1.5rem;">
            <div style="font-size:0.8125rem;color:var(--text-muted);">
              {{ featured.published_at | date: "%d %B %Y" }} · {{ featured.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read
            </div>
            <a href="{{ featured.url }}" class="btn btn-primary btn-sm">Read Article →</a>
          </div>
        </div>
      </div>

      {%- comment -%} Article grid {%- endcomment -%}
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:2rem;">
        {%- for article in blog.articles offset: 1 -%}
          <article class="journal-card reveal" data-delay="{{ forloop.index0 | modulo: 3 }}">
            <a href="{{ article.url }}" class="journal-card-link">
              <div style="border-radius:12px;overflow:hidden;aspect-ratio:16/9;margin-bottom:1.25rem;">
                {%- if article.image -%}
                  <img src="{{ article.image | image_url: width: 700 }}"
                       alt="{{ article.image.alt | default: article.title | escape }}"
                       width="700" height="394"
                       loading="lazy"
                       style="width:100%;height:100%;object-fit:cover;transition:transform 0.4s ease;">
                {%- else -%}
                  <div class="img-placeholder" style="height:100%;font-size:2.5rem;">📖</div>
                {%- endif -%}
              </div>
              <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.75rem;">
                {%- for tag in article.tags limit: 2 -%}
                  <span class="badge badge-burgundy">{{ tag }}</span>
                {%- endfor -%}
              </div>
              <h3 style="font-family:var(--font-serif);font-size:1.25rem;color:var(--espresso);margin-bottom:0.5rem;line-height:1.3;">{{ article.title }}</h3>
              <p style="font-size:0.875rem;color:var(--text-muted);line-height:1.6;margin-bottom:1rem;">
                {{ article.excerpt | default: article.content | strip_html | truncate: 120 }}
              </p>
              <p style="font-size:0.8125rem;color:var(--text-muted);">
                {{ article.published_at | date: "%d %B %Y" }} · {{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read
              </p>
            </a>
          </article>
        {%- endfor -%}
      </div>

      {%- comment -%} Pagination {%- endcomment -%}
      {%- if paginate.pages > 1 -%}
        <div class="pagination" style="margin-top:4rem;">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="btn btn-ghost btn-sm">← Previous</a>
          {%- endif -%}
          <span style="font-size:0.875rem;color:var(--text-muted);">
            Page {{ paginate.current_page }} of {{ paginate.pages }}
          </span>
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="btn btn-ghost btn-sm">Next →</a>
          {%- endif -%}
        </div>
      {%- endif -%}

    {%- else -%}
      <div style="text-align:center;padding:5rem 0;">
        <div style="font-size:3rem;margin-bottom:1rem;">📖</div>
        <p style="font-family:var(--font-serif);font-size:1.5rem;color:var(--espresso);margin-bottom:0.75rem;">The journal is coming soon.</p>
        <p style="color:var(--text-muted);">We're writing things worth reading.</p>
      </div>
    {%- endif -%}
  </div>
</section>
{%- endpaginate -%}
