{% comment %} PLAYMATE LABS — Journal / Blog Template {% endcomment %}
{{ 'journal.css' | asset_url | stylesheet_tag }}
{{ 'journal.js' | asset_url | script_tag }}

{%- assign blog_handle = blog.handle | default: 'journal' -%}

{%- paginate blog.articles by 9 -%}

<!-- JOURNAL HERO -->
<section class="journal-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="breadcrumb-sep">›</span>
      <span>{{ blog.title | default: 'Journal' }}</span>
    </div>
    <div class="journal-hero-inner">
      <span class="section-eyebrow">{{ settings.journal_eyebrow | default: 'The Playmate Journal' }}</span>
      <h1 class="journal-hero-title">{{ settings.journal_heading | default: 'Culture, rituals &amp; relationship experiments.' }}</h1>
      <p class="journal-hero-subtitle">{{ settings.journal_subtext | default: 'Editorial content for modern couples — date ideas, sensory rituals, event recaps and the cultural conversation around modern relationships.' }}</p>
    </div>

    <!-- Category Filter Pills -->
    <div class="journal-filters" id="journal-filters">
      <a href="{{ blog.url }}" class="filter-btn{% unless current_tags %} active{% endunless %}">All</a>
      <a href="{{ blog.url }}/tagged/date-night" class="filter-btn{% if current_tags contains 'date night' %} active{% endif %}">Date Night</a>
      <a href="{{ blog.url }}/tagged/relationships" class="filter-btn{% if current_tags contains 'relationships' %} active{% endif %}">Relationships</a>
      <a href="{{ blog.url }}/tagged/intimacy" class="filter-btn{% if current_tags contains 'intimacy' %} active{% endif %}">Intimacy</a>
      <a href="{{ blog.url }}/tagged/aphrodisiac-chocolate" class="filter-btn{% if current_tags contains 'aphrodisiac chocolate' %} active{% endif %}">Aphrodisiac Chocolate</a>
      <a href="{{ blog.url }}/tagged/science" class="filter-btn{% if current_tags contains 'science' %} active{% endif %}">Science</a>
      <a href="{{ blog.url }}/tagged/sensory" class="filter-btn{% if current_tags contains 'sensory' %} active{% endif %}">Sensory</a>
    </div>
  </div>
</section>

{%- if blog.articles.size > 0 -%}
  {%- assign featured = blog.articles.first -%}

  <!-- FEATURED ARTICLE -->
  <section class="journal-featured section-sm">
    <div class="container">
      <a href="{{ featured.url }}" class="journal-feature-grid reveal">
        <div class="journal-feature-img">
          {%- if featured.image -%}
            <img src="{{ featured.image | image_url: width: 900 }}" alt="{{ featured.image.alt | escape }}" loading="lazy">
          {%- else -%}
            <div class="img-placeholder journal-feature-placeholder">
              <span>💭</span>
            </div>
          {%- endif -%}
        </div>
        <div class="journal-feature-content">
          <p class="journal-featured-label">
            Featured
            {%- if featured.tags.size > 0 -%}
              · {{ featured.tags.first }}
            {%- endif -%}
          </p>
          <h2 class="journal-feature-title">{{ featured.title }}</h2>
          <p class="journal-feature-excerpt">{{ featured.excerpt_or_content | strip_html | truncate: 200 }}</p>
          <div class="journal-feature-meta">
            <span>By {{ featured.author }}</span>
            <span>·</span>
            <span>{{ featured.published_at | date: '%b %d, %Y' }}</span>
            <span>·</span>
            <span>{{ featured.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
          </div>
          <span class="btn btn-primary btn-sm">Read the Full Story</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ARTICLES GRID -->
  <section class="journal-grid-section section bg-ivory">
    <div class="container">
      <div class="journal-articles-grid" id="journal-grid">
        {%- for article in blog.articles offset: 1 -%}
          {%- assign tag_handle = article.tags.first | handleize -%}
          <a href="{{ article.url }}" class="journal-card reveal" data-category="{{ tag_handle }}" data-delay="{{ forloop.index0 | modulo: 3 }}">
            <div class="journal-card-img">
              {%- if article.image -%}
                <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.image.alt | escape }}" loading="lazy">
              {%- else -%}
                {%- assign placeholders = '🧪,🌃,🎭,🧠,🌹,🕯️,💌,🫀' | split: ',' -%}
                {%- assign ph = forloop.index0 | modulo: 8 -%}
                <div class="img-placeholder">
                  <span>{{ placeholders[ph] }}</span>
                </div>
              {%- endif -%}
            </div>
            <div class="journal-card-body">
              <p class="journal-card-category">{{ article.tags.first | default: 'Journal' }}</p>
              <h3 class="journal-card-title">{{ article.title }}</h3>
              <p class="journal-card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 130 }}</p>
              <div class="journal-card-meta">
                <span>{{ article.published_at | date: '%b %d, %Y' }}</span>
                <span>·</span>
                <span>{{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>

      <!-- Pagination -->
      {%- if paginate.pages > 1 -%}
        <div class="journal-pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="btn btn-secondary btn-sm">← Newer</a>
          {%- endif -%}
          <span class="journal-page-info">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="btn btn-secondary btn-sm">Older →</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </section>

{%- else -%}
  <section class="section">
    <div class="container" style="text-align:center;padding:5rem 0;">
      <p style="font-size:3rem;margin-bottom:1rem;">📖</p>
      <h2 style="font-family:var(--font-serif);font-size:2rem;margin-bottom:1rem;">Coming Soon</h2>
      <p style="color:var(--text-muted);max-width:400px;margin:0 auto 2rem;">The Playmate Journal launches soon — editorial content for modern couples.</p>
      <a href="{{ routes.root_url }}" class="btn btn-primary">Back to Home</a>
    </div>
  </section>
{%- endif -%}

<!-- NEWSLETTER CTA -->
{%- if settings.journal_show_newsletter -%}
<section class="journal-newsletter">
  <div class="container">
    <div class="journal-newsletter-inner">
      <div>
        <span class="section-eyebrow" style="color:var(--gold);">{{ settings.journal_newsletter_eyebrow | default: 'Stay in the culture' }}</span>
        <h2>{{ settings.journal_newsletter_heading | default: 'Get new stories delivered to your inbox' }}</h2>
        <p>{{ settings.journal_newsletter_subtext | default: 'Weekly reads on modern relationships, rituals and sensory date nights.' }}</p>
      </div>
      <form action="/contact#contact_form" method="post" class="journal-newsletter-form" id="journal-newsletter-form">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[tags]" value="journal-subscriber,newsletter">
        <div class="journal-newsletter-fields">
          <input type="email" name="contact[email]" placeholder="{{ settings.journal_newsletter_placeholder | default: 'your@email.com' }}" required class="form-input">
          <button type="submit" class="btn btn-gold">{{ settings.journal_newsletter_cta | default: 'Subscribe' }}</button>
        </div>
        <p style="font-size:0.75rem;color:rgba(245,239,230,0.4);margin-top:0.75rem;">No spam. Unsubscribe any time.</p>
      </form>
    </div>
  </div>
</section>
{%- endif -%}

{%- endpaginate -%}

