{% comment %} PLAYMATE LABS — Article Template (Journal Post) {% endcomment %}
{{ 'journal.css' | asset_url | stylesheet_tag }}

<article class="article-page" itemscope itemtype="https://schema.org/Article">

  <!-- ARTICLE HERO -->
  <section class="article-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="breadcrumb-sep">›</span>
        <a href="{{ blog.url }}">{{ blog.title | default: 'Journal' }}</a>
        <span class="breadcrumb-sep">›</span>
        <span>{{ article.title | truncate: 40 }}</span>
      </div>

      <div class="article-hero-meta">
        {%- for tag in article.tags -%}
          <span class="article-tag">{{ tag }}</span>
        {%- endfor -%}
      </div>

      <h1 class="article-hero-title" itemprop="headline">{{ article.title }}</h1>
      <p class="article-hero-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 200 }}</p>

      <div class="article-meta-row">
        <div class="article-author-avatar">
          <span>{{ article.author | slice: 0 }}</span>
        </div>
        <div class="article-meta-details">
          <span itemprop="author" itemscope itemtype="https://schema.org/Person">
            <span itemprop="name">{{ article.author }}</span>
          </span>
          <span class="article-meta-sep">·</span>
          <time itemprop="datePublished" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
            {{ article.published_at | date: '%B %d, %Y' }}
          </time>
          <span class="article-meta-sep">·</span>
          <span>{{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
        </div>
      </div>
    </div>

    {%- if article.image -%}
      <div class="article-hero-img">
        <img
          src="{{ article.image | image_url: width: 1400 }}"
          alt="{{ article.image.alt | escape }}"
          itemprop="image"
          loading="eager"
        >
      </div>
    {%- endif -%}
  </section>

  <!-- ARTICLE CONTENT -->
  <section class="article-content-section">
    <div class="container">
      <div class="article-layout">

        <!-- Main Content -->
        <div class="article-body" itemprop="articleBody">
          {{ article.content }}
        </div>

        <!-- Sidebar -->
        <aside class="article-sidebar">

          <!-- Author Card -->
          <div class="article-sidebar-card">
            <h4 class="article-sidebar-heading">About the Author</h4>
            <div class="article-author-card">
              <div class="article-author-big-avatar">
                <span>{{ article.author | slice: 0 }}</span>
              </div>
              <div>
                <p class="article-author-name">{{ article.author }}</p>
                <p class="article-author-role">Playmate Labs Editorial</p>
              </div>
            </div>
          </div>

          <!-- Tags -->
          {%- if article.tags.size > 0 -%}
          <div class="article-sidebar-card">
            <h4 class="article-sidebar-heading">Filed under</h4>
            <div class="article-tag-list">
              {%- for tag in article.tags -%}
                <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="article-tag">{{ tag }}</a>
              {%- endfor -%}
            </div>
          </div>
          {%- endif -%}

          <!-- Share -->
          <div class="article-sidebar-card">
            <h4 class="article-sidebar-heading">Share this story</h4>
            <div class="article-share-btns">
              <a href="https://www.instagram.com/" target="_blank" rel="noopener" class="article-share-btn instagram">
                <i class="fab fa-instagram"></i> Instagram
              </a>
              <a href="https://twitter.com/intent/tweet?text={{ article.title | url_encode }}&url={{ shop.url }}{{ article.url | url_encode }}" target="_blank" rel="noopener" class="article-share-btn twitter">
                <i class="fab fa-twitter"></i> Twitter
              </a>
            </div>
          </div>

          <!-- Newsletter Sidebar -->
          <div class="article-sidebar-newsletter">
            <span class="section-eyebrow" style="color:var(--gold);font-size:0.6875rem;">Stay in the loop</span>
            <h4>New drops &amp; rituals to your inbox</h4>
            <form action="/contact#contact_form" method="post" class="article-newsletter-form">
              <input type="hidden" name="form_type" value="customer">
              <input type="hidden" name="utf8" value="✓">
              <input type="hidden" name="contact[tags]" value="newsletter,journal-reader">
              <input type="email" name="contact[email]" placeholder="your@email.com" required class="form-input form-input-sm">
              <button type="submit" class="btn btn-primary btn-sm" style="width:100%;justify-content:center;margin-top:0.5rem;">Subscribe</button>
            </form>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- RELATED ARTICLES -->
  {%- if blog.articles.size > 1 -%}
  <section class="article-related section bg-ivory">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Keep Reading</span>
        <h2>More from the Journal</h2>
      </div>
      <div class="article-related-grid">
        {%- assign count = 0 -%}
        {%- for a in blog.articles -%}
          {%- if a.id != article.id and count < 3 -%}
            <a href="{{ a.url }}" class="journal-card reveal">
              <div class="journal-card-img">
                {%- if a.image -%}
                  <img src="{{ a.image | image_url: width: 600 }}" alt="{{ a.image.alt | escape }}" loading="lazy">
                {%- else -%}
                  <div class="img-placeholder"><span>📖</span></div>
                {%- endif -%}
              </div>
              <div class="journal-card-body">
                <p class="journal-card-category">{{ a.tags.first | default: 'Journal' }}</p>
                <h3 class="journal-card-title">{{ a.title }}</h3>
                <div class="journal-card-meta">
                  <span>{{ a.published_at | date: '%b %d, %Y' }}</span>
                </div>
              </div>
            </a>
            {%- assign count = count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div style="text-align:center;margin-top:2.5rem;">
        <a href="{{ blog.url }}" class="btn btn-secondary">View All Articles</a>
      </div>
    </div>
  </section>
  {%- endif -%}

</article>

<!-- Structured Data -->
<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "Article",
  "headline": {{ article.title | json }},
  "author": {
    "@type": "Person",
    "name": {{ article.author | json }}
  },
  "datePublished": "{{ article.published_at | date: '%Y-%m-%d' }}",
  "description": {{ article.excerpt_or_content | strip_html | truncate: 200 | json }},
  "publisher": {
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "logo": {
      "@type": "ImageObject",
      "url": "{{ settings.share_image | image_url: width: 200 }}"
    }
  }
  {%- if article.image -%}
  ,"image": "{{ article.image | image_url: width: 1200 }}"
  {%- endif -%}
}
</script>
