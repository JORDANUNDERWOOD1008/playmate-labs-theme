<!-- ══════════ STICKY ATC (mobile) ══════════ -->
<div class="sticky-atc-bar" id="sticky-atc" style="display:none;position:fixed;bottom:0;left:0;right:0;background:white;border-top:1px solid var(--border-light);padding:1rem;z-index:200;box-shadow:0 -4px 20px rgba(0,0,0,0.1);">
  <div style="display:flex;align-items:center;gap:1rem;max-width:600px;margin:0 auto;">
    <div style="flex:1;">
      <p style="font-size:0.875rem;font-weight:600;color:var(--espresso);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ product.title }}</p>
      <p style="font-size:0.875rem;color:var(--burgundy);font-weight:600;">{{ product.selected_or_first_available_variant.price | money }}</p>
    </div>
    <button class="product-atc-btn" style="flex:none;width:auto;padding:0 1.5rem;height:48px;" onclick="document.getElementById('atc-btn').click();">Add to Cart</button>
  </div>
</div>

<script>
  // Gallery switcher
  function switchImage(src, thumb) {
    var img = document.getElementById('main-product-img');
    if (img) img.src = src;
    document.querySelectorAll('.product-thumb').forEach(function(t) { t.classList.remove('active'); });
    if (thumb) thumb.classList.add('active');
  }

  // Quantity adjuster
  function adjustQty(delta) {
    var input = document.getElementById('quantity');
    var cartQty = document.getElementById('cart-qty');
    var val = parseInt(input.value) + delta;
    if (val < 1) val = 1;
    if (val > 10) val = 10;
    input.value = val;
    if (cartQty) cartQty.value = val;
  }
  document.getElementById('quantity').addEventListener('change', function() {
    var v = parseInt(this.value) || 1;
    this.value = Math.max(1, Math.min(10, v));
    var cq = document.getElementById('cart-qty');
    if (cq) cq.value = this.value;
  });

  // Accordion
  function toggleAccordion(btn) {
    var body = btn.nextElementSibling;
    var icon = btn.querySelector('i');
    body.classList.toggle('open');
    btn.classList.toggle('open');
    if (icon) {
      icon.classList.toggle('fa-chevron-down');
      icon.classList.toggle('fa-chevron-up');
    }
  }

  // Purchase options toggle
  document.querySelectorAll('.product-purchase-option input').forEach(function(radio) {
    radio.addEventListener('change', function() {
      document.querySelectorAll('.product-purchase-option').forEach(function(o) { o.classList.remove('selected'); });
      this.closest('.product-purchase-option').classList.add('selected');
    });
  });

  // Sticky ATC bar
  var atcBtn = document.getElementById('atc-btn');
  var stickyAtc = document.getElementById('sticky-atc');
  if (atcBtn && stickyAtc) {
    var obs = new IntersectionObserver(function(e) {
      stickyAtc.style.display = e[0].isIntersecting ? 'none' : 'flex';
    }, { threshold: 0 });
    obs.observe(atcBtn);
  }

  // ATC form with cart drawer
  var atcForm = document.getElementById('add-to-cart-form');
  if (atcForm) {
    atcForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var variantId = document.getElementById('variant-id').value;
      var qty = parseInt(document.getElementById('quantity').value) || 1;
      var btn = document.getElementById('atc-btn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Adding...';
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: qty })
      })
      .then(function(r) { return r.json(); })
      .then(function() {
        btn.innerHTML = '<i class="fas fa-check"></i> Added to cart!';
        btn.style.background = '#2d7a3a';
        // Open cart drawer if available
        var cartOpen = document.querySelector('[data-cart-open]');
        if (cartOpen) cartOpen.click();
        // Refresh cart count
        return fetch('/cart.js');
      })
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var counts = document.querySelectorAll('.cart-count');
        counts.forEach(function(c) { c.textContent = cart.item_count; });
        setTimeout(function() {
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-shopping-bag"></i> Add to Cart';
          btn.style.background = '';
        }, 2500);
      })
      .catch(function(err) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-shopping-bag"></i> Add to Cart';
        console.error('ATC error:', err);
      });
    });
  }
</script>
