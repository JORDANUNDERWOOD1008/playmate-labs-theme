{% comment %}
  PLAYMATE LABS — LOGIN TEMPLATE
  File: templates/customers/login.liquid
{% endcomment %}

<section style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:calc(var(--nav-height)+3rem) 0;background:var(--ivory);">
  <div style="width:100%;max-width:440px;margin:0 auto;padding:0 1.5rem;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <h1 style="font-family:var(--font-serif);font-size:2rem;color:var(--espresso);margin-bottom:0.5rem;">Welcome Back</h1>
      <p style="color:var(--text-muted);">Sign in to your Playmate Labs account.</p>
    </div>

    {%- form 'customer_login', id: 'login-form' -%}
      {%- if form.errors -%}
        <div class="form-error" style="margin-bottom:1.5rem;padding:1rem;background:rgba(107,30,58,0.08);border:1px solid var(--burgundy);border-radius:10px;color:var(--burgundy);font-size:0.875rem;">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}
      <div style="display:flex;flex-direction:column;gap:0.875rem;margin-bottom:1.5rem;">
        <input type="email" name="customer[email]" placeholder="Email address" class="form-input" required autocomplete="email" autofocus>
        <input type="password" name="customer[password]" placeholder="Password" class="form-input" required autocomplete="current-password">
      </div>
      <button type="submit" class="btn btn-primary btn-lg" style="width:100%;justify-content:center;margin-bottom:1rem;">
        Sign In
      </button>
      <div style="text-align:center;font-size:0.875rem;">
        <a href="{{ routes.account_recover_url }}" style="color:var(--burgundy);">Forgot your password?</a>
      </div>
    {%- endform -%}

    <div style="text-align:center;margin-top:2rem;padding-top:2rem;border-top:1px solid var(--border-color);">
      <p style="font-size:0.875rem;color:var(--text-muted);margin-bottom:1rem;">New to Playmate Labs?</p>
      <a href="{{ routes.account_register_url }}" class="btn btn-ghost btn-lg" style="width:100%;justify-content:center;">
        Create Free Account
      </a>
    </div>
  </div>
</section>
