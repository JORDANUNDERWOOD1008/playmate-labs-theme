{% comment %}
  PLAYMATE LABS — CART PAGE TEMPLATE
  File: templates/cart.liquid
{% endcomment %}

{%- comment -%} CART PAGE {%- endcomment -%}
<section style="padding:calc(var(--nav-height)+3rem) 0 6rem;min-height:80vh;background:var(--ivory);">
  <div class="container">
    <div class="breadcrumb" style="margin-bottom:2rem;">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="breadcrumb-sep">›</span>
      <span>Your Cart</span>
    </div>
    <h1 style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,3rem);color:var(--espresso);margin-bottom:2.5rem;">
      Your Cart
      {%- if cart.item_count > 0 -%}
        <span style="font-size:1rem;color:var(--text-muted);font-family:var(--font-body);font-weight:400;margin-left:0.75rem;">
          ({{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }})
        </span>
      {%- endif -%}
    </h1>

    {%- if cart.item_count > 0 -%}
      {%- form 'cart', cart, id: 'cart-form' -%}
        <div style="display:grid;grid-template-columns:1fr 380px;gap:3rem;align-items:start;" class="cart-page-grid">

          {%- comment -%} CART ITEMS {%- endcomment -%}
          <div>
            {%- for item in cart.items -%}
              <div class="cart-page-item" style="display:grid;grid-template-columns:100px 1fr auto;gap:1.5rem;align-items:start;padding:2rem 0;border-bottom:1px solid var(--border-color);">

                {%- comment -%} Item Image {%- endcomment -%}
                <a href="{{ item.url }}">
                  {%- if item.image -%}
                    <img src="{{ item.image | image_url: width: 200 }}"
                         alt="{{ item.title | escape }}"
                         width="200" height="200"
                         loading="lazy"
                         style="width:100%;border-radius:12px;object-fit:cover;">
                  {%- else -%}
                    <div class="img-placeholder" style="width:100%;aspect-ratio:1;border-radius:12px;font-size:2rem;">🌹</div>
                  {%- endif -%}
                </a>

                {%- comment -%} Item Info {%- endcomment -%}
                <div>
                  <a href="{{ item.url }}" style="text-decoration:none;">
                    <h3 style="font-family:var(--font-serif);font-size:1.125rem;color:var(--espresso);margin-bottom:0.25rem;">{{ item.product.title }}</h3>
                    {%- unless item.product.has_only_default_variant -%}
                      <p style="font-size:0.8125rem;color:var(--text-muted);margin-bottom:0.25rem;">{{ item.variant.title }}</p>
                    {%- endunless -%}
                  </a>
                  {%- if item.product.metafields.custom.short_desc -%}
                    <p style="font-size:0.8125rem;color:var(--text-muted);margin-top:0.5rem;">{{ item.product.metafields.custom.short_desc | truncate: 80 }}</p>
                  {%- endif -%}

                  {%- comment -%} Qty Selector {%- endcomment -%}
                  <div style="display:flex;align-items:center;gap:1rem;margin-top:1rem;">
                    <div class="qty-selector" style="width:auto;">
                      <button type="button" class="qty-btn cart-page-dec"
                              data-key="{{ item.key }}"
                              aria-label="Decrease quantity">−</button>
                      <input type="number"
                             name="updates[]"
                             id="updates_{{ item.key }}"
                             value="{{ item.quantity }}"
                             min="0"
                             class="qty-value"
                             style="width:2.5rem;text-align:center;border:none;background:transparent;"
                             aria-label="Quantity for {{ item.title | escape }}">
                      <button type="button" class="qty-btn cart-page-inc"
                              data-key="{{ item.key }}"
                              aria-label="Increase quantity">+</button>
                    </div>
                    <button type="button"
                            class="cart-page-remove"
                            data-key="{{ item.key }}"
                            style="font-size:0.8125rem;color:var(--text-muted);background:none;border:none;cursor:pointer;text-decoration:underline;padding:0;">
                      Remove
                    </button>
                  </div>
                </div>

                {%- comment -%} Price {%- endcomment -%}
                <div style="text-align:right;">
                  {%- if item.original_line_price != item.final_line_price -%}
                    <p style="text-decoration:line-through;color:var(--text-muted);font-size:0.875rem;">{{ item.original_line_price | money }}</p>
                  {%- endif -%}
                  <p style="font-weight:600;font-size:1rem;color:var(--espresso);">{{ item.final_line_price | money }}</p>
                </div>

              </div>
            {%- endfor -%}

            {%- comment -%} CROSS-SELLS {%- endcomment -%}
            {%- assign cross_sell_col = collections['ritual-add-ons'] -%}
            {%- if cross_sell_col.products.size > 0 -%}
              <div style="margin-top:3rem;">
                <h3 style="font-family:var(--font-serif);font-size:1.25rem;color:var(--espresso);margin-bottom:1.5rem;">Complete Your Ritual</h3>
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1.25rem;">
                  {%- for product in cross_sell_col.products limit: 3 -%}
                    <div style="border:1px solid var(--border-color);border-radius:12px;padding:1.25rem;text-align:center;">
                      {%- if product.featured_image -%}
                        <img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ product.title | escape }}" width="200" height="200" loading="lazy" style="width:80px;height:80px;object-fit:cover;border-radius:8px;margin-bottom:0.75rem;">
                      {%- else -%}
                        <div style="font-size:2.5rem;margin-bottom:0.75rem;">✨</div>
                      {%- endif -%}
                      <p style="font-size:0.875rem;font-weight:500;margin-bottom:0.25rem;">{{ product.title }}</p>
                      <p style="font-size:0.8125rem;color:var(--text-muted);margin-bottom:0.75rem;">{{ product.price | money }}</p>
                      <button class="btn btn-ghost btn-sm quick-add-to-cart"
                              data-variant-id="{{ product.first_available_variant.id }}"
                              style="width:100%;justify-content:center;">
                        + Add
                      </button>
                    </div>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} ORDER SUMMARY {%- endcomment -%}
          <div style="background:var(--cream);border:1px solid var(--border-color);border-radius:20px;padding:2rem;position:sticky;top:calc(var(--nav-height)+1rem);">
            <h3 style="font-family:var(--font-serif);font-size:1.25rem;color:var(--espresso);margin-bottom:1.5rem;">Order Summary</h3>

            {%- comment -%} Line items summary {%- endcomment -%}
            <div style="margin-bottom:1.5rem;">
              {%- for item in cart.items -%}
                <div style="display:flex;justify-content:space-between;font-size:0.875rem;margin-bottom:0.5rem;">
                  <span style="color:var(--text-muted);">{{ item.title | truncate: 30 }} × {{ item.quantity }}</span>
                  <span>{{ item.final_line_price | money }}</span>
                </div>
              {%- endfor -%}
            </div>

            {%- comment -%} Discount code {%- endcomment -%}
            <div style="margin-bottom:1.5rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border-color);">
              <p style="font-size:0.8125rem;color:var(--text-muted);margin-bottom:0.5rem;">Discount code</p>
              <div style="display:flex;gap:0.5rem;">
                <input type="text" name="discount" placeholder="Enter code" class="form-input" style="flex:1;font-size:0.875rem;">
                <button type="submit" name="checkout" class="btn btn-ghost btn-sm">Apply</button>
              </div>
            </div>

            {%- comment -%} Totals {%- endcomment -%}
            {%- if cart.total_discounts > 0 -%}
              <div style="display:flex;justify-content:space-between;font-size:0.875rem;margin-bottom:0.5rem;">
                <span style="color:var(--text-muted);">Subtotal</span>
                <span>{{ cart.original_total_price | money }}</span>
              </div>
              <div style="display:flex;justify-content:space-between;font-size:0.875rem;margin-bottom:1rem;color:var(--burgundy);">
                <span>Discounts</span>
                <span>− {{ cart.total_discounts | money }}</span>
              </div>
            {%- endif -%}
            <div style="display:flex;justify-content:space-between;font-size:1rem;font-weight:700;color:var(--espresso);margin-bottom:0.5rem;">
              <span>Subtotal</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <p style="font-size:0.75rem;color:var(--text-muted);margin-bottom:1.75rem;">
              Shipping &amp; taxes calculated at checkout
            </p>

            <button type="submit"
                    name="checkout"
                    class="btn btn-primary btn-lg"
                    style="width:100%;justify-content:center;margin-bottom:0.75rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:0.5rem;">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
              Checkout Securely — {{ cart.total_price | money }}
            </button>

            <a href="{{ routes.all_products_collection_url }}" class="btn btn-ghost btn-lg" style="width:100%;justify-content:center;">
              ← Continue Shopping
            </a>

            {%- comment -%} Trust {%- endcomment -%}
            <div style="display:flex;gap:1.5rem;justify-content:center;margin-top:1.5rem;flex-wrap:wrap;">
              <div style="display:flex;align-items:center;gap:0.375rem;font-size:0.75rem;color:var(--text-muted);">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                Secure Checkout
              </div>
              <div style="display:flex;align-items:center;gap:0.375rem;font-size:0.75rem;color:var(--text-muted);">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/></svg>
                Free delivery £60+
              </div>
              <div style="display:flex;align-items:center;gap:0.375rem;font-size:0.75rem;color:var(--text-muted);">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
                30-day returns
              </div>
            </div>
          </div>

        </div>
      {%- endform -%}

    {%- else -%}
      <div style="text-align:center;padding:6rem 0;">
        <div style="font-size:4rem;margin-bottom:1.5rem;">🛒</div>
        <h2 style="font-family:var(--font-serif);font-size:2rem;color:var(--espresso);margin-bottom:0.75rem;">Your cart is empty</h2>
        <p style="color:var(--text-muted);margin-bottom:2.5rem;font-size:1rem;">Time to start a ritual.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
          <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary btn-lg">Shop Now</a>
          <a href="{{ pages['5-day-experience'].url | default: '/pages/5-day-experience' }}" class="btn btn-ghost btn-lg">Free 5-Day Experience</a>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>
