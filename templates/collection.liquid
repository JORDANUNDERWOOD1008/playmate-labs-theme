{% comment %}
  PLAYMATE LABS — COLLECTION TEMPLATE
  File: templates/collection.liquid
  Used for: /collections/*, /collections/all
{% endcomment %}

{{ 'shop.css' | asset_url | stylesheet_tag }}
<script src="{{ 'shop.js' | asset_url }}" defer></script>

{%- paginate collection.products by 12 -%}

{%- comment -%} Shop Hero {%- endcomment -%}
<section class="shop-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="breadcrumb-sep">›</span>
      {%- if collection.handle != 'all' -%}
        <a href="{{ routes.all_products_collection_url }}">Shop</a>
        <span class="breadcrumb-sep">›</span>
      {%- endif -%}
      <span>{{ collection.title }}</span>
    </div>
    <div class="shop-hero-content">
      <span class="section-eyebrow">{{ collection.metafields.custom.eyebrow | default: 'The Collection' }}</span>
      <h1 class="heading-xl">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p class="body-lg" style="max-width:600px;margin-top:1rem;">{{ collection.description }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{%- comment -%} Featured Banner for specific collections {%- endcomment -%}
{%- if collection.handle == 'monthly-drops' or collection.handle == 'all' -%}
<section class="shop-featured-banner">
  <div class="container">
    <div class="shop-banner-grid">
      <a href="{{ collections['monthly-drops'].url }}" class="shop-banner-card shop-banner-primary">
        <div class="shop-banner-bg bg-dark">
          <div class="shop-banner-inner">
            <span class="badge badge-gold" style="margin-bottom:0.75rem;">Latest Drop</span>
            <h2 style="font-family:var(--font-serif);font-size:1.75rem;color:var(--cream);margin-bottom:0.75rem;">The Velvet Hour</h2>
            <p style="font-size:0.875rem;color:rgba(245,239,230,0.65);margin-bottom:1.25rem;">Limited drop — 47 kits remaining</p>
            <span class="btn btn-gold btn-sm">Shop Now</span>
          </div>
          <div style="font-size:6rem;opacity:0.15;position:absolute;right:1.5rem;bottom:1rem;">🍷</div>
        </div>
      </a>
      <a href="{{ pages['5-day-experience'].url | default: '/pages/5-day-experience' }}" class="shop-banner-card shop-banner-secondary">
        <div class="shop-banner-bg" style="background:linear-gradient(135deg,var(--burgundy-dark),var(--burgundy));">
          <div class="shop-banner-inner">
            <span class="badge badge-burgundy" style="margin-bottom:0.75rem;">Free Lead Magnet</span>
            <h2 style="font-family:var(--font-serif);font-size:1.5rem;color:var(--cream);margin-bottom:0.75rem;">5-Day Sensory Experience</h2>
            <p style="font-size:0.875rem;color:rgba(245,239,230,0.65);margin-bottom:1.25rem;">Free digital ritual for couples</p>
            <span class="btn btn-ghost btn-sm">Unlock Free</span>
          </div>
          <div style="font-size:5rem;opacity:0.15;position:absolute;right:1.5rem;bottom:1rem;">✨</div>
        </div>
      </a>
    </div>
  </div>
</section>
{%- endif -%}

{%- comment -%} Filter + Sort Toolbar {%- endcomment -%}
<section class="shop-toolbar">
  <div class="container">
    <div class="shop-toolbar-inner">
      <div class="shop-filter-row">
        {%- comment -%} Type filters {%- endcomment -%}
        <div class="shop-filters">
          <a href="{{ collection.url }}"
             class="filter-btn{% unless current_tags %} active{% endunless %}">
            All
          </a>
          {%- for type in shop.types -%}
            {%- if type != blank -%}
              <a href="{{ collection.url }}/{{ type | url_encode }}"
                 class="filter-btn{% if current_tags contains type %} active{% endif %}">
                {{ type }}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- comment -%} Sort {%- endcomment -%}
        <div class="shop-sort">
          <label for="sort-select" class="visually-hidden">Sort by</label>
          <select id="sort-select" class="sort-select" data-sort-url="{{ collection.url }}">
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}"{% if option.value == sort_by %} selected{% endif %}>
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
          <span class="shop-count">{{ collection.products_count }} products</span>
        </div>
      </div>
    </div>
  </div>
</section>

{%- comment -%} Product Grid {%- endcomment -%}
<section class="shop-grid-section">
  <div class="container">
    {%- if collection.products.size == 0 -%}
      <div class="empty-collection">
        <div style="font-size:3rem;margin-bottom:1rem;">✨</div>
        <h2 style="font-family:var(--font-serif);">Nothing here yet</h2>
        <p style="color:var(--text-muted);margin-bottom:2rem;">New products are on their way.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">Browse All Products</a>
      </div>
    {%- else -%}
      <div class="product-grid product-grid-3" id="product-grid">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product, show_badge: true, show_quick_add: true %}
        {%- endfor -%}
      </div>

      {%- comment -%} Pagination {%- endcomment -%}
      {%- if paginate.pages > 1 -%}
        <div class="pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="btn btn-ghost btn-sm pagination-prev">
              ← Previous
            </a>
          {%- endif -%}
          <div class="pagination-pages">
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="pagination-page">{{ part.title }}</a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span class="pagination-page active">{{ part.title }}</span>
                {%- else -%}
                  <span class="pagination-ellipsis">…</span>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="btn btn-ghost btn-sm pagination-next">
              Next →
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{%- endpaginate -%}

{%- comment -%} Compliance notice for consumables collection {%- endcomment -%}
{%- if collection.handle == 'consumables' or collection.handle contains 'food' -%}
<div class="compliance-notice container" style="margin:2rem auto;padding:1.5rem;border:1px solid var(--border-color);border-radius:12px;font-size:0.8125rem;color:var(--text-muted);">
  <strong>Allergen Information:</strong> Some products in this collection contain nuts, dairy, soy and gluten. Full ingredient lists and allergen information are available on each individual product page. If you have any dietary requirements or allergies, please review the full ingredients list before purchase. For queries contact <a href="mailto:hello@playmate-labs.com">hello@playmate-labs.com</a>.
</div>
{%- endif -%}
