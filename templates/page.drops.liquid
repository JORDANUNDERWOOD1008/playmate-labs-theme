{% comment %}
  PLAYMATE LABS — MONTHLY DROPS PAGE  v3
  File: templates/page.drops.liquid
  Used for: /pages/monthly-drops
  Mirrors: https://njpvfxya.gensparkspace.com/drops.html
{% endcomment %}

{{ 'drops.css' | asset_url | stylesheet_tag }}

{{ 'global.css' | asset_url | stylesheet_tag }}
{{ 'components.css' | asset_url | stylesheet_tag }}

{%- comment -%} Schema-driven colour overrides — mapped to new v4 settings IDs {%- endcomment -%}
<style>
  :root {
    --drops-hero-from:    {{ settings.drops_hero_bg_from    | default: '#1A0A06' }};
    --drops-hero-to:      {{ settings.drops_hero_bg_to      | default: '#2D1020' }};
    --drops-hero-h:       {{ settings.drops_hero_heading_color | default: 'var(--cream)' }};
    --drops-hero-italic:  {{ settings.drops_hero_italic_color  | default: 'var(--gold)' }};
    --drops-hero-sub:     {{ settings.drops_hero_subtext_color | default: 'rgba(245,239,230,0.65)' }};
    --drops-cd-bg:        {{ settings.drops_countdown_bg     | default: 'rgba(255,255,255,0.08)' }};
    --drops-cd-num:       {{ settings.drops_countdown_number_color | default: 'var(--cream)' }};
    --drops-cd-lbl:       {{ settings.drops_countdown_label_color  | default: 'rgba(245,239,230,0.5)' }};
    --drops-bar-fill:     {{ settings.drops_sold_bar_fill    | default: 'var(--gold)' }};
    --drops-bar-track:    {{ settings.drops_sold_bar_track   | default: 'rgba(255,255,255,0.12)' }};
    --drops-incl-bg:      {{ settings.drops_includes_card_bg | default: 'rgba(255,255,255,0.06)' }};
    --drops-incl-bd:      {{ settings.drops_includes_card_border | default: 'rgba(255,255,255,0.1)' }};
    --drops-incl-icon:    {{ settings.drops_includes_icon_color | default: 'var(--gold)' }};
    --drops-incl-name:    {{ settings.drops_includes_name_color | default: 'var(--cream)' }};
    --drops-sub-bg:       {{ settings.drops_sub_bg           | default: 'var(--ivory)' }};
    --drops-sub-card:     {{ settings.drops_sub_card_bg      | default: '#FFFFFF' }};
    --drops-sub-border:   {{ settings.drops_sub_card_border  | default: 'var(--gold)' }};
    --drops-sub-price:    {{ settings.drops_sub_price_color  | default: 'var(--burgundy)' }};
    --drops-past-bg:      {{ settings.drops_past_bg          | default: '#FFFFFF' }};
    --drops-past-card:    {{ settings.drops_past_card_bg     | default: 'var(--ivory)' }};
    --drops-sold-bg:      {{ settings.drops_past_sold_badge_bg   | default: 'rgba(0,0,0,0.5)' }};
    --drops-sold-tx:      {{ settings.drops_past_sold_badge_text | default: '#FFFFFF' }};
    /* Legacy aliases kept for drops.css compatibility */
    --drops-accent:       {{ settings.drops_hero_italic_color | default: 'var(--gold)' }};
    --drops-text:         {{ settings.drops_hero_heading_color | default: 'var(--cream)' }};
  }
</style>

<!-- ===== ANNOUNCEMENT STRIP ===== -->
{%- if settings.drops_announcement_text != blank -%}
<div class="drops-announcement" style="background:{{ settings.drops_announcement_bg | default: 'var(--espresso)' }};color:{{ settings.drops_announcement_text_color | default: 'var(--gold)' }};">
  {{ settings.drops_announcement_text }}
  {%- if settings.drops_announcement_link != blank -%}
    &nbsp;<a href="{{ settings.drops_announcement_link }}" style="color:var(--cream);text-decoration:underline;">{{ settings.drops_announcement_cta | default: 'Grab Yours →' }}</a>
  {%- endif -%}
</div>
{%- endif -%}

<!-- ===== HERO ===== -->
<section class="drops-hero">
  <div class="drops-hero-bg" {% if settings.drops_hero_image %}style="background-image:url('{{ settings.drops_hero_image | img_url: '1800x' }}');"{% endif %}>
    <div class="drops-hero-overlay"></div>
    <div class="container drops-hero-inner">
      <span class="drops-eyebrow">{{ settings.drops_eyebrow | default: 'A monthly cultural release' }}</span>
      <h1 class="drops-hero-heading">
        {{ settings.drops_hero_heading_line1 | default: 'Limited monthly drops' }}<br>
        <em>{{ settings.drops_hero_heading_italic | default: 'for modern relationships.' }}</em>
      </h1>
      <p class="drops-hero-sub">{{ settings.drops_hero_subtext | default: 'Every month we design a new themed date night kit — limited, beautiful and built around a ritual concept for two. Available for 30 days or until sold out.' }}</p>

      {%- comment -%} Drop preview icons {%- endcomment -%}
      <div class="drops-icon-strip">
        <div class="drops-icon-item drops-icon-active">🍷</div>
        <div class="drops-icon-item">🍫</div>
        <div class="drops-icon-item">🕯️</div>
        <div class="drops-icon-item">🃏</div>
        <div class="drops-icon-item">📖</div>
      </div>
    </div>
  </div>
</section>

<!-- ===== CURRENT DROP ===== -->
<section class="section drops-current" id="current-drop">
  <div class="container">

    {%- comment -%} Drop number / label {%- endcomment -%}
    <div class="drop-label-row">
      <span class="drop-number-badge">{{ settings.drops_current_number | default: 'Drop 08 — January 2025' }}</span>
      <span class="drop-status-badge badge-active">{{ settings.drops_current_status | default: 'Active Now' }}</span>
    </div>

    <div class="drops-current-grid">

      {%- comment -%} LEFT: visual / product {%- endcomment -%}
      <div class="drops-current-visual">
        {%- if settings.drops_current_image != blank -%}
          <img src="{{ settings.drops_current_image | img_url: '700x700', crop: 'center' }}" alt="{{ settings.drops_current_name | default: 'Current Drop' }}" class="drops-current-img">
        {%- else -%}
          <div class="drops-current-img-placeholder">
            <span class="drops-icon-hero">{{ settings.drops_current_icon | default: '🍷' }}</span>
            <span class="drops-current-name-overlay">{{ settings.drops_current_name | default: 'The Velvet Hour' }}</span>
          </div>
        {%- endif -%}

        {%- comment -%} Countdown {%- endcomment -%}
        {%- if settings.drops_show_countdown -%}
          <div class="drops-countdown-card" id="drop-countdown">
            <p class="drops-countdown-label">{{ settings.drops_countdown_label | default: 'Drop Closes In' }}</p>
            <div class="drops-countdown-timer">
              <div class="countdown-unit"><span class="countdown-num" id="cd-days">--</span><span class="countdown-label">Days</span></div>
              <div class="countdown-sep">:</div>
              <div class="countdown-unit"><span class="countdown-num" id="cd-hours">--</span><span class="countdown-label">Hours</span></div>
              <div class="countdown-sep">:</div>
              <div class="countdown-unit"><span class="countdown-num" id="cd-mins">--</span><span class="countdown-label">Mins</span></div>
              <div class="countdown-sep">:</div>
              <div class="countdown-unit"><span class="countdown-num" id="cd-secs">--</span><span class="countdown-label">Secs</span></div>
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} RIGHT: info {%- endcomment -%}
      <div class="drops-current-info">
        <span class="section-eyebrow" style="color:{{ settings.drops_accent_color | default: 'var(--gold)' }};">{{ settings.drops_current_theme_label | default: "This Month's Theme:" }} <em>{{ settings.drops_current_theme | default: 'Sensory Intimacy' }}</em></span>
        <h2 class="drops-current-title">{{ settings.drops_current_name | default: 'The Velvet Hour' }}</h2>
        <p class="drops-current-desc">{{ settings.drops_current_description | default: 'An evening ritual for two. Built around the science of sensory intimacy — dark, rich flavour, warm amber light, and conversation prompts that feel like foreplay for your relationship.' }}</p>

        {%- comment -%} Best For tags {%- endcomment -%}
        <div class="drops-best-for">
          <span class="drops-meta-label">Best For</span>
          <div class="drops-tags">
            {%- assign best_for = settings.drops_best_for | default: 'Established couples,Anniversaries,Valentine\'s Day,Gift ideas,At-home date nights' -%}
            {%- assign best_for_items = best_for | split: ',' -%}
            {%- for item in best_for_items -%}
              <span class="drops-tag">{{ item | strip }}</span>
            {%- endfor -%}
          </div>
        </div>

        {%- comment -%} What's Inside {%- endcomment -%}
        <div class="drops-whats-inside">
          <span class="drops-meta-label">What's Inside</span>
          <ul class="drops-contents-list">
            {%- assign contents = settings.drops_contents | default: 'Madagascan Dark Chocolate (120g),Amber Vetiver Candle (150ml),The Connection Game (52 cards),Velvet Hour Ritual Guide,Digital Companion Access,Luxury Gift Packaging' -%}
            {%- assign content_items = contents | split: ',' -%}
            {%- for item in content_items -%}
              <li><i class="fas fa-check" style="color:var(--gold);margin-right:0.5rem;"></i>{{ item | strip }}</li>
            {%- endfor -%}
          </ul>
        </div>

        {%- comment -%} Stock bar {%- endcomment -%}
        {%- assign remaining = settings.drops_remaining_count | default: 47 -%}
        {%- assign total = settings.drops_total_count | default: 200 -%}
        {%- assign pct_sold = remaining | times: 100 | divided_by: total -%}
        <div class="drops-stock-section">
          <div class="drops-stock-row">
            <span class="drops-stock-label">Kits remaining</span>
            <span class="drops-stock-count"><strong>{{ remaining }}</strong> of {{ total }}</span>
          </div>
          <div class="drops-stock-bar">
            <div class="drops-stock-fill" style="width:{{ pct_sold }}%;"></div>
          </div>
          <p class="drops-stock-sub">{{ 100 | minus: pct_sold }}% sold. {{ settings.drops_stock_sub | default: 'Drop closes January 31st.' }}</p>
        </div>

        {%- comment -%} CTA {%- endcomment -%}
        <div class="drops-cta-row">
          {%- if settings.drops_current_product != blank -%}
            <a href="{{ settings.drops_current_product.url }}" class="btn btn-gold" style="font-size:1.0625rem;padding:1rem 2rem;">
              {{ settings.drops_cta_text | default: 'Get This Drop' }} — £{{ settings.drops_current_product.price | money_without_currency }}
            </a>
          {%- else -%}
            <a href="{{ collections['monthly-drops'].url | default: '/collections/monthly-drops' }}" class="btn btn-gold" style="font-size:1.0625rem;padding:1rem 2rem;">
              {{ settings.drops_cta_text | default: 'Get This Drop' }} — £{{ settings.drops_current_price | default: '68' }}
            </a>
          {%- endif -%}
          <p class="drops-sub-cta">or join the <a href="#subscribe" style="color:var(--gold);">drop subscription</a> for £{{ settings.drops_sub_price | default: '58' }}/mo</p>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- ===== SUBSCRIPTION ===== -->
<section class="section drops-subscribe" id="subscribe">
  <div class="container">
    <div class="drops-subscribe-grid">

      <div class="drops-subscribe-info">
        <span class="section-eyebrow" style="color:{{ settings.drops_accent_color | default: 'var(--gold)' }};">Never Miss a Drop</span>
        <h2 class="drops-section-heading">
          {{ settings.drops_sub_heading_1 | default: 'The Monthly Drop' }}<br>
          <em style="color:{{ settings.drops_sub_italic_color | default: 'var(--gold)' }};">{{ settings.drops_sub_heading_italic | default: 'Subscription' }}</em>
        </h2>
        <p class="drops-subscribe-sub">{{ settings.drops_sub_description | default: 'A new themed date night kit curated and delivered to your door every month. Cancel anytime. No drama.' }}</p>

        <ul class="drops-sub-perks">
          {%- assign perks = settings.drops_sub_perks | default: 'Save 15% vs. buying individual drops (£58 vs £68),Priority access — first to get each new drop,Members-only early reveals and sneak peeks,Exclusive subscriber-only bonus items monthly,2x Playmate points on all drop purchases,Flexible — pause skip or cancel anytime' -%}
          {%- assign perk_items = perks | split: ',' -%}
          {%- for perk in perk_items -%}
