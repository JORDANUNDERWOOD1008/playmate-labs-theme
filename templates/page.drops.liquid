  <div class="container">
    <div class="drops-teaser-card">
      <span class="section-eyebrow" style="color:var(--text-muted);">{{ settings.drops_next_coming_label | default: 'Coming February 2025' }}</span>
      <h2 class="drops-section-heading" style="color:var(--cream);">
        {{ settings.drops_next_label | default: 'Drop 09 —' }} <em style="color:{{ settings.drops_accent_color | default: 'var(--gold)' }};">{{ settings.drops_next_teaser | default: 'Something New' }}</em>
      </h2>
      <p style="color:rgba(245,239,230,0.7);max-width:460px;margin:0 auto 2rem;">{{ settings.drops_next_desc | default: 'The theme is under wraps until January 31st. Subscribers find out 48 hours early.' }}</p>
      <a href="#subscribe" class="btn btn-gold">{{ settings.drops_next_cta | default: 'Join Early Access' }}</a>
    </div>
  </div>
</section>

<!-- ===== TESTIMONIALS ===== -->
<section class="section drops-testimonials">
  <div class="container">
    <div class="testimonials-grid">
      {%- for i in (1..3) -%}
        {%- assign t_text = 'drops_testimonial_' | append: i | append: '_text' -%}
        {%- assign t_author = 'drops_testimonial_' | append: i | append: '_author' -%}
        {%- assign t_sub = 'drops_testimonial_' | append: i | append: '_sub' -%}
        {%- assign default_texts = 'The midnight hours drop was genuinely the best thing we have done as a couple this year. Better than any restaurant honestly.,I subscribed after receiving one as a gift. That was 4 months ago. I now buy two — one for us and one for my sister\'s couple.,We do the drop the first Friday of every month. It\'s our ritual now. The quality is exceptional.' | split: ',' -%}
        {%- assign default_authors = 'Emily & Tom,Priya M.,Chris & Dan' | split: ',' -%}
        {%- assign default_subs = 'Drop Subscriber · 2 months,Drop Subscriber · 4 months,Drop Subscriber · 7 months' | split: ',' -%}
        <div class="testimonial-card" style="background:var(--white);border-radius:12px;padding:1.75rem;">
          <div class="star-rating" style="font-size:1rem;margin-bottom:0.75rem;">★★★★★</div>
          <p class="testimonial-text">"{{ settings[t_text] | default: default_texts[forloop.index0] }}"</p>
          <p class="testimonial-author" style="font-weight:600;">— {{ settings[t_author] | default: default_authors[forloop.index0] }}</p>
          <p style="font-size:0.8rem;color:var(--text-muted);margin-top:0.25rem;">{{ settings[t_sub] | default: default_subs[forloop.index0] }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
// Countdown timer
(function() {
  var endStr = '{{ settings.drops_countdown_end }}';
  if (!endStr) return;
  var end = new Date(endStr);
  function update() {
    var now = new Date();
    var diff = end - now;
    if (diff <= 0) { document.getElementById('drop-countdown') && (document.getElementById('drop-countdown').style.display='none'); return; }
    var d = Math.floor(diff/86400000);
    var h = Math.floor((diff%86400000)/3600000);
    var m = Math.floor((diff%3600000)/60000);
    var s = Math.floor((diff%60000)/1000);
    function pad(n){ return String(n).padStart(2,'0'); }
    var cd = document.getElementById('cd-days');
    var ch = document.getElementById('cd-hours');
    var cm = document.getElementById('cd-mins');
    var cs = document.getElementById('cd-secs');
    if(cd) cd.textContent = pad(d);
    if(ch) ch.textContent = pad(h);
    if(cm) cm.textContent = pad(m);
    if(cs) cs.textContent = pad(s);
  }
  update();
  setInterval(update, 1000);
})();
</script>
