          {%- endfor -%}
        </ul>

        <p class="drops-sub-footnote">{{ settings.drops_sub_footnote | default: 'Cancel anytime. No lock-in. Full refunds within 7 days.' }}</p>

        <a href="{{ settings.drops_sub_url | default: '/collections/monthly-drops' }}" class="btn btn-gold" style="margin-top:1.5rem;">
          {{ settings.drops_sub_cta | default: 'Subscribe for £58/mo' }}
        </a>
      </div>

      <div class="drops-subscribe-pillars">
        <div class="drops-pillar">
          <div class="drops-pillar-icon">📅</div>
          <h3>{{ settings.drops_pillar_1_title | default: 'Monthly Theme' }}</h3>
          <p>{{ settings.drops_pillar_1_desc | default: 'Each drop is built around a concept — a sensory theme, an emotion or a cultural moment. Not just a product bundle.' }}</p>
        </div>
        <div class="drops-pillar">
          <div class="drops-pillar-icon">🎯</div>
          <h3>{{ settings.drops_pillar_2_title | default: 'Limited by Design' }}</h3>
          <p>{{ settings.drops_pillar_2_desc | default: '200 kits max per drop. When they\'re gone, they\'re gone. The scarcity makes the ritual feel intentional.' }}</p>
        </div>
        <div class="drops-pillar">
          <div class="drops-pillar-icon">✨</div>
          <h3>{{ settings.drops_pillar_3_title | default: 'Curated & Tested' }}</h3>
          <p>{{ settings.drops_pillar_3_desc | default: 'Every ingredient, product and ritual element is tested in real couples\' date nights before going to production.' }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== PAST DROPS ARCHIVE ===== -->
{%- if settings.drops_show_archive -%}
<section class="section drops-archive">
  <div class="container">
    <div class="section-header" style="text-align:center;margin-bottom:2.5rem;">
      <span class="section-eyebrow" style="color:{{ settings.drops_accent_color | default: 'var(--gold)' }};">{{ settings.drops_archive_eyebrow | default: 'The Vault' }}</span>
      <h2 class="drops-section-heading">{{ settings.drops_archive_heading | default: 'Previous Drops' }}</h2>
    </div>
    <div class="drops-archive-grid">

      {%- for i in (1..6) -%}
        {%- assign drop_icon = 'drops_archive_' | append: i | append: '_icon' -%}
        {%- assign drop_name = 'drops_archive_' | append: i | append: '_name' -%}
        {%- assign drop_desc = 'drops_archive_' | append: i | append: '_desc' -%}
        {%- assign drop_label = 'drops_archive_' | append: i | append: '_label' -%}
        {%- assign drop_rating = 'drops_archive_' | append: i | append: '_rating' -%}

        {%- assign default_icons = '🌙,🌊,🌿,🌹,🌸,🍋' | split: ',' -%}
        {%- assign default_names = 'Midnight Hours,Still Waters,Rooted,First Blush,Cherry Blossom,Citrus Awakening' | split: ',' -%}
        {%- assign default_descs = 'Spiced mulled chocolate black soy candle and an intimacy card game for cold nights.,Japanese-inspired tea ceremony ocean soundscape and a slow-down card game.,Botanical hot cacao cedarwood & vetiver candle nature-inspired prompts.,Rose & lychee white chocolate blush candle and connection prompts for new love.,Spring sakura ritual matcha ceremony and cherry blossom scented candle.,Bright citrus energy ritual zesty notes and playful daytime connection cards.' | split: ',' -%}
        {%- assign default_labels = 'Drop 07 — December 2024,Drop 06 — November 2024,Drop 05 — October 2024,Drop 04 — September 2024,Drop 03 — August 2024,Drop 02 — July 2024' | split: ',' -%}
        {%- assign default_ratings = '189,201,178,214,196,167' | split: ',' -%}

        {%- assign icon_val = settings[drop_icon] | default: default_icons[forloop.index0] -%}
        {%- assign name_val = settings[drop_name] | default: default_names[forloop.index0] -%}
        {%- assign desc_val = settings[drop_desc] | default: default_descs[forloop.index0] -%}
        {%- assign label_val = settings[drop_label] | default: default_labels[forloop.index0] -%}
        {%- assign rating_val = settings[drop_rating] | default: default_ratings[forloop.index0] -%}

