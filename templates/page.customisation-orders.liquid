{% comment %}
  PLAYMATE LABS — CUSTOMISATION ORDERS ADMIN VIEW v3
  File: templates/page.customisation-orders.liquid

  URL: /pages/customisation-orders
  Purpose: Ops / fulfilment team view of all customised box orders.

  Data sources (in order of priority):
  1. Live: shop.metafields.customiser.orders_json (populated by sync script or webhook)
  2. Upload: Shopify Admin CSV export (drag-drop or paste)
  3. Manual: Paste JSON from API or export script

  Security: Protect this page via:
    Shopify Admin → Online Store → Pages → Customisation Orders → Visibility: Hidden
    Share the URL only with ops/fulfilment team
{% endcomment %}

{{ 'global.css' | asset_url | stylesheet_tag }}

{%- assign meta_orders = shop.metafields.customiser.orders_json -%}
{%- assign has_live_data = false -%}
{%- if meta_orders != blank and meta_orders != nil -%}
  {%- assign has_live_data = true -%}
{%- endif -%}

<style>
  /* ── Base ── */
  *, *::before, *::after { box-sizing: border-box; }
  .pcb-admin-wrap {
    max-width: 1280px; margin: 0 auto; padding: 36px 24px 100px;
    font-family: var(--font-sans, 'Inter', sans-serif);
  }

  /* ── Header ── */
  .pcb-header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 16px; margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1px solid rgba(90,20,50,.12); }
  .pcb-title { font-family: var(--font-serif, 'Cormorant Garamond', serif); font-size: 2rem; font-weight: 600; color: #1a0a05; margin: 0 0 4px; }
  .pcb-sub   { font-size: .8rem; color: rgba(26,10,5,.5); margin: 0; }
  .pcb-live-badge { display: inline-flex; align-items: center; gap: 6px; padding: 5px 12px; border-radius: 20px; font-size: .7rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
  .pcb-live-badge.live { background: rgba(0,160,80,.1); color: #007a3d; border: 1px solid rgba(0,160,80,.25); }
  .pcb-live-badge.cached { background: rgba(201,168,76,.1); color: #7a5c10; border: 1px solid rgba(201,168,76,.3); }
  .pcb-live-badge.empty  { background: rgba(90,20,50,.06); color: rgba(90,20,50,.5); border: 1px solid rgba(90,20,50,.15); }

  /* ── Stats ── */
  .pcb-stats { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 28px; }
  .pcb-stat { flex: 1; min-width: 130px; background: #F5EFE6; border: 1px solid rgba(90,20,50,.1); border-radius: 10px; padding: 14px 18px; }
  .pcb-stat-label { font-size: .65rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: rgba(26,10,5,.45); margin-bottom: 6px; }
  .pcb-stat-value { font-family: var(--font-serif, 'Cormorant Garamond', serif); font-size: 1.75rem; font-weight: 600; color: #1a0a05; line-height: 1; }
  .pcb-stat-value.gold { color: #C9A84C; }

  /* ── Toolbar ── */
  .pcb-toolbar { display: flex; gap: 10px; margin-bottom: 18px; flex-wrap: wrap; align-items: center; }
  .pcb-search { flex: 1; min-width: 220px; padding: 10px 14px; border: 1.5px solid rgba(90,20,50,.15); border-radius: 8px; font-size: .85rem; font-family: inherit; outline: none; transition: border-color .2s; }
  .pcb-search:focus { border-color: #5a1432; }
  .pcb-select { padding: 10px 12px; border: 1.5px solid rgba(90,20,50,.15); border-radius: 8px; font-size: .8rem; font-family: inherit; outline: none; background: white; cursor: pointer; }
  .pcb-btn { padding: 10px 18px; border: none; border-radius: 8px; font-family: inherit; font-size: .75rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; cursor: pointer; transition: all .2s; white-space: nowrap; display: inline-flex; align-items: center; gap: 6px; }
  .pcb-btn-dark    { background: #1a0a05; color: #F5EFE6; }
  .pcb-btn-dark:hover { background: #2d1408; }
  .pcb-btn-green   { background: #007a3d; color: white; }
  .pcb-btn-green:hover { background: #005c2e; }
  .pcb-btn-outline { background: transparent; color: #1a0a05; border: 1.5px solid rgba(90,20,50,.2); }
  .pcb-btn-outline:hover { background: #F5EFE6; }
  .pcb-btn:disabled { opacity: .5; cursor: default; }

  /* ── Upload zone ── */
  .pcb-upload-strip { background: rgba(201,168,76,.06); border: 1.5px dashed rgba(201,168,76,.4); border-radius: 10px; padding: 18px 20px; margin-bottom: 22px; display: flex; align-items: center; flex-wrap: wrap; gap: 14px; }
  .pcb-upload-strip.drag-over { background: rgba(201,168,76,.14); border-color: #C9A84C; }
  .pcb-upload-icon { font-size: 1.6rem; flex-shrink: 0; }
  .pcb-upload-text { flex: 1; min-width: 200px; }
  .pcb-upload-text strong { font-size: .88rem; color: #1a0a05; display: block; margin-bottom: 3px; }
  .pcb-upload-text small { font-size: .75rem; color: rgba(26,10,5,.5); line-height: 1.4; display: block; }
  .pcb-upload-text a { color: #5a1432; font-weight: 600; }
  #pcb-file-input { display: none; }

  /* ── Info panel ── */
  .pcb-info { background: rgba(201,168,76,.07); border: 1px solid rgba(201,168,76,.22); border-radius: 9px; padding: 14px 18px; margin-bottom: 22px; font-size: .8rem; color: rgba(26,10,5,.65); line-height: 1.6; }
  .pcb-info strong { color: #1a0a05; }
  .pcb-info code { background: rgba(90,20,50,.07); padding: 1px 5px; border-radius: 3px; font-size: .85em; font-family: monospace; }
  .pcb-info details summary { cursor: pointer; font-weight: 600; color: #5a1432; margin-bottom: 6px; }

  /* ── Table ── */
  .pcb-table-wrap { overflow-x: auto; border-radius: 10px; border: 1px solid rgba(90,20,50,.1); margin-bottom: 20px; }
  .pcb-table { width: 100%; border-collapse: collapse; font-size: .8rem; background: #fff; }
  .pcb-table th { background: #1a0a05; color: #F5EFE6; font-size: .62rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: 11px 14px; text-align: left; white-space: nowrap; cursor: pointer; user-select: none; }
  .pcb-table th:hover { background: #2d1408; }
  .pcb-table th .sort-arrow { opacity: .4; margin-left: 4px; }
  .pcb-table th.sorted .sort-arrow { opacity: 1; }
  .pcb-table td { padding: 11px 14px; border-bottom: 1px solid rgba(90,20,50,.07); vertical-align: top; color: #1a0a05; }
  .pcb-table tr:last-child td { border-bottom: none; }
  .pcb-table tr:hover td { background: rgba(245,239,230,.5); }
  .pcb-badge { display: inline-block; padding: 2px 8px; border-radius: 20px; font-size: .62rem; font-weight: 700; letter-spacing: .07em; text-transform: uppercase; }
  .pcb-badge-yes { background: rgba(201,168,76,.16); color: #7a5c10; border: 1px solid rgba(201,168,76,.35); }
  .pcb-msg  { max-width: 180px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; color: rgba(26,10,5,.6); font-style: italic; font-size: .75rem; }
  .pcb-file { display: inline-flex; align-items: center; gap: 5px; background: rgba(201,168,76,.09); border: 1px solid rgba(201,168,76,.28); border-radius: 5px; padding: 2px 7px; font-size: .7rem; font-weight: 600; }
  .pcb-muted { color: rgba(26,10,5,.22); }
  .pcb-empty { text-align: center; padding: 50px 20px; color: rgba(26,10,5,.35); font-size: .85rem; }
  .pcb-loading { text-align: center; padding: 40px; }
  .pcb-spinner { display: inline-block; width: 24px; height: 24px; border: 2.5px solid rgba(90,20,50,.15); border-top-color: #5a1432; border-radius: 50%; animation: spin .7s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── Lightbox ── */
  .pcb-lightbox { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.88); z-index: 9999; align-items: center; justify-content: center; }
  .pcb-lightbox.open { display: flex; }
  .pcb-lightbox img { max-width: 90vw; max-height: 90vh; object-fit: contain; border-radius: 8px; box-shadow: 0 20px 60px rgba(0,0,0,.5); }
  .pcb-lb-close { position: absolute; top: 18px; right: 18px; background: rgba(255,255,255,.12); border: none; color: white; font-size: 1.4rem; cursor: pointer; width: 38px; height: 38px; border-radius: 50%; }

  /* ── Paste modal ── */
  .pcb-modal-bg { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 999; align-items: center; justify-content: center; }
  .pcb-modal-bg.open { display: flex; }
  .pcb-modal { background: #fff; border-radius: 12px; padding: 24px; max-width: 580px; width: 95%; max-height: 85vh; overflow-y: auto; }
  .pcb-modal h3 { font-size: .95rem; font-weight: 700; margin: 0 0 10px; color: #1a0a05; }
  .pcb-modal textarea { width: 100%; height: 180px; padding: 10px; border: 1px solid #ccc; border-radius: 6px; font-family: monospace; font-size: .78rem; resize: vertical; }

  /* ── Pagination ── */
  .pcb-pagination { display: flex; align-items: center; gap: 8px; justify-content: center; margin-top: 16px; }
  .pcb-page-btn { padding: 6px 12px; border: 1px solid rgba(90,20,50,.2); border-radius: 6px; background: white; cursor: pointer; font-size: .78rem; }
  .pcb-page-btn:hover { background: #F5EFE6; }
  .pcb-page-btn.active { background: #1a0a05; color: #F5EFE6; border-color: #1a0a05; }
  .pcb-page-info { font-size: .75rem; color: rgba(26,10,5,.5); }

  /* ── Toast ── */
  .pcb-toast { position: fixed; bottom: 24px; right: 24px; background: #1a0a05; color: #F5EFE6; padding: 12px 20px; border-radius: 8px; font-size: .82rem; font-weight: 600; z-index: 99999; transform: translateY(80px); opacity: 0; transition: all .3s; pointer-events: none; }
  .pcb-toast.show { transform: translateY(0); opacity: 1; }

  @media (max-width: 600px) {
    .pcb-title { font-size: 1.5rem; }
    .pcb-stat-value { font-size: 1.4rem; }
    .pcb-toolbar { flex-direction: column; }
    .pcb-search, .pcb-select { width: 100%; }
  }
</style>

<div class="pcb-admin-wrap" id="pcb-root">

  <!-- Header -->
  <div class="pcb-header">
    <div>
      <h1 class="pcb-title">📦 Customisation Orders</h1>
      <p class="pcb-sub">Print-on-demand fulfilment dashboard — messages, photos &amp; surcharge data.</p>
    </div>
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
      {%- if has_live_data -%}
        <span class="pcb-live-badge live">
          <span style="width:7px;height:7px;border-radius:50%;background:#007a3d;display:inline-block;"></span>
          Live data
        </span>
      {%- else -%}
        <span class="pcb-live-badge empty">
          <span style="width:7px;height:7px;border-radius:50%;background:rgba(90,20,50,.4);display:inline-block;"></span>
          No live data yet
        </span>
      {%- endif -%}
      <button class="pcb-btn pcb-btn-dark" id="pcb-export-btn">⬇ Export CSV</button>
    </div>
  </div>

  <!-- Stats -->
  <div class="pcb-stats">
    <div class="pcb-stat"><div class="pcb-stat-label">Customised orders</div><div class="pcb-stat-value" id="stat-total">—</div></div>
    <div class="pcb-stat"><div class="pcb-stat-label">Surcharge revenue</div><div class="pcb-stat-value gold" id="stat-revenue">—</div></div>
    <div class="pcb-stat"><div class="pcb-stat-label">With messages</div><div class="pcb-stat-value" id="stat-msgs">—</div></div>
    <div class="pcb-stat"><div class="pcb-stat-label">With file uploads</div><div class="pcb-stat-value" id="stat-files">—</div></div>
  </div>

  <!-- Upload strip -->
  <div class="pcb-upload-strip" id="pcb-drop-zone">
    <div class="pcb-upload-icon">📂</div>
    <div class="pcb-upload-text">
      <strong>Upload Shopify Orders CSV <em>or</em> drag &amp; drop here</strong>
      <small>
        Export from <a href="https://admin.shopify.com/store/playmatelabs/orders" target="_blank">Shopify Admin → Orders → Export</a>
        (filter by SKU <code>PM-BOX-CUSTOM-499</code> or tag <code>customisation</code>).
        The CSV <em>Lineitem properties</em> column contains the message &amp; file name.
      </small>
    </div>
    <label for="pcb-file-input" class="pcb-btn pcb-btn-outline" style="cursor:pointer;">📤 Upload CSV</label>
    <input type="file" id="pcb-file-input" accept=".csv,text/csv">
    <button class="pcb-btn pcb-btn-outline" id="pcb-paste-btn">📋 Paste JSON</button>
    <button class="pcb-btn pcb-btn-outline" id="pcb-refresh-btn">↻ Refresh live</button>
  </div>

  <!-- Info panel -->
  <div class="pcb-info">
    <details>
      <summary>ℹ️ How to get live order data</summary>
      <br>
      <strong>Option 1 — Sync script (recommended):</strong> Run from your terminal:<br>
      <code>node scripts/export-customisation-orders.js --sync --csv</code><br>
      This fetches orders via the Admin API and writes them to the store's metafield so this page updates automatically. Re-run daily or set up a cron job.<br><br>
      <strong>Option 2 — Webhook receiver:</strong> Run <code>node scripts/webhook-receiver.js</code> on a public server.
      New orders are captured automatically as they arrive.<br><br>
      <strong>Option 3 — Shopify Admin CSV:</strong> Go to Admin → Orders → filter by tag <code>customisation</code> → Export CSV → upload above.
      The <em>Lineitem properties</em> column contains the message and file name.
    </details>
  </div>

  <!-- Toolbar -->
  <div class="pcb-toolbar">
    <input type="text" class="pcb-search" id="pcb-search" placeholder="Search order #, customer, message, file…">
    <select class="pcb-select" id="pcb-filter-file">
      <option value="">All orders</option>
      <option value="with-file">With file upload</option>
