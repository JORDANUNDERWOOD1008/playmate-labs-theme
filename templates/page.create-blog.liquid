async function log(msg, cls = '') {
  const el = document.getElementById('log');
  if (el.innerHTML.includes('Awaiting')) el.innerHTML = '';
  const span = document.createElement('div');
  span.innerHTML = msg;
  if (cls) span.className = cls;
  el.appendChild(span);
  el.scrollTop = el.scrollHeight;
}

async function runCreator() {
  const tokenInput = document.getElementById('apiToken');
  const btn = document.getElementById('runBtn');
  const token = tokenInput.value.trim();
  
  if (!token) { alert('Please enter your Admin API token first.'); return; }
  
  btn.disabled = true;
  btn.textContent = '⏳ Running...';
  
  const headers = { 
    'Content-Type': 'application/json',
    'X-Shopify-Access-Token': token
  };
  const base = `https://${STORE}/admin/api/2024-01`;

  // Step 1: Create blog
  await log('⬡ Creating blog: The Playmate Journal...', 'info');
  let blogId;
  try {
    const r = await fetch(`${base}/blogs.json`, {
      method: 'POST',
      headers,
      body: JSON.stringify({ blog: { title: 'The Playmate Journal', handle: 'journal', commentable: 'moderate' } })
    });
    const data = await r.json();
    if (!r.ok) {
      // Blog may already exist — try to fetch it
      await log(`  ⚠ Blog creation returned ${r.status}: ${JSON.stringify(data.errors)} — checking if it exists already...`, 'err');
      const listR = await fetch(`${base}/blogs.json`, { headers });
      const listData = await listR.json();
      const existing = listData.blogs && listData.blogs.find(b => b.handle === 'journal');
      if (existing) { blogId = existing.id; await log(`  ✓ Found existing blog ID: ${blogId}`, 'ok'); }
      else { await log('  ✗ Cannot create or find journal blog. Check token scope.', 'err'); btn.disabled = false; btn.textContent = '▶ Create Blog & Articles'; return; }
    } else {
      blogId = data.blog.id;
      await log(`  ✓ Blog created! ID: ${blogId} → /blogs/journal`, 'ok');
    }
  } catch(e) { await log(`  ✗ Error: ${e.message}`, 'err'); btn.disabled = false; return; }

  // Step 2: Create articles
  await log('', '');
  await log('⬡ Creating articles...', 'info');
  const created = [];

  for (const art of ARTICLES) {
    try {
      const payload = {
        article: {
          blog_id: blogId,
          title: art.title,
          author: art.author,
          tags: art.tags,
          body_html: art.body_html,
          published_at: art.published_at,
          handle: art.handle,
          metafields: [
            { namespace: 'global', key: 'title_tag', value: art.seo_title, type: 'single_line_text_field' },
            { namespace: 'global', key: 'description_tag', value: art.seo_desc, type: 'single_line_text_field' }
          ]
        }
      };
      const r = await fetch(`${base}/blogs/${blogId}/articles.json`, {
        method: 'POST', headers,
        body: JSON.stringify(payload)
      });
      const data = await r.json();
      if (r.ok) {
        const url = `/blogs/journal/${data.article.handle}`;
        created.push({ title: art.title, url });
        await log(`  ✓ <a href="${url}" target="_blank" style="color:#C9A96E">${art.title.substring(0,55)}...</a>`, 'ok');
      } else {
        await log(`  ✗ FAILED: ${art.title.substring(0,55)} — ${JSON.stringify(data.errors)}`, 'err');
      }
    } catch(e) { await log(`  ✗ Error: ${e.message}`, 'err'); }
  }

  await log('', '');
  if (created.length > 0) {
    await log(`✅ Done! Created ${created.length}/7 articles.`, 'ok');
    await log('', '');
    await log('📋 Article URLs:', 'info');
    for (const c of created) {
      await log(`  <a href="${c.url}" target="_blank" style="color:#C9A96E">${c.url}</a>`, '');
    }
    await log('', '');
    await log('Next: Go to your Journal page and verify the articles appear in the dynamic grid. The page automatically displays live Shopify blog articles when the blog exists.', 'muted');
  } else {
    await log('⚠ No articles were created. Check the errors above.', 'err');
  }
  
  btn.disabled = false;
  btn.textContent = '▶ Run Again';
}

// Auto-fill token from URL param ?token=
(function() {
  const p = new URLSearchParams(window.location.search);
  if (p.get('token')) document.getElementById('apiToken').value = p.get('token');
})();
</script>
