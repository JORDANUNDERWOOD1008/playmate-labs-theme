  // ── Core navigation ──
  window.ejGoTo = function(n) {
    var screens = document.querySelectorAll('.ej-screen');
    screens.forEach(function(s){ s.classList.remove('ej-active'); });

    var target = document.getElementById(screenIds[n - 1]);
    if (target) {
      target.classList.add('ej-active');
      target.scrollIntoView({ behavior: 'auto', block: 'start' });
      window.scrollTo(0, 0);
    }

    state.screen = n;
    updateProgress(n);
    updateNavSteps(n);
    updateNavVisibility(n);
  };

  window.ejGoToDay = function(day, delta) {
    if (day == null && delta) {
      // Back from first day
      ejGoTo(3);
      return;
    }
    if (day < 1 || day > 5) return;
    var screenNum = dayScreenMap[day];
    ejGoTo(screenNum);
    state.currentDay = day;
    persistState();
  };

  function updateProgress(n) {
    var pct = progressMap[n] || 0;
    var fill = document.getElementById('ej-progress-fill');
    if (fill) fill.style.width = pct + '%';
  }

  function updateNavSteps(n) {
    var steps = document.getElementById('ej-nav-steps');
    if (!steps) return;
    if (n >= 4 && n <= 8) {
      steps.style.display = 'flex';
      var day = n - 3;
      var dots = steps.querySelectorAll('.ej-nav-step');
      dots.forEach(function(d, i) {
        d.classList.remove('ej-step-done', 'ej-step-active');
        if (i + 1 < day) d.classList.add('ej-step-done');
        if (i + 1 === day) d.classList.add('ej-step-active');
      });
    } else {
      steps.style.display = 'none';
    }
  }

  function updateNavVisibility(n) {
    var nav = document.getElementById('ej-nav');
    if (!nav) return;
    if (n === 1) {
      nav.style.display = 'none';
    } else {
      nav.style.display = 'flex';
    }
  }

  // ── Form navigation ──
  window.ejFormStep = function(step) {
    if (step === 2) {
      var name = document.getElementById('ej-name');
      var email = document.getElementById('ej-email');
      if (!name || !name.value.trim()) { ejShake(name); return; }
      if (!email || !email.value.trim() || !ejIsEmail(email.value)) { ejShake(email); return; }
      state.name = name.value.trim();
      state.email = email.value.trim();
      state.phone = (document.getElementById('ej-phone') || {}).value || '';
    }
    if (step === 3) {
      var city = document.getElementById('ej-city');
      if (!city || !city.value.trim()) { ejShake(city); return; }
      state.city = city.value.trim();
      state.status = (document.getElementById('ej-status') || {}).value || '';
    }
    state.formStep = step;
    ['ej-fstep-1','ej-fstep-2','ej-fstep-3'].forEach(function(id, i) {
      var el = document.getElementById(id);
      if (el) {
        el.style.display = (i + 1 === step) ? 'block' : 'none';
        if (i + 1 === step) el.style.animation = 'ejSlideIn 0.45s cubic-bezier(0.16,1,0.3,1) both';
      }
    });
    // Update step dots
    ['ej-fdot-1','ej-fdot-2','ej-fdot-3'].forEach(function(id, i) {
      var dot = document.getElementById(id);
      if (!dot) return;
      dot.classList.remove('ej-active','ej-done');
      if (i + 1 < step) dot.classList.add('ej-done');
      if (i + 1 === step) dot.classList.add('ej-active');
    });
    window.scrollTo(0,0);
  };

  // ── Form submit ──
  window.ejSubmitForm = function() {
    state.interests = Array.from(document.querySelectorAll('#ej-interests .ej-active')).map(function(el){ return el.dataset.val; });
    state.comms = Array.from(document.querySelectorAll('#ej-comms .ej-active')).map(function(el){ return el.dataset.val; });
    persistState();
    ejSubmitKlaviyo();
    ejGoTo(3);
    var nameEl = document.getElementById('ej-welcome-name');
    var compEl = document.getElementById('ej-comp-name');
    if (nameEl) nameEl.textContent = state.name;
    if (compEl && state.name) compEl.textContent = state.name + '.';
  };

  function ejSubmitKlaviyo() {
    var pk = {{ section.settings.klaviyo_public_api_key | default: '' | json }};
    var lid = {{ section.settings.klaviyo_journey_list_id | default: '' | json }};
    if (!pk || !lid || !state.email) return;
    var payload = {
      data: {
        type: 'subscription',
        attributes: {
          list_id: lid,
          email: state.email,
          custom_source: '5-Day Journey — Playmate Labs',
          properties: {
            first_name: state.name,
            phone: state.phone,
            city: state.city,
            status: state.status,
            interests: state.interests.join(','),
            comms: state.comms.join(','),
            source: '5_day_journey_interactive'
          }
        }
      }
    };
    fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + pk, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'revision': '2023-10-15' },
      body: JSON.stringify(payload)
    }).catch(function(){});
  }

  // ── Toggle pills ──
  window.ejTogglePill = function(el) {
    el.classList.toggle('ej-active');
  };

  // ── Prompt selection ──
  window.ejSelectPrompt = function(card) {
    var wasSelected = card.classList.contains('ej-selected');
    card.classList.toggle('ej-selected');
    if (!wasSelected) {
      try { sessionStorage.setItem('ej_fav_prompt', card.querySelector('.ej-prompt-text').textContent); } catch(e) {}
    }
  };

  // ── Journal save ──
  window.ejSaveJournal = function(day) {
    var ta = document.getElementById('ej-' + day + '-journal');
    if (!ta || !ta.value.trim()) return;
    try { sessionStorage.setItem('ej_journal_' + day, ta.value.trim()); } catch(e) {}
    var btn = event && event.target ? event.target : null;
    if (btn) { btn.textContent = '✓ Saved'; setTimeout(function(){ btn.textContent = '♡ Save'; }, 2000); }
  };

  // ── Star rating ──
  window.ejRate = function(btn, val) {
    state.d2Stars = val;
    var stars = document.querySelectorAll('#ej-d2-stars button');
    stars.forEach(function(s, i) {
      s.style.opacity = (i < val) ? '1' : '0.3';
    });
  };

  // ── Shuffle / roulette ──
  var d2Challenges = [
    "Name your partner's three favourite physical sensations. Go.",
    "Take turns: what's one thing your partner does that you genuinely find attractive?",
    "Without words, show how you feel about this person right now.",
    "What's something you've never admitted you find sexy?",
    "If our relationship was a film, what genre would it be — and who would play us?",
    "Describe your partner using only weather words.",
    "What's something you want to do together that you've been too shy to suggest?",
    "If you could change one small thing about our routine, what would it be?",
    "Name something your partner taught you about yourself.",
    "What does intimacy mean to you right now, at this moment?"
  ];
  var d2Icons = ['🎯','🃏','🎲','👁️','💭','🌊','✨','🔥','🌹','💫'];
  var d2idx = 0;

  window.ejShuffle = function() {
    var card = document.getElementById('ej-roulette');
    var text = document.getElementById('ej-roulette-text');
    var icon = document.getElementById('ej-roulette-icon');
    if (!card || !text || !icon) return;
    card.classList.add('ej-flip');
    setTimeout(function() {
      d2idx = (d2idx + 1) % d2Challenges.length;
      text.textContent = '"' + d2Challenges[d2idx] + '"';
      icon.textContent = d2Icons[d2idx];
      card.classList.remove('ej-flip');
    }, 200);
  };

  // ── Sensory mood ──
  var moodData = {
    candlelight: {
      title: 'The Candlelight Ritual',
      steps: ['Dim every light in the room. Place a single candle between you.','No screens for 20 minutes. One drink each. Start the Playmate Candlelight playlist.','One person touches the other\'s hand for 60 seconds. No speaking. Notice everything.','Take turns: what are three things you can sense right now that you love?']
    },
    touch: {
      title: 'The Touch Ritual',
      steps: ['Sit facing each other. Close your eyes.','One person traces the outline of the other\'s face — very slowly.','Swap. Notice what you feel, not just physically.','What did you notice that surprised you?']
    },
    taste: {
      title: 'The Taste Ritual',
      steps: ['Prepare three things to taste — ideally contrasting: sweet, bitter, rich.','Feed each other. No hands. Eyes closed.','Describe what you taste without naming the food.','What\'s a flavour that reminds you of your partner?']
    },
    scent: {
      title: 'The Scent Ritual',
      steps: ['Find three things in your home that have a distinct scent.','Blindfold one partner. Hold each scent beneath their nose.','They describe the memory or feeling it evokes — without naming it.','Swap. Then share what surprised you about each other\'s associations.']
    },
    sound: {
      title: 'The Sound Ritual',
      steps: ['Create a playlist of 5 songs — each one that means something to you.','Listen to them in silence together.','After each song, share one memory or feeling it triggers.','End with: what\'s one song that will always remind you of us?']
    }
  };

  window.ejSelectMood = function(pill, mood) {
    document.querySelectorAll('.ej-sensory-pill').forEach(function(p){ p.classList.remove('ej-active'); });
    pill.classList.add('ej-active');
    state.moodSelected = mood;
    var data = moodData[mood];
    if (!data) return;
    var titleEl = document.getElementById('ej-ritual-title');
    var stepsEl = document.getElementById('ej-ritual-steps');
    if (titleEl) titleEl.textContent = data.title;
    if (stepsEl) {
      stepsEl.innerHTML = data.steps.map(function(step, i) {
        return '<div style="display:flex;gap:0.875rem;align-items:flex-start;">'
          + '<div style="width:24px;height:24px;border-radius:50%;background:rgba(201,169,110,0.2);border:1px solid rgba(201,169,110,0.25);display:flex;align-items:center;justify-content:center;font-size:0.75rem;color:var(--ej-gold);flex-shrink:0;font-weight:600;">' + (i+1) + '</div>'
          + '<p style="font-size:0.875rem;color:rgba(245,239,230,0.7);line-height:1.6;margin:0;padding-top:0.25rem;">' + step + '</p>'
          + '</div>';
      }).join('');
    }
  };

  // ── Adventure commit ──
  var adventureCommits = [false, false];
  window.ejAdventureCommit = function(num) {
    adventureCommits[num - 1] = true;
    var iconEl = document.getElementById('ej-adv-p' + num + '-icon');
    var btnEl = document.getElementById('ej-adv-p' + num);
    if (iconEl) iconEl.textContent = '✓';
    if (btnEl) {
      btnEl.style.borderColor = 'rgba(201,169,110,0.6)';
      btnEl.style.color = 'var(--ej-gold-light)';
    }
    if (adventureCommits[0] && adventureCommits[1]) {
      setTimeout(function() {
        var locked = document.getElementById('ej-adv-locked');
        var unlocked = document.getElementById('ej-adv-unlocked');
        if (locked) locked.style.display = 'none';
        if (unlocked) unlocked.style.display = 'block';
      }, 600);
    }
  };

  // ── Choice selection ──
  window.ejSelectChoice = function(card) {
    document.querySelectorAll('#ej-adventure-choices .ej-choice-card').forEach(function(c){ c.classList.remove('ej-selected'); });
    card.classList.add('ej-selected');
  };

  // ── Completion confetti ──
  function ejFireConfetti() {
    var wrap = document.getElementById('ej-confetti');
    if (!wrap) return;
    var colors = ['#C9A96E','#E2C98A','#6B1E3A','#F5EFE6','#4A1228'];
    for (var i = 0; i < 60; i++) {
      (function() {
        var piece = document.createElement('div');
        piece.className = 'ej-confetti-piece';
        piece.style.left = Math.random() * 100 + 'vw';
        piece.style.background = colors[Math.floor(Math.random() * colors.length)];
        piece.style.transform = 'rotate(' + Math.random() * 360 + 'deg)';
        piece.style.animationDuration = (1.5 + Math.random() * 2.5) + 's';
        piece.style.animationDelay = Math.random() * 1 + 's';
        wrap.appendChild(piece);
        setTimeout(function(){ if (piece.parentNode) piece.parentNode.removeChild(piece); }, 5000);
      })();
    }
  }

  // ── Share ──
  window.ejShare = function() {
    var url = window.location.href;
    var text = 'Just completed the Playmate Labs 5-Day Virtual Sensory Experience. Five days that genuinely changed our date nights. Try it free:';
    if (navigator.share) {
      navigator.share({ title: 'Playmate Labs — 5-Day Experience', text: text, url: url });
    } else {
      navigator.clipboard && navigator.clipboard.writeText(url).then(function(){
        alert('Link copied! Share it with someone who needs better date nights.');
      });
    }
  };

  // ── Restart ──
  window.ejRestart = function() {
    state.screen = 1;
    state.currentDay = 0;
    ejGoTo(1);
  };

  // ── Helpers ──
  function ejIsEmail(e) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e);
  }

  function ejShake(el) {
    if (!el) return;
    el.style.animation = 'none';
    el.style.borderColor = '#C9A96E';
    el.focus();
    setTimeout(function(){ el.style.borderColor = ''; }, 1500);
  }

  function persistState() {
    try {
      sessionStorage.setItem('ej_state', JSON.stringify({
        name: state.name,
        email: state.email,
        city: state.city,
        currentDay: state.currentDay
      }));
    } catch(e) {}
  }

  function restoreState() {
    try {
      var s = sessionStorage.getItem('ej_state');
      if (s) {
        var d = JSON.parse(s);
        if (d.name) {
          state.name = d.name;
          var nameEl = document.getElementById('ej-welcome-name');
          var compEl = document.getElementById('ej-comp-name');
          if (nameEl) nameEl.textContent = d.name;
          if (compEl) compEl.textContent = d.name + '.';
        }
      }
    } catch(e) {}
  }

  // ── Init ──
  document.addEventListener('DOMContentLoaded', function() {
    restoreState();
    updateNavVisibility(1);
    updateProgress(1);

    // Trigger confetti when screen 9 becomes active
    var obs = new MutationObserver(function(mutations) {
      mutations.forEach(function(m) {
        if (m.target.id === 'ej-screen-9' && m.target.classList.contains('ej-active')) {
          setTimeout(ejFireConfetti, 400);
        }
      });
    });
    var s9 = document.getElementById('ej-screen-9');
    if (s9) obs.observe(s9, { attributes: true, attributeFilter: ['class'] });

    // Handle URL hash for deep linking to days
    var hash = window.location.hash;
    if (hash === '#day1') ejGoToDay(1);
    else if (hash === '#day2') ejGoToDay(2);
    else if (hash === '#day3') ejGoToDay(3);
    else if (hash === '#day4') ejGoToDay(4);
    else if (hash === '#day5') ejGoToDay(5);
    else if (hash === '#complete') ejGoTo(9);
    else if (hash === '#join') ejGoTo(2);
  });

})();
</script>

