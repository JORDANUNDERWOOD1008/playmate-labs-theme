{% comment %}
  PLAYMATE LABS — 5-DAY VIRTUAL SENSORY EXPERIENCE (INTERACTIVE JOURNEY)
  File: sections/experience-journey.liquid
  Template: page.experience-journey
  
  This is the full interactive 9-screen SPA journey:
    Screen 1: Lead capture landing
    Screen 2: Onboarding form (multi-step)
    Screen 3: Welcome / success state
    Screen 4–8: Day 1–5 experience pages
    Screen 9: Completion page
  
  Integrates with existing experience.css and global theme styles.
  Does NOT duplicate: header, footer, hero section, lead form already on /pages/5-day-experience
{% endcomment %}

{{ 'experience-journey.css' | asset_url | stylesheet_tag }}

<div class="ej-root" id="ej-root" data-screen="1">

  <!-- ══════════════════════════════════
       PROGRESS BAR (top of viewport)
  ══════════════════════════════════ -->
  <div class="ej-progress-bar" id="ej-progress-bar">
    <div class="ej-progress-fill" id="ej-progress-fill" style="width:0%"></div>
  </div>

  <!-- ══════════════════════════════════
       NAV
  ══════════════════════════════════ -->
  <nav class="ej-nav" id="ej-nav">
    <a class="ej-nav-logo" href="{{ routes.root_url }}">
      Playmate<span>.</span>
    </a>
    <div class="ej-nav-steps" id="ej-nav-steps" style="display:none;">
      <div class="ej-nav-step" data-step="1"></div>
      <div class="ej-nav-step" data-step="2"></div>
      <div class="ej-nav-step" data-step="3"></div>
      <div class="ej-nav-step" data-step="4"></div>
      <div class="ej-nav-step" data-step="5"></div>
    </div>
  </nav>

  <!-- ══════════════════════════════════
       SCREEN 1: LEAD CAPTURE LANDING
  ══════════════════════════════════ -->
  <div class="ej-screen ej-active" id="ej-screen-1">
    <div class="ej-bg ej-bg-dark">
      <div class="ej-orb ej-orb-1"></div>
      <div class="ej-orb ej-orb-2"></div>
      <div class="ej-orb ej-orb-3"></div>
    </div>

    <div class="ej-content ej-content-center">
      
      <!-- Tag -->
      <div class="ej-tag" style="margin-bottom:1.75rem;">
        <span>✦</span>
        <span>{{ section.settings.s1_tag | default: 'Free Virtual Experience' }}</span>
      </div>

      <!-- Headline -->
      <h1 class="ej-headline" style="text-align:center;">
        {{ section.settings.s1_headline_1 | default: 'Unlock a Free' }}<br>
        <em>{{ section.settings.s1_headline_em | default: '5-Day Virtual' }}</em><br>
        {{ section.settings.s1_headline_2 | default: 'Sensory Experience' }}
      </h1>

      <!-- Divider -->
      <div class="ej-divider" style="margin:1.5rem auto;"></div>

      <!-- Sub -->
      <p class="ej-body" style="text-align:center;max-width:520px;margin-bottom:0.5rem;">
        {{ section.settings.s1_subheadline | default: 'Five beautifully designed prompts, games and rituals to make date night feel new again.' }}
      </p>
      <p class="ej-body-sm" style="text-align:center;max-width:440px;margin-bottom:2.5rem;">
        {{ section.settings.s1_support | default: 'Delivered through a beautifully guided digital journey — with exclusive access to events, drops and rewards.' }}
      </p>

      <!-- CTA -->
      <div style="display:flex;flex-direction:column;align-items:center;gap:1rem;width:100%;max-width:380px;">
        <button class="ej-btn ej-btn-gold ej-btn-lg ej-btn-block" onclick="ejGoTo(2)">
          <span>✦</span>
          <span>{{ section.settings.s1_cta | default: 'Start Free' }}</span>
        </button>
        <p class="ej-body-sm" style="text-align:center;">
          {{ section.settings.s1_footnote | default: 'No credit card. No commitment. Just 5 beautiful days.' }}
        </p>
      </div>

      <!-- Social proof -->
      <div class="ej-social-strip" style="justify-content:center;margin-top:2rem;">
        <div class="ej-avatars">
          <div class="ej-avatar">R+T</div>
          <div class="ej-avatar">D+M</div>
          <div class="ej-avatar">L</div>
          <div class="ej-avatar">J+A</div>
        </div>
        <div>
          <div class="ej-stars">★★★★★</div>
          <p class="ej-body-sm" style="margin:0;">{{ section.settings.s1_social | default: '14,000+ couples started this week' }}</p>
        </div>
      </div>

      <!-- 5 Day Preview Strip -->
      <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;margin-top:3rem;width:100%;">
        {%- assign day_names_s1 = 'Curiosity,Play,Sensory,Adventure,Invitation' | split: ',' -%}
        {%- assign day_icons_s1 = '🌹,🎮,✨,🌙,🏆' | split: ',' -%}
        {%- for i in (1..5) -%}
          <div style="display:flex;flex-direction:column;align-items:center;gap:0.375rem;opacity:0.85;">
            <div style="width:40px;height:40px;border-radius:50%;background:rgba(201,169,110,0.12);border:1px solid rgba(201,169,110,0.25);display:flex;align-items:center;justify-content:center;font-size:1.125rem;">
              {{ day_icons_s1[forloop.index0] }}
            </div>
            <span style="font-size:0.6875rem;color:rgba(245,239,230,0.45);text-transform:uppercase;letter-spacing:0.08em;">Day {{ i }}</span>
            <span style="font-size:0.8125rem;color:rgba(245,239,230,0.7);font-family:'Playfair Display',serif;font-style:italic;">{{ day_names_s1[forloop.index0] }}</span>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>


  <!-- ══════════════════════════════════
       SCREEN 2: ONBOARDING FORM
  ══════════════════════════════════ -->
  <div class="ej-screen" id="ej-screen-2">
    <div class="ej-bg ej-bg-dark">
      <div class="ej-orb ej-orb-1" style="animation-delay:2s;"></div>
      <div class="ej-orb ej-orb-2" style="animation-delay:5s;"></div>
    </div>

    <div class="ej-content ej-pt-nav" style="display:flex;flex-direction:column;justify-content:center;min-height:100vh;">

      <!-- Step Dots -->
      <div class="ej-step-indicator" id="ej-form-steps">
        <div class="ej-step-dot ej-active" id="ej-fdot-1"></div>
        <div class="ej-step-dot" id="ej-fdot-2"></div>
        <div class="ej-step-dot" id="ej-fdot-3"></div>
      </div>

      <!-- FORM STEP 1: Name + Email + Phone -->
      <div id="ej-fstep-1" class="ej-onboard-card" style="animation:ejSlideIn 0.5s cubic-bezier(0.16,1,0.3,1) both;">
        <div class="ej-eyebrow">Step 1 of 3</div>
        <h2 class="ej-headline ej-headline-sm">Let's personalise<br><em>your experience</em></h2>
        <p class="ej-body-sm" style="margin-bottom:1.75rem;">Your journey starts here. We'll use these to deliver your daily prompts.</p>

        <div class="ej-form-group">
          <label class="ej-label">First name *</label>
          <input class="ej-input" type="text" id="ej-name" placeholder="Your first name" autocomplete="given-name">
        </div>
        <div class="ej-form-group">
          <label class="ej-label">Email address *</label>
          <input class="ej-input" type="email" id="ej-email" placeholder="your@email.com" autocomplete="email">
        </div>
        <div class="ej-form-group" style="margin-bottom:1.5rem;">
          <label class="ej-label">Phone number <span style="opacity:0.4;">(optional — for SMS drop alerts)</span></label>
          <input class="ej-input" type="tel" id="ej-phone" placeholder="+44 7700 000000" autocomplete="tel">
        </div>

        <button class="ej-btn ej-btn-primary ej-btn-lg ej-btn-block" onclick="ejFormStep(2)">
          Continue
          <span class="ej-btn-icon">→</span>
        </button>
        <p class="ej-microcopy">No spam. We only send the good stuff.</p>
      </div>

      <!-- FORM STEP 2: City + Status -->
      <div id="ej-fstep-2" class="ej-onboard-card" style="display:none;">
        <div class="ej-eyebrow">Step 2 of 3</div>
        <h2 class="ej-headline ej-headline-sm">A little more<br><em>about you</em></h2>
        <p class="ej-body-sm" style="margin-bottom:1.75rem;">Helps us match you with local events and the right experience.</p>

        <div class="ej-form-group">
          <label class="ej-label">Your city *</label>
          <input class="ej-input" type="text" id="ej-city" placeholder="London, Manchester, New York..." autocomplete="address-level2">
        </div>

        <div class="ej-form-group" style="margin-bottom:1.5rem;">
          <label class="ej-label">I'm joining as...</label>
          <select class="ej-input ej-select" id="ej-status">
            <option value="">Select (optional)</option>
            <option value="couple">A couple looking for novelty</option>
            <option value="dating">Dating and exploring</option>
            <option value="gift">Sending as a gift</option>
            <option value="curious">Single and curious</option>
          </select>
        </div>

        <button class="ej-btn ej-btn-primary ej-btn-lg ej-btn-block" onclick="ejFormStep(3)">
          Continue
          <span class="ej-btn-icon">→</span>
        </button>
        <button class="ej-btn ej-btn-ghost ej-btn-sm" style="width:100%;margin-top:0.75rem;" onclick="ejFormStep(1)">← Back</button>
      </div>

      <!-- FORM STEP 3: Interests + CTA -->
      <div id="ej-fstep-3" class="ej-onboard-card" style="display:none;">
        <div class="ej-eyebrow">Step 3 of 3</div>
        <h2 class="ej-headline ej-headline-sm">What excites<br><em>you most?</em></h2>
        <p class="ej-body-sm" style="margin-bottom:1.25rem;">Select all that apply — we'll tailor the experience.</p>

        <div class="ej-form-group">
          <label class="ej-label">Date night vibes</label>
          <div class="ej-checkbox-group" id="ej-interests">
            <span class="ej-pill-check" data-val="playful" onclick="ejTogglePill(this)">🎮 Playful & fun</span>
            <span class="ej-pill-check" data-val="sensory" onclick="ejTogglePill(this)">✨ Sensory rituals</span>
            <span class="ej-pill-check" data-val="intimate" onclick="ejTogglePill(this)">🌹 Intimate connection</span>
            <span class="ej-pill-check" data-val="adventure" onclick="ejTogglePill(this)">🌙 Adventure & novelty</span>
            <span class="ej-pill-check" data-val="dining" onclick="ejTogglePill(this)">🍷 Wine & dining</span>
            <span class="ej-pill-check" data-val="creative" onclick="ejTogglePill(this)">🎨 Creative experiences</span>
          </div>
        </div>

        <div class="ej-form-group" style="margin:1.25rem 0;">
          <label class="ej-label">I'd also love to receive:</label>
          <div class="ej-checkbox-group" id="ej-comms">
            <span class="ej-pill-check ej-active" data-val="events" onclick="ejTogglePill(this)">🎟️ Event invites</span>
            <span class="ej-pill-check ej-active" data-val="drops" onclick="ejTogglePill(this)">📦 Early drop access</span>
            <span class="ej-pill-check" data-val="community" onclick="ejTogglePill(this)">👥 Community news</span>
          </div>
        </div>

        <button class="ej-btn ej-btn-gold ej-btn-lg ej-btn-block" onclick="ejSubmitForm()">
          <span>✦</span>
          <span>Unlock My Experience</span>
        </button>
        <button class="ej-btn ej-btn-ghost ej-btn-sm" style="width:100%;margin-top:0.75rem;" onclick="ejFormStep(2)">← Back</button>
        <p class="ej-microcopy">By signing up you agree to our privacy policy. You can unsubscribe anytime.</p>
      </div>

    </div>
  </div>


  <!-- ══════════════════════════════════
       SCREEN 3: WELCOME / SUCCESS
  ══════════════════════════════════ -->
  <div class="ej-screen" id="ej-screen-3">
    <div class="ej-bg ej-bg-dark">
      <div class="ej-orb ej-orb-1"></div>
      <div class="ej-orb ej-orb-2" style="animation-delay:3s;"></div>
    </div>

    <div class="ej-content ej-content-center" style="padding-top:100px;">

      <div class="ej-success-icon">🌹</div>

      <div class="ej-tag" style="margin-bottom:1.5rem;">
        <span>✓</span>
        <span>You're In</span>
      </div>

      <h1 class="ej-headline ej-headline-md" style="text-align:center;">
        Welcome to the<br>
        <em>Playmate world</em>
      </h1>

      <p class="ej-body" style="text-align:center;max-width:460px;">
        Your 5-day journey begins now, <span id="ej-welcome-name" style="color:var(--ej-gold-light);font-family:'Playfair Display',serif;font-style:italic;"></span>.
        We've sent you a confirmation email — check your inbox.
      </p>

      <div class="ej-hr" style="width:100%;max-width:400px;"></div>

      <!-- Journey preview -->
      <div class="ej-journey-preview" style="width:100%;max-width:480px;">
        {%- assign ej_day_themes = 'Curiosity,Play,Sensory,Adventure,Invitation' | split: ',' -%}
        {%- assign ej_day_teases = 'Rediscover each other through questions you&#39;ve never asked.,A competitive sensory challenge with forfeits and rewards.,A guided ritual using things already in your home.,A secret date night prompt that breaks your normal pattern.,Your personal welcome into the Playmate world.' | split: ',' -%}
        {%- assign ej_day_icons2 = '🌹,🎮,✨,🌙,🏆' | split: ',' -%}
        {%- for i in (1..5) -%}
          <div class="ej-journey-item">
            <div class="ej-journey-num">{{ i }}</div>
            <div style="flex:1;">
              <div class="ej-journey-label">{{ ej_day_icons2[forloop.index0] }} Day {{ i }}: {{ ej_day_themes[forloop.index0] }}</div>
              <div class="ej-journey-theme">{{ ej_day_teases[forloop.index0] }}</div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <div style="display:flex;flex-direction:column;gap:0.75rem;width:100%;max-width:400px;margin-top:2rem;">
        <button class="ej-btn ej-btn-gold ej-btn-lg ej-btn-block" onclick="ejGoToDay(1)">
          <span>🌹</span>
          <span>Begin Day 1 Now</span>
        </button>
        <div style="display:flex;gap:0.75rem;">
          <a href="{{ section.settings.shop_url | default: '/collections/all' }}" class="ej-btn ej-btn-ghost ej-btn-sm" style="flex:1;text-align:center;">
            Shop Drops
          </a>
          <a href="{{ section.settings.events_url | default: '/pages/events' }}" class="ej-btn ej-btn-ghost ej-btn-sm" style="flex:1;text-align:center;">
            Browse Events
          </a>
        </div>
      </div>

    </div>
  </div>


  <!-- ══════════════════════════════════
       SCREEN 4: DAY 1 — CURIOSITY
  ══════════════════════════════════ -->
  <div class="ej-screen" id="ej-screen-day1">
    <div class="ej-bg ej-bg-day1">
      <div class="ej-orb ej-orb-1" style="background:radial-gradient(circle,rgba(201,169,110,0.1) 0%,transparent 70%);"></div>
      <div class="ej-orb ej-orb-2" style="animation-delay:4s;"></div>
    </div>

    <div class="ej-content ej-pt-nav">

      <!-- Day progress -->
      <div class="ej-day-progress" style="margin-top:1rem;">
        {%- for i in (1..5) -%}
          <div class="ej-day-step {% if i == 1 %}ej-current{% endif %}" id="ej-dstep-{{ i }}-day1">
            <div class="ej-day-step-dot">{{ i }}</div>
          </div>
        {%- endfor -%}
      </div>

      <!-- Day badge -->
      <div class="ej-day-badge">
        <span class="ej-day-badge-icon">🌹</span>
        Day 1 &nbsp;·&nbsp; Curiosity
      </div>

      <!-- Headline -->
      <h1 class="ej-headline ej-headline-md">
        {{ section.settings.d1_headline | default: 'What do you' }}<br>
        <em>{{ section.settings.d1_italic | default: 'really want' }}</em><br>
        {{ section.settings.d1_headline2 | default: 'to know?' }}
      </h1>

      <p class="ej-body">
        {{ section.settings.d1_intro | default: 'Ten questions that cut through the familiar. Deceptively simple, surprisingly revealing. Pick your favourite — or work through them all.' }}
      </p>

      <!-- Prompt Cards -->
      <div class="ej-prompt-grid" id="ej-d1-prompts">
        {%- assign d1_prompts = "What's a version of yourself your partner has never seen?,What would you do differently if you knew they couldn't judge you?,Name one thing you've always wanted to try but never said aloud.,What does intimacy actually mean to you — right now in this stage of life?,If tonight had a soundtrack, what would it be and why?,Describe the best date you've ever had without naming where it was.,What's something small your partner does that you actually love?,If you had 48 hours together with no plans — what would you hope happened?,What do you want more of in this relationship?,What's something you've been meaning to say?" | split: ',' -%}
        {%- for prompt in d1_prompts -%}
          <div class="ej-prompt-card" onclick="ejSelectPrompt(this)">
            <div class="ej-prompt-number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
            <div class="ej-prompt-text">{{ prompt }}</div>
            <span class="ej-prompt-heart">♡</span>
          </div>
        {%- endfor -%}
      </div>

      <!-- Journal -->
      <div class="ej-journal" style="margin-top:2rem;">
        <div class="ej-journal-label">✎ Your Reflection</div>
        <textarea id="ej-d1-journal" placeholder="Type your thoughts here... only you can see this."></textarea>
        <div class="ej-journal-actions">
          <button class="ej-shuffle-btn" onclick="ejSaveJournal('d1')">
            ♡ Save
          </button>
        </div>
      </div>

      <!-- Soft CTA -->
      <div class="ej-product-cta" style="margin-top:2rem;">
        <div class="ej-product-eyebrow">✦ Playmate Drops</div>
        <div class="ej-product-name">The Conversation Kit</div>
        <div class="ej-product-price">Perfectly matched to tonight's prompts</div>
        <a href="{{ section.settings.shop_url | default: '/collections/all' }}" class="ej-btn ej-btn-outline-gold ej-btn-sm">
          Explore the Drop →
        </a>
      </div>

      <div style="height:5rem;"></div>
    </div>

    <!-- Sticky CTA -->
    <div class="ej-sticky-cta">
      <button class="ej-btn ej-btn-ghost ej-btn-sm" onclick="ejGoToDay(null, -1)" style="flex:0 0 auto;padding:0.875rem 1.25rem;">←</button>
      <button class="ej-btn ej-btn-primary ej-btn-block" onclick="ejGoToDay(2)">
        Come back tomorrow: Day 2 →
      </button>
    </div>
  </div>


  <!-- ══════════════════════════════════
       SCREEN 5: DAY 2 — PLAY
  ══════════════════════════════════ -->
  <div class="ej-screen" id="ej-screen-day2">
    <div class="ej-bg ej-bg-day2">
      <div class="ej-orb ej-orb-1" style="background:radial-gradient(circle,rgba(30,60,107,0.2) 0%,transparent 70%);"></div>
      <div class="ej-orb ej-orb-2" style="background:radial-gradient(circle,rgba(107,30,58,0.25) 0%,transparent 70%);animation-delay:4s;"></div>
    </div>

    <div class="ej-content ej-pt-nav">

      <!-- Day progress -->
      <div class="ej-day-progress" style="margin-top:1rem;">
        {%- for i in (1..5) -%}
          <div class="ej-day-step {% if i <= 1 %}ej-done{% elsif i == 2 %}ej-current{% endif %}">
            <div class="ej-day-step-dot">{% if i <= 1 %}✓{% else %}{{ i }}{% endif %}</div>
          </div>
        {%- endfor -%}
      </div>

      <div class="ej-day-badge">
        <span class="ej-day-badge-icon">🎮</span>
        Day 2 &nbsp;·&nbsp; Play
      </div>

      <h1 class="ej-headline ej-headline-md">
        {{ section.settings.d2_headline | default: 'Game' }}<br>
        <em>{{ section.settings.d2_italic | default: 'on.' }}</em>
      </h1>

      <p class="ej-body">
        {{ section.settings.d2_intro | default: 'A competitive sensory challenge. Who actually knows who? Scored live. With forfeits. Prepare to be surprised by how wrong you are — and how good that feels.' }}
      </p>

      <!-- Roulette Card -->
      <div class="ej-roulette-wrap">
        <div class="ej-roulette-card" id="ej-roulette">
          <span class="ej-game-icon" id="ej-roulette-icon">🎮</span>
          <p class="ej-roulette-quote" id="ej-roulette-text">
            "Name your partner's three favourite physical sensations. Go."
          </p>
          <button class="ej-shuffle-btn" onclick="ejShuffle()" id="ej-shuffle-btn">
            <span>⟳</span> New challenge
          </button>
        </div>
      </div>

      <!-- Game action cards -->
      <h3 style="font-family:'Playfair Display',serif;font-size:1.25rem;color:var(--ej-cream);margin:2rem 0 1rem;">The Games</h3>
      <div style="display:grid;gap:0.875rem;" id="ej-game-cards">
        <div class="ej-game-card" style="padding:1.5rem;text-align:left;display:flex;gap:1rem;align-items:flex-start;">
          <div style="font-size:1.75rem;flex-shrink:0;">🎯</div>
          <div>
            <div class="ej-game-title" style="font-size:1.0625rem;margin-bottom:0.375rem;">Guess the answer</div>
            <div class="ej-game-challenge">Partner predicts your answer on each question. Wrong answer = forfeit.</div>
          </div>
        </div>
        <div class="ej-game-card" style="padding:1.5rem;text-align:left;display:flex;gap:1rem;align-items:flex-start;">
          <div style="font-size:1.75rem;flex-shrink:0;">🃏</div>
          <div>
            <div class="ej-game-title" style="font-size:1.0625rem;margin-bottom:0.375rem;">Truth or reveal</div>
            <div class="ej-game-challenge">One card. One truth. No chickening out.</div>
          </div>
        </div>
        <div class="ej-game-card" style="padding:1.5rem;text-align:left;display:flex;gap:1rem;align-items:flex-start;">
          <div style="font-size:1.75rem;flex-shrink:0;">🎲</div>
          <div>
            <div class="ej-game-title" style="font-size:1.0625rem;margin-bottom:0.375rem;">Sensory roulette</div>
            <div class="ej-game-challenge">Spin and receive a random sensory challenge for right now.</div>
          </div>
        </div>
        <div class="ej-game-card" style="padding:1.5rem;text-align:left;display:flex;gap:1rem;align-items:flex-start;">
          <div style="font-size:1.75rem;flex-shrink:0;">👁️</div>
          <div>
            <div class="ej-game-title" style="font-size:1.0625rem;margin-bottom:0.375rem;">The 30-second stare</div>
            <div class="ej-game-challenge">No phones. No talking. Just each other for 30 seconds. See what happens.</div>
          </div>
        </div>
      </div>

      <!-- Journal -->
      <div class="ej-journal" style="margin-top:2rem;">
        <div class="ej-journal-label">✎ Rate tonight's game</div>
        <div style="display:flex;gap:0.5rem;margin-bottom:0.75rem;" id="ej-d2-stars">
          {%- for i in (1..5) -%}
            <button onclick="ejRate(this,{{ i }})" style="font-size:1.5rem;background:none;border:none;cursor:pointer;opacity:0.4;transition:all 0.2s;color:var(--ej-gold);padding:0.25rem;">★</button>
          {%- endfor -%}
        </div>
        <textarea id="ej-d2-journal" placeholder="What surprised you most about tonight?" style="min-height:70px;"></textarea>
      </div>

      <div style="height:5rem;"></div>
    </div>

    <div class="ej-sticky-cta">
      <button class="ej-btn ej-btn-ghost ej-btn-sm" onclick="ejGoToDay(1)" style="flex:0 0 auto;padding:0.875rem 1.25rem;">←</button>
      <button class="ej-btn ej-btn-primary ej-btn-block" onclick="ejGoToDay(3)">
