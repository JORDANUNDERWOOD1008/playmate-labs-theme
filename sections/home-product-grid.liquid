{% comment %}
  PLAYMATE LABS — HOME PRODUCT GRID SECTION
  File: sections/home-product-grid.liquid
{% endcomment %}

<section class="section home-products" id="shop-preview">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">{{ section.settings.eyebrow | default: 'The Collection' }}</span>
      <h2 class="heading-xl">{{ section.settings.heading | default: 'Rituals worth staying in for.' }}</h2>
      <div class="section-divider"></div>
    </div>

    {%- comment -%} Category Pills {%- endcomment -%}
    <div class="shop-category-pills">
      <button class="category-pill active" data-filter="all">All</button>
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          <button class="category-pill" data-filter="{{ block.settings.filter_value | handleize }}">
            {{ block.settings.label }}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="product-grid product-grid-4">
      {%- assign grid_collection = collections[section.settings.collection] -%}
      {%- if grid_collection != blank -%}
        {%- for product in grid_collection.products limit: section.settings.products_limit -%}
          {% render 'product-card', product: product, show_badge: true, show_quick_add: true %}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Fallback: show from all products {%- endcomment -%}
        {%- for product in collections.all.products limit: 8 -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div style="text-align:center;margin-top:3rem;" class="reveal">
      <a href="{{ section.settings.view_all_url | default: routes.all_products_collection_url }}"
         class="btn btn-ghost btn-lg">
        {{ section.settings.view_all_text | default: 'View All Products' }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Grid",
  "blocks": [
    {
      "type": "category",
      "name": "Category Filter",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Kits"
        },
        {
          "type": "text",
          "id": "filter_value",
          "label": "Filter value (matches product type)",
          "default": "date-night-kits"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Rituals worth staying in for."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 4,
      "max": 12,
      "step": 2,
      "default": 8,
      "label": "Number of products"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all link text",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link URL"
    }
  ],
  "presets": [
    {
      "name": "Product Grid",
      "blocks": [
        { "type": "category", "settings": { "label": "Consumables", "filter_value": "consumables" } },
        { "type": "category", "settings": { "label": "Date Night Kits", "filter_value": "date-night-kits" } },
        { "type": "category", "settings": { "label": "Games", "filter_value": "games" } },
        { "type": "category", "settings": { "label": "Gifts", "filter_value": "gifts" } }
      ]
    }
  ]
}
{% endschema %}
