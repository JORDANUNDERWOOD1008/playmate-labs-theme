{%- if section.settings.section_hidden == false -%}
<!-- SHOP HIGHLIGHTS -->
<section class="section" id="shop-highlights">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">The Collection</span>
      <h2 class="heading-xl">Designed to make date<br>night feel new again.</h2>
      <div class="section-divider"></div>
    </div>

    <!-- Category Filter Nav -->
    <div class="shop-cat-nav reveal">
      <button class="filter-btn active" data-group="home-shop" data-filter="all">All</button>
      <button class="filter-btn" data-group="home-shop" data-filter="consumables">Consumables</button>
      <button class="filter-btn" data-group="home-shop" data-filter="kits">Date Night Kits</button>
      <button class="filter-btn" data-group="home-shop" data-filter="games">Games</button>
      <button class="filter-btn" data-group="home-shop" data-filter="drops">Limited Drops</button>
    </div>

    <div class="products-grid reveal">
      <!-- Product 1 -->
      <div class="product-card" data-category="consumables drops">
        <div class="product-card-img-wrap">
          <div class="img-placeholder" style="height:100%;flex-direction:column;gap:0.5rem;">
            <span style="font-size:3rem;position:relative;z-index:1;">🍫</span>
            <span style="font-size:0.75rem;color:rgba(245,239,230,0.4);position:relative;z-index:1;font-family:var(--font-serif);">Aphrodisiac Blend</span>
          </div>
          <div class="product-card-badges">
            <span class="badge badge-gold">Best Seller</span>
          </div>
          <div class="product-card-actions">
            <button class="btn btn-primary btn-sm" style="width:100%;justify-content:center;"
              data-add-to-cart data-product-id="p1" data-product-name="Dark Sensory Chocolate" data-product-price="24" data-product-icon="🍫"
              onclick="event.stopPropagation()">Add to Cart</button>
          </div>
        </div>
        <div class="product-card-body">
          <div class="star-rating" style="margin-bottom:0.375rem;">★★★★★ <span class="rating-text">(142)</span></div>
          <h3 class="product-card-name">Dark Sensory Chocolate</h3>
          <p class="product-card-desc">72% Madagascan cacao with rose, cardamom &amp; maca</p>
          <p class="product-card-price">£24</p>
        </div>
      </div>

      <!-- Product 2 -->
      <div class="product-card" data-category="kits">
        <div class="product-card-img-wrap">
          <div class="img-placeholder" style="height:100%;flex-direction:column;gap:0.5rem;">
            <span style="font-size:3rem;position:relative;z-index:1;">🕯️</span>
            <span style="font-size:0.75rem;color:rgba(245,239,230,0.4);position:relative;z-index:1;font-family:var(--font-serif);">Amber &amp; Vetiver</span>
          </div>
          <div class="product-card-badges">
            <span class="badge badge-burgundy">New</span>
          </div>
          <div class="product-card-actions">
            <button class="btn btn-primary btn-sm" style="width:100%;justify-content:center;"
              data-add-to-cart data-product-id="p2" data-product-name="Amber Ritual Candle" data-product-price="36" data-product-icon="🕯️"
              onclick="event.stopPropagation()">Add to Cart</button>
          </div>
        </div>
        <div class="product-card-body">
          <div class="star-rating" style="margin-bottom:0.375rem;">★★★★★ <span class="rating-text">(89)</span></div>
          <h3 class="product-card-name">Amber Ritual Candle</h3>
          <p class="product-card-desc">Hand-poured, 40-hour burn, sets the scene perfectly</p>
          <p class="product-card-price">£36</p>
        </div>
      </div>

      <!-- Product 3 -->
      <div class="product-card" data-category="games">
        <div class="product-card-img-wrap">
          <div class="img-placeholder" style="height:100%;flex-direction:column;gap:0.5rem;background:linear-gradient(135deg, #3D1A2E, #6B1E3A);">
            <span style="font-size:3rem;position:relative;z-index:1;">🃏</span>
            <span style="font-size:0.75rem;color:rgba(245,239,230,0.5);position:relative;z-index:1;font-family:var(--font-serif);">52 Cards</span>
          </div>
          <div class="product-card-badges">
            <span class="badge badge-dark">Limited</span>
          </div>
          <div class="product-card-actions">
            <button class="btn btn-primary btn-sm" style="width:100%;justify-content:center;"
              data-add-to-cart data-product-id="p3" data-product-name="The Connection Game" data-product-price="32" data-product-icon="🃏"
              onclick="event.stopPropagation()">Add to Cart</button>
          </div>
        </div>
        <div class="product-card-body">
          <div class="star-rating" style="margin-bottom:0.375rem;">★★★★★ <span class="rating-text">(214)</span></div>
          <h3 class="product-card-name">The Connection Game</h3>
          <p class="product-card-desc">52 cards to deepen intimacy, spark play and ignite curiosity</p>
          <p class="product-card-price">£32</p>
        </div>
      </div>

      <!-- Product 4 -->
      <div class="product-card" data-category="kits drops">
        <div class="product-card-img-wrap">
          <div class="img-placeholder" style="height:100%;flex-direction:column;gap:0.5rem;background:linear-gradient(135deg, #2C1810, #4A2E22);">
            <span style="font-size:3rem;position:relative;z-index:1;">🌹</span>
            <span style="font-size:0.75rem;color:rgba(245,239,230,0.4);position:relative;z-index:1;font-family:var(--font-serif);">Full Kit</span>
          </div>
          <div class="product-card-badges">
            <span class="badge badge-gold">Best Seller</span>
          </div>
          <div class="product-card-actions">
            <button class="btn btn-primary btn-sm" style="width:100%;justify-content:center;"
              data-add-to-cart data-product-id="p4" data-product-name="The Velvet Hour Kit" data-product-price="68" data-product-icon="🌹"
              onclick="event.stopPropagation()">Add to Cart</button>
          </div>
        </div>
        <div class="product-card-body">
          <div class="star-rating" style="margin-bottom:0.375rem;">★★★★★ <span class="rating-text">(327)</span></div>
          <h3 class="product-card-name">The Velvet Hour Kit</h3>
          <p class="product-card-desc">Our flagship date night kit — everything for one perfect evening</p>
          <p class="product-card-price">£68 <span class="original">£82</span></p>
        </div>
      </div>
    </div>

    <div class="text-center reveal" style="margin-top:var(--space-xl);">
      <a href="/collections/all" class="btn btn-secondary btn-lg">Browse Full Collection</a>
    </div>
  </div>
</section>

<style>
.product-card-actions {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 1rem;
  background: linear-gradient(to top, rgba(26,16,10,0.7) 0%, transparent 100%);
  transform: translateY(8px);
  opacity: 0;
  transition: all 0.3s ease;
}
.product-card:hover .product-card-actions {
  transform: translateY(0);
  opacity: 1;
}
.product-card-name {
  font-family: var(--font-serif);
  font-size: 1.0625rem;
  margin-bottom: 0.375rem;
}
.product-card-desc {
  font-size: 0.8125rem;
  color: var(--text-muted);
  line-height: 1.5;
  margin-bottom: 0.625rem;
}
.product-card-price {
  font-weight: 600;
  font-size: 1.0625rem;
  color: var(--text-dark);
}
.product-card-price .original {
  font-weight: 400;
  text-decoration: line-through;
  color: var(--text-light);
  margin-left: 0.375rem;
}
.product-card-body {
  padding: 1.25rem;
}
.star-rating {
  color: var(--gold);
  font-size: 0.875rem;
}
.rating-text {
  color: var(--text-muted);
  font-size: 0.75rem;
  font-family: var(--font-sans);
}
</style>
{%- endif -%}

{% schema %}
{
  "name": "Shop Highlights",
  "settings": [
    {
      "type": "header",
      "content": "⚙️ Section Visibility"
    },
    {
      "type": "checkbox",
      "id": "section_hidden",
      "label": "Hide this section",
      "default": false,
      "info": "Tick to hide this section from the live site. Untick to show it again."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed to make date night feel new again."
    }
  ],
  "presets": [
    {
      "name": "Shop Highlights",
      "category": "Featured"
    }
  ]
}
{% endschema %}
