<!-- VALUE STRIP -->
<section class="value-strip">
  <div class="container">
    <div class="value-strip-inner">
      <div class="value-strip-item reveal" data-delay="0">
        <div class="vs-icon">✦</div>
        <div>
          <h4>Sensory Products</h4>
          <p>Consumables, kits &amp; rituals</p>
        </div>
      </div>
      <div class="value-strip-item reveal" data-delay="1">
        <div class="vs-icon">📦</div>
        <div>
          <h4>Monthly Drops</h4>
          <p>Themed limited releases</p>
        </div>
      </div>
      <div class="value-strip-item reveal" data-delay="2">
        <div class="vs-icon">✨</div>
        <div>
          <h4>Immersive Events</h4>
          <p>IRL experiences &amp; pop-ups</p>
        </div>
      </div>
      <div class="value-strip-item reveal" data-delay="3">
        <div class="vs-icon">🎮</div>
        <div>
          <h4>Digital Games</h4>
          <p>5-day sensory experiences</p>
        </div>
      </div>
      <div class="value-strip-item reveal" data-delay="4">
        <div class="vs-icon">🏆</div>
        <div>
          <h4>Community Rewards</h4>
          <p>Points, perks &amp; early access</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value Strip",
  "settings": [],
  "presets": [{ "name": "Value Strip", "category": "Promotional" }]
}
{% endschema %}
