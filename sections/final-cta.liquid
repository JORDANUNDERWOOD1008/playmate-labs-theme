{%- if section.settings.section_hidden == false -%}
<!-- FINAL CTA -->
<section class="section final-cta" id="final-cta">
  <div class="container">
    <div class="final-cta-inner">
      <span class="section-eyebrow" style="color:var(--gold-light);">Ready to Begin?</span>
      <h2 class="heading-xl text-cream" style="max-width:640px;margin:1rem auto;">
        Date night has been<br><em style="font-style:italic;color:var(--gold-light);">rewritten.</em><br>It's your turn.
      </h2>
      <div class="section-divider" style="background:var(--gold);"></div>
      <p style="color:rgba(245,239,230,0.6);max-width:440px;margin:0 auto 2.5rem;font-size:1rem;line-height:1.7;">
        Start with a free 5-day experience. Subscribe to monthly drops. Or find an event near you. Your next great evening starts here.
      </p>
      <div class="final-cta-actions">
        <a href="/pages/5-day-experience" class="btn btn-gold btn-xl">
          <i class="fas fa-unlock-alt"></i>
          Start Free 5-Day Experience
        </a>
        <a href="/collections/all" class="btn btn-ghost btn-xl">Browse the Shop</a>
      </div>
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    {
      "type": "header",
      "content": "⚙️ Section Visibility"
    },
    {
      "type": "checkbox",
      "id": "section_hidden",
      "label": "Hide this section",
      "default": false,
      "info": "Tick to hide this section from the live site. Untick to show it again."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    }
  ],
  "presets": [
    {
      "name": "Final CTA",
      "category": "Call to Action"
    }
  ]
}
{% endschema %}
