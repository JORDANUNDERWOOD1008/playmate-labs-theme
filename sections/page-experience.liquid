    <div class="section-header" style="text-align:center;margin-bottom:3rem;">
      <span class="section-eyebrow" style="color:{{ section.settings.exp_accent_color | default: 'var(--gold)' }};">{{ section.settings.exp_days_eyebrow | default: 'What Happens Each Day' }}</span>
      <h2 style="font-family:var(--font-serif);font-size:2.25rem;color:{{ section.settings.exp_heading_color | default: 'var(--espresso)' }};">{{ section.settings.exp_days_heading | default: 'Five chapters. Each one unforgettable.' }}</h2>
    </div>

    <div class="exp-days-list">
      {%- assign day_names = 'Curiosity,Play,Sensory,Adventure,Invitation' | split: ',' -%}
      {%- assign day_icons = '🌹,🎮,✨,🌙,🏆' | split: ',' -%}
      {%- assign day_default_descs = 'Rediscover each other through 10 questions you&#39;ve never asked. The ones you&#39;re slightly nervous to answer. The ones that make conversation feel like foreplay.,A competitive sensory challenge — who knows the other better? Scored live with forfeits and rewards designed to make you both laugh flirt and reveal small truths.,A guided 20-minute ritual using things already in your home. Touch taste scent and sound — experienced differently when done together with intention. This is the one people screenshot.,A secret location date night prompt — designed to surprise the person you&#39;re with. Instructions sealed until you&#39;ve both committed. Then opened together at a mystery moment.,Your personal welcome into the Playmate world. A reflection ritual a curated recommendation and an exclusive offer to take the experience further with our first Drop kit.' | split: ',' -%}
      {%- assign day_challenges = '"What&#39;s a version of yourself your partner has never seen?","Name your partner&#39;s three favourite physical sensations. Go.","Close your eyes. Eat one thing slowly. Describe what you taste without using flavour words.","Plan something for tomorrow. One rule: they can&#39;t know what it is until you&#39;ve arrived.","Write one sentence about tonight. Read it aloud."' | split: '","' -%}
      {%- assign day_times = '20–30 minutes,25–40 minutes,20–25 minutes,30–45 minutes,30 minutes' | split: ',' -%}

      {%- for i in (1..5) -%}
        {%- assign day_name_key = 'exp_day_' | append: i | append: '_name' -%}
        {%- assign day_desc_key = 'exp_day_' | append: i | append: '_desc' -%}
        {%- assign day_challenge_key = 'exp_day_' | append: i | append: '_challenge' -%}
        {%- assign day_time_key = 'exp_day_' | append: i | append: '_time' -%}
        {%- assign day_icon_key = 'exp_day_' | append: i | append: '_icon' -%}

        <div class="exp-day-card">
          <div class="exp-day-number">Day {{ i }}</div>
          <div class="exp-day-icon">{{ settings[day_icon_key] | default: day_icons[forloop.index0] }}</div>
          <div class="exp-day-body">
            <h3 class="exp-day-title" style="color:{{ section.settings.exp_accent_color | default: 'var(--gold)' }};">{{ settings[day_name_key] | default: day_names[forloop.index0] }}</h3>
            <p class="exp-day-desc">{{ settings[day_desc_key] | default: day_default_descs[forloop.index0] }}</p>
            <div class="exp-day-challenge">
              <span class="exp-challenge-label">Today's Challenge</span>
              <blockquote class="exp-challenge-quote">{{ settings[day_challenge_key] | default: day_challenges[forloop.index0] }}</blockquote>
            </div>
            <span class="exp-day-time"><i class="fas fa-clock" style="color:var(--gold);margin-right:0.375rem;"></i>{{ settings[day_time_key] | default: day_times[forloop.index0] }}</span>
