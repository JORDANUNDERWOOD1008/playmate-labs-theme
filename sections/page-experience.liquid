<!-- ===== KLAVIYO EXPERIENCE FORM JS ===== -->
<script>
(function() {
  var KLAVIYO_LIST_ID = {{ section.settings.klaviyo_experience_list_id | default: '' | json }};
  var KLAVIYO_PUBLIC_KEY = {{ section.settings.klaviyo_public_api_key | default: '' | json }};

  window.expKlaviyoSubmit = function(formNum) {
    var emailEl = document.getElementById('exp-email-' + formNum);
    if (!emailEl) return;
    var email = emailEl.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      emailEl.focus();
      return;
    }
    if (KLAVIYO_LIST_ID && KLAVIYO_PUBLIC_KEY) {
      var payload = {
        data: {
          type: 'subscription',
          attributes: {
            list_id: KLAVIYO_LIST_ID,
            email: email,
            custom_source: '5-Day Experience — Playmate Labs',
            properties: { source: '5_day_experience_page', form_number: formNum }
          }
        }
      };
      fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + KLAVIYO_PUBLIC_KEY, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'revision': '2023-10-15' },
        body: JSON.stringify(payload)
      })
      .then(function(res) {
        if (res.ok || res.status === 202) { expShowSuccess(formNum); }
        else { expShopifyFallback(email); }
      })
      .catch(function() { expShopifyFallback(email); });
    } else {
      expShopifyFallback(email);
    }
  };

  function expShowSuccess(formNum) {
    var fields = document.getElementById('exp-form-fields-' + formNum);
    var success = document.getElementById('exp-form-success-' + formNum);
    if (fields) fields.style.display = 'none';
    if (success) success.style.display = 'flex';
    // Also show the other form's success if both submitted the same session
    try { sessionStorage.setItem('pl_exp_signed_up', '1'); } catch(e) {}
  }

  function expShopifyFallback(email) {
    var f = document.createElement('form');
    f.method = 'POST';
    f.action = '/contact';
    f.style.display = 'none';
    f.innerHTML = '<input name="form_type" value="customer">'
      + '<input name="contact[email]" value="' + String(email).replace(/"/g,'&quot;') + '">'
      + '<input name="contact[tags]" value="newsletter,5-day-experience,free-experience">';
    document.body.appendChild(f);
    f.submit();
  }

  // Pre-fill if already signed up
  document.addEventListener('DOMContentLoaded', function() {
    try {
      if (sessionStorage.getItem('pl_exp_signed_up')) {
        [1,2].forEach(function(n) {
          var f = document.getElementById('exp-form-fields-' + n);
          var s = document.getElementById('exp-form-success-' + n);
          if (f) f.style.display = 'none';
          if (s) s.style.display = 'flex';
        });
      }
    } catch(e) {}
  });
})();
</script>

