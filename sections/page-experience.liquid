        <span class="exp-badge">{{ section.settings.exp_badge_card | default: 'No credit card required' }}</span>
      </div>
      <h1 class="exp-hero-heading">
        {{ section.settings.exp_hero_line1 | default: 'Five days to make' }}<br>
        <em style="color:{{ section.settings.exp_accent_color | default: 'var(--gold)' }};">{{ section.settings.exp_hero_italic | default: 'date night' }}</em>
        {{ section.settings.exp_hero_line2 | default: 'feel new.' }}
      </h1>
      <p class="exp-hero-sub">{{ section.settings.exp_hero_subtext | default: 'A free 5-day digital date night experience designed for modern couples. Flirty games, sensory rituals and playful prompts — one chapter per day, delivered straight to your inbox.' }}</p>

      {%- comment -%} Klaviyo Signup Form — Hero {%- endcomment -%}
