<!-- FEATURED MONTHLY DROP -->
<section class="section featured-drop bg-dark" id="featured-drop">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow" style="color:var(--gold-light);">This Month's Drop</span>
      <h2 class="heading-xl text-cream" style="max-width:600px;margin:0 auto;">{{ section.settings.drop_title | default: 'The Velvet Hour' }}</h2>
      <div class="section-divider" style="background:var(--gold);"></div>
      <p class="body-lg" style="color:rgba(245,239,230,0.65);max-width:500px;margin:0 auto;">
        {{ section.settings.drop_tagline | default: 'An evening ritual for two. Dark chocolate, warm amber candlelight and a game that turns conversation into connection.' }}
      </p>
    </div>

    <div class="drop-featured-grid">
      <!-- Visual -->
      <div class="drop-featured-visual reveal-left">
        <div class="drop-main-image img-placeholder">
          {%- if section.settings.drop_image -%}
            <img src="{{ section.settings.drop_image | img_url: '800x' }}" alt="{{ section.settings.drop_title }}" style="width:100%;height:100%;object-fit:cover;border-radius:16px;">
          {%- else -%}
            <div class="drop-img-scene">
              <div style="font-size:5rem;text-align:center;position:relative;z-index:1;">🍷</div>
              <p style="color:rgba(245,239,230,0.4);font-family:var(--font-serif);font-size:1.25rem;position:relative;z-index:1;">{{ section.settings.drop_title | default: 'The Velvet Hour' }}</p>
            </div>
          {%- endif -%}
        </div>
        <div class="drop-mini-images">
          <div class="img-placeholder" style="aspect-ratio:1;border-radius:12px;"><span style="font-size:2rem;">🍫</span></div>
          <div class="img-placeholder" style="aspect-ratio:1;border-radius:12px;"><span style="font-size:2rem;">🕯️</span></div>
          <div class="img-placeholder" style="aspect-ratio:1;border-radius:12px;"><span style="font-size:2rem;">🃏</span></div>
        </div>
      </div>

      <!-- Content -->
      <div class="drop-featured-content reveal-right">
        <div class="drop-meta-row">
          <span class="badge badge-burgundy">Drop 08 — Jan 2025</span>
          <span class="badge badge-gold">Limited 200 Kits</span>
        </div>

        <h3 class="drop-title text-cream">{{ section.settings.drop_subtitle | default: 'A ritual for modern romance.' }}</h3>
        <p class="drop-desc">
          {{ section.settings.drop_description | default: "The Velvet Hour is built around the science of sensory intimacy — dark, rich flavour, warm amber light, and conversation prompts that feel like foreplay for your relationship." }}
        </p>

        <div class="drop-includes">
          <h4 class="label" style="color:var(--gold);margin-bottom:1rem;">What's Inside</h4>
          <ul class="drop-includes-list">
            <li><i class="fas fa-check"></i> 72% Madagascan Dark Chocolate Ritual Bar (120g)</li>
            <li><i class="fas fa-check"></i> Amber Vetiver Hand-poured Candle (150ml)</li>
            <li><i class="fas fa-check"></i> The Connection Game — 52 card deck</li>
            <li><i class="fas fa-check"></i> Velvet Hour Ritual Guide</li>
            <li><i class="fas fa-check"></i> Digital companion experience access</li>
            <li><i class="fas fa-check"></i> Luxury gift packaging</li>
          </ul>
        </div>

        <div class="drop-cta-row">
          <div class="drop-price-block">
            <p class="drop-price text-cream">{{ section.settings.drop_price | default: '£68' }}</p>
            <p style="font-size:0.8rem;color:rgba(245,239,230,0.45);">or £58/mo with Drop subscription</p>
          </div>
          <a href="{{ section.settings.drop_url | default: '/collections/monthly-drops' }}" class="btn btn-gold btn-lg">Shop This Drop</a>
        </div>

        <div class="drop-urgency">
          <i class="fas fa-fire" style="color:var(--gold);"></i>
          <span style="font-size:0.8125rem;color:rgba(245,239,230,0.65);">
            <strong style="color:var(--gold);">47 kits remaining.</strong> Drop closes January 31st.
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Drop",
  "settings": [
    { "type": "text", "id": "drop_title", "label": "Drop Name", "default": "The Velvet Hour" },
    { "type": "text", "id": "drop_tagline", "label": "Drop Tagline" },
    { "type": "text", "id": "drop_subtitle", "label": "Drop Subtitle", "default": "A ritual for modern romance." },
    { "type": "textarea", "id": "drop_description", "label": "Drop Description" },
    { "type": "text", "id": "drop_price", "label": "Price", "default": "£68" },
    { "type": "url", "id": "drop_url", "label": "Drop URL" },
    { "type": "image_picker", "id": "drop_image", "label": "Drop Image" }
  ],
  "presets": [{ "name": "Featured Drop", "category": "Featured" }]
}
{% endschema %}
