{%- if section.settings.section_hidden == false -%}
<!-- SOCIAL PROOF / TESTIMONIALS -->
<section class="section social-proof" id="social-proof">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">What Couples Say</span>
      <h2 class="heading-xl">Real couples,<br>real evenings.</h2>
      <div class="section-divider"></div>
    </div>

    <div class="testimonials-grid">
      <div class="testimonial-card reveal" data-delay="0">
        <div class="star-rating" style="margin-bottom:1rem;font-size:1rem;">★★★★★</div>
        <p class="testimonial-quote">We've tried every date night box on the market. Nothing comes close. The Velvet Hour didn't just give us things to do — it gave us a reason to actually be present with each other again.</p>
        <div class="testimonial-author">
          <div class="testimonial-avatar">S+J</div>
          <div>
            <p class="testimonial-name">Sophie &amp; James</p>
            <p class="testimonial-detail">London · Velvet Hour Kit</p>
          </div>
        </div>
      </div>

      <div class="testimonial-card reveal" data-delay="1">
        <div class="star-rating" style="margin-bottom:1rem;font-size:1rem;">★★★★★</div>
        <p class="testimonial-quote">I bought this as a Valentine's gift thinking it was just a nice box. It turned into the best conversation we'd had in two years. Now we subscribe monthly.</p>
        <div class="testimonial-author">
          <div class="testimonial-avatar">M</div>
          <div>
            <p class="testimonial-name">Marcus D.</p>
            <p class="testimonial-detail">Manchester · Monthly Subscriber</p>
          </div>
        </div>
      </div>

      <div class="testimonial-card reveal" data-delay="2">
        <div class="star-rating" style="margin-bottom:1rem;font-size:1rem;">★★★★★</div>
        <p class="testimonial-quote">The 5-Day Experience was honestly better than therapy for us. Low stakes, high reward. We look forward to it every morning — it's genuinely changed our relationship.</p>
        <div class="testimonial-author">
          <div class="testimonial-avatar">A+K</div>
          <div>
            <p class="testimonial-name">Aisha &amp; Kai</p>
            <p class="testimonial-detail">Birmingham · 5-Day Experience</p>
          </div>
        </div>
      </div>
    </div>


  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Social Proof",
  "settings": [
    {
      "type": "header",
      "content": "⚙️ Section Visibility"
    },
    {
      "type": "checkbox",
      "id": "section_hidden",
      "label": "Hide this section",
      "default": false,
      "info": "Tick to hide this section from the live site. Untick to show it again."
    }
  ],
  "presets": [
    {
      "name": "Social Proof",
      "category": "Content"
    }
  ]
}
{% endschema %}
