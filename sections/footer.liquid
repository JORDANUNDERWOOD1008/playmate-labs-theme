{% comment %}
  PLAYMATE LABS — FOOTER SECTION
  File: sections/footer.liquid
{% endcomment %}

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">

      {%- comment -%} Brand Column {%- endcomment -%}
      <div class="footer-brand">
        <a href="{{ routes.root_url }}" class="nav-logo" style="font-size:1.375rem;margin-bottom:0.25rem;display:inline-block;">
          {%- if section.settings.footer_logo != blank -%}
            <img src="{{ section.settings.footer_logo | image_url: height: 36 }}"
                 alt="{{ shop.name }}"
                 height="36"
                 loading="lazy">
          {%- else -%}
            Playmate <span>Labs</span>
          {%- endif -%}
        </a>
        <p>{{ section.settings.footer_tagline | default: 'Rewriting how couples do date night. Novel sensory products, monthly drops, immersive events and digital rituals for modern relationships.' }}</p>
        <div class="footer-social">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" class="footer-social-link" aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}
            <a href="{{ settings.social_tiktok_link }}" class="footer-social-link" aria-label="TikTok" target="_blank" rel="noopener">T</a>
          {%- endif -%}
          {%- if settings.social_pinterest_link != blank -%}
            <a href="{{ settings.social_pinterest_link }}" class="footer-social-link" aria-label="Pinterest" target="_blank" rel="noopener">P</a>
          {%- endif -%}
          {%- if settings.social_spotify_link != blank -%}
            <a href="{{ settings.social_spotify_link }}" class="footer-social-link" aria-label="Spotify" target="_blank" rel="noopener">S</a>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Shop Column {%- endcomment -%}
      <div class="footer-col">
        <h4>Shop</h4>
        <ul>
          <li><a href="/collections/all">All Products</a></li>
          <li><a href="/products/playmate-chocolate">The Velvet Hour</a></li>
          <li><a href="/pages/monthly-drops">Monthly Drops</a></li>
          <li><a href="/pages/gifts">Gifts</a></li>
        </ul>
      </div>

      {%- comment -%} Explore Column {%- endcomment -%}
      <div class="footer-col">
        <h4>Explore</h4>
        <ul>
          <li><a href="/pages/about">About Playmate Labs</a></li>
          <li><a href="/pages/jordan-underwood">Jordan Underwood</a></li>
          <li><a href="/blogs/the-playmate-journal">The Journal</a></li>
          <li><a href="/pages/events">Events</a></li>
          <li><a href="/pages/5-day-experience">5-Day Experience</a></li>
        </ul>
      </div>

      {%- comment -%} Help Column {%- endcomment -%}
      <div class="footer-col">
        <h4>Help</h4>
        <ul>
          <li><a href="/pages/faq">FAQ</a></li>
          <li><a href="/pages/contact-1">Contact Us</a></li>
          <li><a href="/pages/stockists">Stockists</a></li>
        </ul>
      </div>

    </div>

    {%- comment -%} Newsletter in footer — Klaviyo-powered {%- endcomment -%}
    {%- if section.settings.show_footer_email -%}
    <div class="footer-newsletter">
      <div class="footer-newsletter-inner">
        <div>
          <h4 style="font-family:var(--font-serif);font-size:1.125rem;color:var(--cream);margin-bottom:0.25rem;">
            {{ section.settings.footer_newsletter_heading | default: 'Stay in the loop' }}
          </h4>
          <p style="font-size:0.875rem;color:var(--text-muted);">
            {{ section.settings.footer_newsletter_sub | default: 'Early access to drops, events and rituals.' }}
          </p>
        </div>
        <div id="footer-newsletter-wrap">
          <div class="footer-email-row" id="footer-newsletter-fields">
            <input type="email"
                   id="footer-newsletter-email"
                   placeholder="Your email address"
                   class="form-input"
                   required
                   autocomplete="email">
            <button type="button" class="btn btn-gold btn-sm" id="footer-newsletter-btn">
              {{ section.settings.footer_newsletter_btn | default: 'Subscribe' }}
            </button>
          </div>
          <p id="footer-newsletter-success" style="display:none;font-size:0.8125rem;color:var(--gold);margin-top:0.75rem;">✓ You're in! Check your inbox.</p>
        </div>
      </div>
    </div>
    <script>
    (function(){
      var KLAVIYO_PUBLIC_KEY = {{ settings.klaviyo_public_api_key | default: '' | json }};
      var KLAVIYO_FOOTER_LIST = {{ settings.klaviyo_footer_list_id | default: '' | json }}
                              || {{ settings.klaviyo_popup_list_id | default: '' | json }};
      document.getElementById('footer-newsletter-btn')?.addEventListener('click', function(){
        var emailEl = document.getElementById('footer-newsletter-email');
        var email = emailEl ? emailEl.value.trim() : '';
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { emailEl?.focus(); return; }
        this.disabled = true;
        if (KLAVIYO_PUBLIC_KEY && KLAVIYO_FOOTER_LIST) {
          fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + KLAVIYO_PUBLIC_KEY, {
            method:'POST',
            headers:{'Content-Type':'application/json','revision':'2023-10-15'},
            body: JSON.stringify({data:{type:'subscription',attributes:{list_id:KLAVIYO_FOOTER_LIST,email:email,custom_source:'Footer — Playmate Labs',properties:{source:'footer_newsletter'}}}})
          }).then(function(r){ if(r.ok||r.status===202){footerSuccess();}else{footerShopify(email);} }).catch(function(){footerShopify(email);});
        } else { footerShopify(email); }
      });
      function footerSuccess(){
        var f=document.getElementById('footer-newsletter-fields');
        var s=document.getElementById('footer-newsletter-success');
        if(f)f.style.display='none';
        if(s)s.style.display='block';
      }
      function footerShopify(email){
        var f=document.createElement('form');
        f.method='POST';f.action='/contact';f.style.display='none';
        f.innerHTML='<input name="form_type" value="customer"><input name="contact[email]" value="'+String(email).replace(/"/g,'&quot;')+'"><input name="contact[tags]" value="newsletter,footer-signup">';
        document.body.appendChild(f);f.submit();
      }
    })();
    </script>
    {%- endif -%}

    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="footer-bottom-links">
        {%- if section.settings.footer_bottom_menu != blank -%}
          {%- for link in linklists[section.settings.footer_bottom_menu].links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="{{ pages['privacy-policy'].url | default: '/policies/privacy-policy' }}">Privacy Policy</a>
          <a href="{{ pages['terms-conditions'].url | default: '/policies/terms-of-service' }}">Terms &amp; Conditions</a>
          <a href="{{ pages['cookie-policy'].url | default: '/policies/legal-notice' }}">Cookie Policy</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer logo (optional)"
    },
    {
      "type": "textarea",
      "id": "footer_tagline",
      "label": "Brand tagline",
      "default": "Rewriting how couples do date night. Novel sensory products, monthly drops, immersive events and digital rituals for modern relationships."
    },
    {
      "type": "header",
      "content": "Navigation Columns"
    },
    {
      "type": "text",
      "id": "footer_heading_1",
      "label": "Column 1 Heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "footer_menu_1",
      "label": "Column 1 Menu"
    },
    {
      "type": "text",
      "id": "footer_heading_2",
      "label": "Column 2 Heading",
      "default": "Explore"
    },
    {
      "type": "link_list",
      "id": "footer_menu_2",
      "label": "Column 2 Menu"
    },
    {
      "type": "text",
      "id": "footer_heading_3",
      "label": "Column 3 Heading",
      "default": "Help"
    },
    {
      "type": "link_list",
      "id": "footer_menu_3",
      "label": "Column 3 Menu"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_footer_email",
      "label": "Show email signup",
      "default": true
    },
    {
      "type": "text",
      "id": "footer_newsletter_heading",
      "label": "Newsletter heading",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "footer_newsletter_sub",
      "label": "Newsletter subtext",
      "default": "Early access to drops, events and rituals."
    },
    {
      "type": "text",
      "id": "footer_newsletter_btn",
      "label": "Newsletter button text",
      "default": "Subscribe"
    },
    {
      "type": "link_list",
      "id": "footer_bottom_menu",
      "label": "Footer bottom links menu"
    }
  ]
}
{% endschema %}

