{%- comment -%}
  PLAYMATE LABS — CART DRAWER SECTION
  File: sections/cart-drawer.liquid
  
  This section wrapper is required so the drawer can be refreshed
  via the Shopify Section Rendering API:
    GET /?section_id=cart-drawer
  Returns only the inner HTML so cart-api.js can hot-swap it.
{%- endcomment -%}

<div class="cart-drawer-overlay" id="cart-overlay"></div>
<div class="cart-drawer" id="cart-drawer" role="dialog" aria-modal="true" aria-label="Shopping cart">

  {%- comment -%} ── Header ── {%- endcomment -%}
  <div class="cart-drawer-header">
    <div>
      <h3 style="font-family:var(--font-serif);font-size:1.25rem;">Your Cart</h3>
      <p style="font-size:0.8125rem;color:var(--text-muted);" id="cart-item-count">
        {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}
      </p>
    </div>
    <button class="nav-icon-btn" id="cart-close" aria-label="Close cart">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  {%- comment -%} ── REFRESHABLE INNER REGION ── {%- endcomment -%}
  <div id="cart-drawer-inner">
    {%- render 'cart-drawer-items' -%}
  </div>

</div>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
