{%- if section.settings.section_hidden == false -%}
<!-- JOURNAL PREVIEW -->
<section class="section" id="journal-preview">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">Journal &amp; Explore</span>
      <h2 class="heading-xl">Stories, rituals and<br>ideas for modern love.</h2>
      <div class="section-divider"></div>
    </div>

    <!-- PRIMARY GRID: Feature + 3 Sidebar -->
    <div class="journal-grid">
      <!-- Feature Article -->
      <a href="/blogs/the-playmate-journal/what-14000-couples-taught-us-about-relationships" class="journal-card reveal-left" style="text-decoration:none;display:block;">
        <div class="journal-card-img">
          <img src="https://images.pexels.com/photos/3692738/pexels-photo-3692738.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Couple laughing together — relationship research" style="width:100%;height:100%;object-fit:cover;aspect-ratio:16/9;" loading="lazy">
        </div>
        <div class="journal-card-body">
          <div class="journal-card-category">Relationship Culture</div>
          <h3 class="journal-card-title">What 14,000 Couples Taught Us About What Actually Keeps Relationships Alive</h3>
          <p class="journal-card-excerpt">After 14,000 couples completed our Virtual Sensory Experience, clear patterns emerged. Here's what we learned.</p>
          <div class="journal-card-meta">
            <span>8 min read</span>
            <span>·</span>
            <span>Mar 2025</span>
          </div>
        </div>
      </a>

      <!-- Sidebar Articles -->
      <div class="journal-sidebar reveal-right">
        <a href="/blogs/the-playmate-journal/perfect-sensory-date-night-at-home" style="text-decoration:none;display:block;" class="journal-card-sm">
          <div style="display:grid;grid-template-columns:100px 1fr;gap:1rem;padding:1rem;">
            <img src="https://images.pexels.com/photos/7956573/pexels-photo-7956573.jpeg?auto=compress&cs=tinysrgb&w=400" alt="Candlelit couple dinner date night" style="width:100px;height:80px;object-fit:cover;border-radius:8px;flex-shrink:0;" loading="lazy">
            <div>
              <div class="journal-card-category" style="font-size:0.625rem;">Date Ideas</div>
              <h4 style="font-family:var(--font-serif);font-size:1rem;line-height:1.3;margin-bottom:0.25rem;">How to Plan the Perfect Sensory Date Night at Home</h4>
              <p style="font-size:0.75rem;color:var(--text-light);">5 min · Mar 2025</p>
            </div>
          </div>
        </a>

        <a href="/blogs/the-playmate-journal/10-questions-couples-never-think-to-ask" style="text-decoration:none;display:block;" class="journal-card-sm">
          <div style="display:grid;grid-template-columns:100px 1fr;gap:1rem;padding:1rem;">
            <img src="https://images.pexels.com/photos/6429541/pexels-photo-6429541.jpeg?auto=compress&cs=tinysrgb&w=400" alt="Couple smiling looking at each other connection" style="width:100px;height:80px;object-fit:cover;border-radius:8px;flex-shrink:0;" loading="lazy">
            <div>
              <div class="journal-card-category" style="font-size:0.625rem;">Connection</div>
              <h4 style="font-family:var(--font-serif);font-size:1rem;line-height:1.3;margin-bottom:0.25rem;">10 Questions Couples Never Think to Ask Each Other</h4>
              <p style="font-size:0.75rem;color:var(--text-light);">6 min · Mar 2025</p>
            </div>
          </div>
        </a>

        <a href="/blogs/the-playmate-journal/science-of-sensory-connection-couples" style="text-decoration:none;display:block;" class="journal-card-sm">
          <div style="display:grid;grid-template-columns:100px 1fr;gap:1rem;padding:1rem;">
            <img src="https://images.pexels.com/photos/4694289/pexels-photo-4694289.jpeg?auto=compress&cs=tinysrgb&w=400" alt="Dark moody romantic woman with wine — science of sensory connection" style="width:100px;height:80px;object-fit:cover;border-radius:8px;flex-shrink:0;" loading="lazy">
            <div>
              <div class="journal-card-category" style="font-size:0.625rem;">Science</div>
              <h4 style="font-family:var(--font-serif);font-size:1rem;line-height:1.3;margin-bottom:0.25rem;">The Science of Sensory Connection: Touch, Taste &amp; Smell</h4>
              <p style="font-size:0.75rem;color:var(--text-light);">7 min · Mar 2025</p>
            </div>
          </div>
        </a>
      </div>
    </div>

    <!-- SECONDARY ROW: 4 More Articles -->
    <div class="journal-more-grid reveal" style="
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:1.5rem;
      margin-top:2.5rem;
    ">

      <!-- Article 4: Adventurous Guide -->
      <a href="/blogs/the-playmate-journal/adventurous-couples-guide-sensory-exploration" style="text-decoration:none;display:block;" class="journal-more-card">
        <div style="border-radius:10px;overflow:hidden;background:var(--surface,#f9f5f0);">
          <img src="https://images.pexels.com/photos/4964031/pexels-photo-4964031.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Blindfolded couple — sensory adventure" style="width:100%;height:180px;object-fit:cover;display:block;" loading="lazy">
          <div style="padding:1rem;">
            <div class="journal-card-category" style="font-size:0.625rem;margin-bottom:0.4rem;">Adventure</div>
            <h4 style="font-family:var(--font-serif);font-size:0.9375rem;line-height:1.35;margin-bottom:0.5rem;">The Adventurous Couple's Guide to Sensory Exploration</h4>
            <p style="font-size:0.75rem;color:var(--text-light);">6 min · Mar 2025</p>
          </div>
        </div>
      </a>

      <!-- Article 5: From Routine to Ritual -->
      <a href="/blogs/the-playmate-journal/from-routine-to-ritual-intentional-moments" style="text-decoration:none;display:block;" class="journal-more-card">
        <div style="border-radius:10px;overflow:hidden;background:var(--surface,#f9f5f0);">
          <img src="https://images.pexels.com/photos/30510814/pexels-photo-30510814.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Cosy evening tea with candlelight — ritual and intention" style="width:100%;height:180px;object-fit:cover;display:block;" loading="lazy">
          <div style="padding:1rem;">
            <div class="journal-card-category" style="font-size:0.625rem;margin-bottom:0.4rem;">Rituals</div>
            <h4 style="font-family:var(--font-serif);font-size:0.9375rem;line-height:1.35;margin-bottom:0.5rem;">From Routine to Ritual: How to Make Everyday Moments Feel Intentional</h4>
            <p style="font-size:0.75rem;color:var(--text-light);">6 min · Mar 2025</p>
          </div>
        </div>
      </a>

      <!-- Article 6: Why Couples Stop Being Curious -->
      <a href="/blogs/the-playmate-journal/why-couples-stop-being-curious" style="text-decoration:none;display:block;" class="journal-more-card">
        <div style="border-radius:10px;overflow:hidden;background:var(--surface,#f9f5f0);">
          <img src="https://images.pexels.com/photos/6284951/pexels-photo-6284951.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Couple looking at each other — curiosity and connection" style="width:100%;height:180px;object-fit:cover;display:block;" loading="lazy">
          <div style="padding:1rem;">
            <div class="journal-card-category" style="font-size:0.625rem;margin-bottom:0.4rem;">Psychology</div>
            <h4 style="font-family:var(--font-serif);font-size:0.9375rem;line-height:1.35;margin-bottom:0.5rem;">Why Couples Stop Being Curious About Each Other (And How to Start Again)</h4>
            <p style="font-size:0.75rem;color:var(--text-light);">7 min · Mar 2025</p>
          </div>
        </div>
      </a>

      <!-- Article 7: CTA Card -->
      <a href="/blogs/the-playmate-journal" style="text-decoration:none;display:block;" class="journal-more-card">
        <div style="border-radius:10px;overflow:hidden;background:var(--espresso,#1a0a00);height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:1.5rem;text-align:center;min-height:260px;">
          <span style="font-family:var(--font-serif);font-size:1.25rem;color:var(--cream,#f5efe6);line-height:1.4;margin-bottom:1.25rem;">Explore all stories from<br><em>The Playmate Journal</em></span>
          <span style="display:inline-block;padding:0.625rem 1.5rem;border:1px solid var(--gold,#c9a96e);color:var(--gold,#c9a96e);border-radius:50px;font-size:0.8125rem;letter-spacing:0.05em;text-transform:uppercase;">Read the Journal →</span>
        </div>
      </a>

    </div>

  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Journal Preview",
  "settings": [
    {
      "type": "header",
      "content": "⚙️ Section Visibility"
    },
    {
      "type": "checkbox",
      "id": "section_hidden",
      "label": "Hide this section",
      "default": false,
      "info": "Tick to hide this section from the live site. Untick to show it again."
    }
  ],
  "presets": [
    {
      "name": "Journal Preview",
      "category": "Content"
    }
  ]
}
{% endschema %}
