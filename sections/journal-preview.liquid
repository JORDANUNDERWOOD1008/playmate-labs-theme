<!-- JOURNAL PREVIEW -->
<section class="section" id="journal-preview">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">Journal &amp; Explore</span>
      <h2 class="heading-xl">Stories, rituals and<br>ideas for modern love.</h2>
      <div class="section-divider"></div>
    </div>

    <div class="journal-grid">
      <!-- Feature Article -->
      <a href="/blogs/the-playmate-journal/what-14000-couples-taught-us-about-relationships" class="journal-card reveal-left" style="text-decoration:none;display:block;">
        <div class="journal-card-img">
          <div class="img-placeholder" style="aspect-ratio:16/9;flex-direction:column;gap:1rem;">
            <span style="font-size:4rem;position:relative;z-index:1;">💡</span>
            <span style="font-family:var(--font-serif);font-size:1rem;color:rgba(245,239,230,0.4);position:relative;z-index:1;">Feature Article</span>
          </div>
        </div>
        <div class="journal-card-body">
          <div class="journal-card-category">Relationship Culture</div>
          <h3 class="journal-card-title">What 14,000 Couples Taught Us About What Actually Keeps Relationships Alive</h3>
          <p class="journal-card-excerpt">After 14,000 couples completed our Virtual Sensory Experience, clear patterns emerged. Here's what we learned.</p>
          <div class="journal-card-meta">
            <span>8 min read</span>
            <span>·</span>
            <span>Mar 2025</span>
          </div>
        </div>
      </a>

      <!-- Sidebar Articles -->
      <div class="journal-sidebar reveal-right">
        <a href="/blogs/the-playmate-journal/perfect-sensory-date-night-at-home" style="text-decoration:none;display:block;" class="journal-card-sm">
          <div style="display:grid;grid-template-columns:100px 1fr;gap:1rem;padding:1rem;">
            <div class="img-placeholder" style="height:80px;border-radius:8px;">
              <span style="font-size:1.5rem;position:relative;z-index:1;">🕯️</span>
            </div>
            <div>
              <div class="journal-card-category" style="font-size:0.625rem;">Date Ideas</div>
              <h4 style="font-family:var(--font-serif);font-size:1rem;line-height:1.3;margin-bottom:0.25rem;">How to Plan the Perfect Sensory Date Night at Home</h4>
              <p style="font-size:0.75rem;color:var(--text-light);">5 min · Mar 2025</p>
            </div>
          </div>
        </a>

        <a href="/blogs/the-playmate-journal/10-questions-couples-never-think-to-ask" style="text-decoration:none;display:block;" class="journal-card-sm">
          <div style="display:grid;grid-template-columns:100px 1fr;gap:1rem;padding:1rem;">
            <div class="img-placeholder" style="height:80px;border-radius:8px;background:linear-gradient(135deg,#3D1A2E,#6B1E3A);">
              <span style="font-size:1.5rem;position:relative;z-index:1;">💬</span>
            </div>
            <div>
              <div class="journal-card-category" style="font-size:0.625rem;">Connection</div>
              <h4 style="font-family:var(--font-serif);font-size:1rem;line-height:1.3;margin-bottom:0.25rem;">10 Questions Couples Never Think to Ask Each Other</h4>
              <p style="font-size:0.75rem;color:var(--text-light);">6 min · Mar 2025</p>
            </div>
          </div>
        </a>

        <a href="/blogs/the-playmate-journal/science-of-sensory-connection-couples" style="text-decoration:none;display:block;" class="journal-card-sm">
          <div style="display:grid;grid-template-columns:100px 1fr;gap:1rem;padding:1rem;">
            <div class="img-placeholder" style="height:80px;border-radius:8px;background:linear-gradient(135deg,#4A2E22,#C9A96E30);">
              <span style="font-size:1.5rem;position:relative;z-index:1;">🧠</span>
            </div>
            <div>
              <div class="journal-card-category" style="font-size:0.625rem;">Science</div>
              <h4 style="font-family:var(--font-serif);font-size:1rem;line-height:1.3;margin-bottom:0.25rem;">The Science of Sensory Connection: Touch, Taste & Smell</h4>
              <p style="font-size:0.75rem;color:var(--text-light);">7 min · Mar 2025</p>
            </div>
          </div>
        </a>
      </div>
    </div>

    <div class="text-center reveal" style="margin-top:var(--space-xl);">
      <a href="/blogs/the-playmate-journal" class="btn btn-secondary btn-lg">Read the Journal</a>
    </div>
  </div>
</section>

