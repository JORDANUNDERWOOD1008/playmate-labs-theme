<!-- JOURNAL PREVIEW -->
<section class="section" id="journal-preview">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">Journal &amp; Explore</span>
      <h2 class="heading-xl">Stories, rituals and<br>ideas for modern love.</h2>
      <div class="section-divider"></div>
    </div>

    <div class="journal-grid">
      <!-- Feature Article -->
      <div class="journal-card reveal-left">
        <div class="journal-card-img">
          <div class="img-placeholder" style="aspect-ratio:16/9;flex-direction:column;gap:1rem;">
            <span style="font-size:4rem;position:relative;z-index:1;">💡</span>
            <span style="font-family:var(--font-serif);font-size:1rem;color:rgba(245,239,230,0.4);position:relative;z-index:1;">Feature Article</span>
          </div>
        </div>
        <div class="journal-card-body">
          <div class="journal-card-category">Date Ideas</div>
          <h3 class="journal-card-title">The Art of the Sensory Date Night: A Complete Guide for Couples</h3>
          <p class="journal-card-excerpt">How to engage all five senses and create an evening that bypasses autopilot and drops you somewhere real.</p>
          <div class="journal-card-meta">
            <span>8 min read</span>
            <span>·</span>
            <span>Jan 2025</span>
          </div>
        </div>
      </div>

      <!-- Sidebar Articles -->
      <div class="journal-sidebar reveal-right">
        <div class="journal-card-sm">
          <div style="display:grid;grid-template-columns:100px 1fr;gap:1rem;padding:1rem;">
            <div class="img-placeholder" style="height:80px;border-radius:8px;">
              <span style="font-size:1.5rem;position:relative;z-index:1;">🍷</span>
            </div>
            <div>
              <div class="journal-card-category" style="font-size:0.625rem;">Rituals</div>
              <h4 style="font-family:var(--font-serif);font-size:1rem;line-height:1.3;margin-bottom:0.25rem;">Wine, Chocolate &amp; the Science of Sensory Pleasure</h4>
              <p style="font-size:0.75rem;color:var(--text-light);">5 min · Dec 2024</p>
            </div>
          </div>
        </div>

        <div class="journal-card-sm">
          <div style="display:grid;grid-template-columns:100px 1fr;gap:1rem;padding:1rem;">
            <div class="img-placeholder" style="height:80px;border-radius:8px;background:linear-gradient(135deg,#3D1A2E,#6B1E3A);">
              <span style="font-size:1.5rem;position:relative;z-index:1;">🃏</span>
            </div>
            <div>
              <div class="journal-card-category" style="font-size:0.625rem;">Connection</div>
              <h4 style="font-family:var(--font-serif);font-size:1rem;line-height:1.3;margin-bottom:0.25rem;">36 Questions That Rebuilt Our Relationship</h4>
              <p style="font-size:0.75rem;color:var(--text-light);">7 min · Dec 2024</p>
            </div>
          </div>
        </div>

        <div class="journal-card-sm">
          <div style="display:grid;grid-template-columns:100px 1fr;gap:1rem;padding:1rem;">
            <div class="img-placeholder" style="height:80px;border-radius:8px;background:linear-gradient(135deg,#4A2E22,#C9A96E30);">
              <span style="font-size:1.5rem;position:relative;z-index:1;">🌆</span>
            </div>
            <div>
              <div class="journal-card-category" style="font-size:0.625rem;">City Guide</div>
              <h4 style="font-family:var(--font-serif);font-size:1rem;line-height:1.3;margin-bottom:0.25rem;">The Best Intimate Restaurants in London for 2025</h4>
              <p style="font-size:0.75rem;color:var(--text-light);">4 min · Jan 2025</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center reveal" style="margin-top:var(--space-xl);">
      <a href="/blogs/journal" class="btn btn-secondary btn-lg">Read the Journal</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Journal Preview",
  "settings": [],
  "presets": [{ "name": "Journal Preview", "category": "Content" }]
}
{% endschema %}
