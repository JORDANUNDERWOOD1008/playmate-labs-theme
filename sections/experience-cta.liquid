<!-- 5-DAY EXPERIENCE CTA -->
<section class="experience-section section" id="experience">
  <div class="container">
    <div class="experience-inner">

      <div class="experience-content reveal-left">
        <span class="section-eyebrow">Free Lead Magnet</span>
        <h2 class="heading-xl">The Virtual<br><em>Sensory Experience</em></h2>
        <div class="section-divider" style="margin:1.25rem 0;"></div>
        <p class="body-lg exp-desc" style="color:rgba(245,239,230,0.65);margin-bottom:var(--space-lg);">
          A free 5-day digital date night experience designed for modern couples. Flirty games, sensory rituals and playful prompts — one a day, delivered to your inbox.
        </p>

        <!-- ── CAROUSEL ─────────────────────────────────────────────────────
             body { overflow-x: hidden } kills native scroll AND scrollLeft.
             Solution: translate the entire cards strip via CSS transform,
             driven by touch/pointer JS — zero dependency on overflow. -->
        <div class="exp-carousel-viewport" id="expViewport" aria-label="5-day experience carousel" role="region">
          <!-- horizontal line sits behind the circles, full width of strip -->
          <div class="exp-connector-line" aria-hidden="true"></div>
          <div class="exp-carousel-track" id="expTrack">
            <div class="exp-day-item">
              <div class="exp-day-circle">1</div>
              <div class="exp-day-body">
                <strong>Curiosity</strong>
                <p>Rediscover each other through 10 questions you've never asked</p>
              </div>
            </div>
            <div class="exp-day-item">
              <div class="exp-day-circle">2</div>
              <div class="exp-day-body">
                <strong>Play</strong>
                <p>A competitive sensory challenge — who knows the other better?</p>
              </div>
            </div>
            <div class="exp-day-item">
              <div class="exp-day-circle">3</div>
              <div class="exp-day-body">
                <strong>Sensory</strong>
                <p>A guided 20-minute ritual using things already in your home</p>
              </div>
            </div>
            <div class="exp-day-item">
              <div class="exp-day-circle">4</div>
              <div class="exp-day-body">
                <strong>Adventure</strong>
                <p>A secret location date night prompt — designed to surprise</p>
              </div>
            </div>
            <div class="exp-day-item">
              <div class="exp-day-circle">5</div>
              <div class="exp-day-body">
                <strong>Invitation</strong>
                <p>Your personal welcome into the Playmate world</p>
              </div>
            </div>
          </div>
        </div>
        <!-- dot indicators -->
        <div class="exp-dots" id="expDots" aria-hidden="true">
          <span class="exp-dot exp-dot--active"></span>
          <span class="exp-dot"></span>
          <span class="exp-dot"></span>
          <span class="exp-dot"></span>
          <span class="exp-dot"></span>
        </div>
      </div>

      <div class="experience-form-wrap reveal-right">
        <div class="experience-form-card">
          <div class="exp-form-header">
            <p class="label" style="color:var(--gold);margin-bottom:0.5rem;">It's Free. It's For You.</p>
            <h3 style="font-family:var(--font-serif);font-size:1.75rem;color:var(--cream);">Unlock the<br>5-Day Experience</h3>
            <p style="font-size:0.875rem;color:rgba(245,239,230,0.6);margin-top:0.5rem;">Join 14,000+ couples who've already started.</p>
          </div>

          <form class="exp-form" data-form="experience" style="margin-top:1.5rem;">
            <div class="form-group" style="margin-bottom:0.75rem;">
              <input class="form-input form-input-dark" type="email" name="email" placeholder="Your email address" required>
            </div>
            <div class="form-group" style="margin-bottom:0.75rem;">
              <input class="form-input form-input-dark" type="tel" name="phone" placeholder="Phone number (optional SMS drops)">
            </div>
            <div class="form-group" style="margin-bottom:1.25rem;">
              <select class="form-input form-input-dark form-select" name="status">
                <option value="">I am joining as... (optional)</option>
                <option>A couple looking for novelty</option>
                <option>Dating and exploring</option>
                <option>Buying as a gift for someone</option>
              </select>
            </div>
            <button type="submit" class="btn btn-gold btn-lg" style="width:100%;justify-content:center;">
              <i class="fas fa-unlock-alt" style="margin-right:0.5rem;"></i>
              Unlock Free Experience
            </button>
          </form>
          <div class="form-success" style="display:none;text-align:center;padding:2rem 0;">
            <div style="font-size:2.5rem;margin-bottom:1rem;">🎉</div>
            <h4 style="font-family:var(--font-serif);font-size:1.25rem;color:var(--cream);margin-bottom:0.5rem;">You're in!</h4>
            <p style="font-size:0.875rem;color:rgba(245,239,230,0.65);">Day 1: Curiosity arrives in your inbox tomorrow morning.</p>
            <div style="margin-top:1.5rem;display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;">
              <a href="/pages/events" class="btn btn-sm btn-ghost">Browse Events</a>
              <a href="/pages/monthly-drops" class="btn btn-sm btn-gold">Shop Drops</a>
            </div>
          </div>

          <p style="font-size:0.6875rem;color:rgba(245,239,230,0.3);text-align:center;margin-top:1rem;">
            No spam. Unsubscribe anytime. We respect your inbox.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  'use strict';

  function initCarousel() {
    var viewport = document.getElementById('expViewport');
    var track    = document.getElementById('expTrack');
    var dotsWrap = document.getElementById('expDots');
    if (!viewport || !track) return;

    // Only activate on mobile widths
    if (window.innerWidth > 768) return;

    var cards      = track.querySelectorAll('.exp-day-item');
    var totalCards = cards.length;
    var currentIdx = 0;
    var offsetX    = 0;     // current translateX value (negative = moved left)
    var startX     = 0;
    var startOffset = 0;
    var dragging   = false;
    var CARD_GAP   = 16;    // 1rem gap in px

    function cardWidth() {
      // Each card is 72vw; read actual rendered width
      return cards[0] ? cards[0].offsetWidth : window.innerWidth * 0.72;
    }

    function maxOffset() {
      // Maximum negative translateX (last card fully visible)
      return -((totalCards - 1) * (cardWidth() + CARD_GAP));
    }

    function applyTransform(x, animate) {
      track.style.transition = animate ? 'transform 0.35s cubic-bezier(0.25,0.46,0.45,0.94)' : 'none';
      track.style.transform  = 'translateX(' + x + 'px)';
    }

    function snapTo(idx) {
      idx = Math.max(0, Math.min(totalCards - 1, idx));
      currentIdx = idx;
      offsetX    = -(idx * (cardWidth() + CARD_GAP));
      applyTransform(offsetX, true);
      updateDots(idx);
    }

    function updateDots(idx) {
      if (!dotsWrap) return;
      dotsWrap.querySelectorAll('.exp-dot').forEach(function (d, i) {
        d.classList.toggle('exp-dot--active', i === idx);
      });
    }

    function pointerStart(x) {
      dragging    = true;
      startX      = x;
      startOffset = offsetX;
      track.style.transition = 'none';
    }

    function pointerMove(x) {
      if (!dragging) return;
      var delta = x - startX;
      var next  = startOffset + delta;
      // Rubber-band at edges
      var max = maxOffset();
      if (next > 0)   next = next * 0.25;
      if (next < max) next = max + (next - max) * 0.25;
      offsetX = next;
      applyTransform(offsetX, false);
    }

    function pointerEnd(x) {
      if (!dragging) return;
      dragging = false;
      var delta = x - startX;
      var threshold = cardWidth() * 0.2; // 20% of card width
      if (delta < -threshold) {
        snapTo(currentIdx + 1);
      } else if (delta > threshold) {
        snapTo(currentIdx - 1);
      } else {
        snapTo(currentIdx); // snap back
      }
    }

    // ── Touch events ──
    viewport.addEventListener('touchstart', function (e) {
      pointerStart(e.touches[0].clientX);
    }, { passive: true });

    viewport.addEventListener('touchmove', function (e) {
      pointerMove(e.touches[0].clientX);
      // Don't call preventDefault — passive listener
    }, { passive: true });

    viewport.addEventListener('touchend', function (e) {
      pointerEnd(e.changedTouches[0].clientX);
    }, { passive: true });

    // ── Mouse drag (desktop testing) ──
    viewport.addEventListener('mousedown', function (e) {
      pointerStart(e.clientX);
      e.preventDefault();
    });
    document.addEventListener('mousemove', function (e) {
      pointerMove(e.clientX);
    });
    document.addEventListener('mouseup', function (e) {
      pointerEnd(e.clientX);
    });

    // Initial position
    snapTo(0);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousel);
  } else {
    initCarousel();
  }
})();
</script>

{% schema %}
{
  "name": "5-Day Experience CTA",
  "settings": [],
  "presets": [{ "name": "5-Day Experience CTA", "category": "Lead Capture" }]
}
{% endschema %}
