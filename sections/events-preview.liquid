<!-- EVENTS PREVIEW -->
<section class="section bg-ivory" id="events-preview">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">Upcoming Experiences</span>
      <h2 class="heading-xl">Experiences worth<br>dressing up for.</h2>
      <div class="section-divider"></div>
      <p style="color:var(--text-muted);max-width:480px;margin:0 auto;">IRL events, sensory pop-ups and couples experiences across the UK — and beyond.</p>
    </div>

    <div class="events-preview-grid">
      <!-- Event 1 -->
      <div class="event-card reveal" data-delay="0">
        <div class="event-card-img">
          <div class="img-placeholder" style="height:200px;flex-direction:column;gap:0.5rem;">
            <span style="font-size:2.5rem;position:relative;z-index:1;">🌹</span>
            <span style="font-family:var(--font-serif);font-size:0.9rem;color:rgba(245,239,230,0.4);position:relative;z-index:1;">Sensory Dinner</span>
          </div>
          <div class="event-date-badge">
            <span class="day">14</span>
            <span class="month">Feb</span>
          </div>
        </div>
        <div class="event-card-body">
          <div class="event-card-meta">
            <span class="event-card-city"><i class="fas fa-map-marker-alt" style="font-size:0.6rem;"></i> London</span>
            <span class="event-card-type">Couples Dinner</span>
          </div>
          <h3 class="event-card-title">The Velvet Valentine's Experience</h3>
          <p class="event-card-desc">An intimate sensory dinner for two in a candlelit, curated space. 7 courses. One memorable evening.</p>
          <div class="event-card-footer">
            <span class="event-price">From £140/couple</span>
            <a href="/pages/events" class="btn btn-sm btn-secondary">RSVP</a>
          </div>
        </div>
      </div>

      <!-- Event 2 -->
      <div class="event-card reveal" data-delay="1">
        <div class="event-card-img">
          <div class="img-placeholder" style="height:200px;flex-direction:column;gap:0.5rem;background:linear-gradient(135deg,#2C1810,#6B1E3A);">
            <span style="font-size:2.5rem;position:relative;z-index:1;">🥂</span>
            <span style="font-family:var(--font-serif);font-size:0.9rem;color:rgba(245,239,230,0.4);position:relative;z-index:1;">Social Night</span>
          </div>
          <div class="event-date-badge">
            <span class="day">02</span>
            <span class="month">Mar</span>
          </div>
        </div>
        <div class="event-card-body">
          <div class="event-card-meta">
            <span class="event-card-city"><i class="fas fa-map-marker-alt" style="font-size:0.6rem;"></i> Manchester</span>
            <span class="event-card-type">Social Event</span>
          </div>
          <h3 class="event-card-title">Singles &amp; Mingling — The Playmate Night</h3>
          <p class="event-card-desc">Not a speed date. Not a bar night. Something entirely new — for people who take fun seriously.</p>
          <div class="event-card-footer">
            <span class="event-price">£35/person</span>
            <a href="/pages/events" class="btn btn-sm btn-secondary">RSVP</a>
          </div>
        </div>
      </div>

      <!-- Event 3 -->
      <div class="event-card reveal" data-delay="2">
        <div class="event-card-img">
          <div class="img-placeholder" style="height:200px;flex-direction:column;gap:0.5rem;background:linear-gradient(135deg,#4A2E22,#2C1810);">
            <span style="font-size:2.5rem;position:relative;z-index:1;">🎭</span>
            <span style="font-family:var(--font-serif);font-size:0.9rem;color:rgba(245,239,230,0.4);position:relative;z-index:1;">Immersive</span>
          </div>
          <div class="event-date-badge" style="background:var(--gold);">
            <span class="day" style="color:var(--espresso);">20</span>
            <span class="month" style="color:var(--espresso);">Apr</span>
          </div>
        </div>
        <div class="event-card-body">
          <div class="event-card-meta">
            <span class="event-card-city"><i class="fas fa-map-marker-alt" style="font-size:0.6rem;"></i> London</span>
            <span class="event-card-type">Flagship Event</span>
          </div>
          <h3 class="event-card-title">The Annual Playmate Gathering</h3>
          <p class="event-card-desc">Our signature event. One night. 300 couples. An immersive sensory world built for connection.</p>
          <div class="event-card-footer">
            <span class="event-price">From £85/couple</span>
            <a href="/pages/events" class="btn btn-sm btn-primary">Get Tickets</a>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center reveal" style="margin-top:var(--space-xl);">
      <a href="/pages/events" class="btn btn-secondary btn-lg">View All Events</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Events Preview",
  "settings": [],
  "presets": [{ "name": "Events Preview", "category": "Content" }]
}
{% endschema %}
