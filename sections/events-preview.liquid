<style>
  /* Coming Soon Badge */
  .event-card-img {
    position: relative;
    overflow: hidden;
  }

  .coming-soon-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(90, 20, 50, 0.92);
    color: #F5EFE6;
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    border: 1px solid rgba(245, 220, 180, 0.35);
    backdrop-filter: blur(4px);
    z-index: 10;
    pointer-events: none;
    box-shadow: 0 2px 8px rgba(0,0,0,0.25);
  }

  .coming-soon-badge--gold {
    background: rgba(180, 140, 60, 0.92);
    color: #1a0a05;
    border-color: rgba(245, 220, 120, 0.5);
  }

  /* Ensure image covers properly */
  .event-card-img img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .event-card:hover .event-card-img img {
    transform: scale(1.04);
  }
</style>

<script>
(function () {
  'use strict';

  function initEventsCarousel() {
    var viewport = document.getElementById('eventsViewport');
    var track    = document.getElementById('eventsTrack');
    var dotsWrap = document.getElementById('eventsDots');
    if (!viewport || !track) return;
    if (window.innerWidth > 768) return;

    var cards      = track.querySelectorAll('.event-card');
    var totalCards = cards.length;
    var currentIdx = 0;
    var offsetX    = 0;
    var startX     = 0;
    var startOffset = 0;
    var dragging   = false;
    var CARD_GAP   = 16; // 1rem

    function cardWidth() {
      return cards[0] ? cards[0].offsetWidth : window.innerWidth * 0.82;
    }

    function applyTransform(x, animate) {
      track.style.transition = animate
        ? 'transform 0.35s cubic-bezier(0.25,0.46,0.45,0.94)'
        : 'none';
      track.style.transform = 'translateX(' + x + 'px)';
    }

    function snapTo(idx) {
      idx = Math.max(0, Math.min(totalCards - 1, idx));
      currentIdx = idx;
      offsetX    = -(idx * (cardWidth() + CARD_GAP));
      applyTransform(offsetX, true);
      updateDots(idx);
    }

    function updateDots(idx) {
      if (!dotsWrap) return;
      dotsWrap.querySelectorAll('.events-dot').forEach(function (d, i) {
        d.classList.toggle('events-dot--active', i === idx);
      });
    }

    function onStart(x) {
      dragging     = true;
      startX       = x;
      startOffset  = offsetX;
      track.style.transition = 'none';
    }

    function onMove(x) {
      if (!dragging) return;
      var delta = x - startX;
      var next  = startOffset + delta;
      var max   = -((totalCards - 1) * (cardWidth() + CARD_GAP));
      if (next > 0)   next = next * 0.25;
      if (next < max) next = max + (next - max) * 0.25;
      offsetX = next;
      applyTransform(offsetX, false);
    }

    function onEnd(x) {
      if (!dragging) return;
      dragging = false;
      var delta     = x - startX;
      var threshold = cardWidth() * 0.2;
      if      (delta < -threshold) snapTo(currentIdx + 1);
      else if (delta >  threshold) snapTo(currentIdx - 1);
      else                          snapTo(currentIdx);
    }

    viewport.addEventListener('touchstart', function (e) { onStart(e.touches[0].clientX); }, { passive: true });
    viewport.addEventListener('touchmove',  function (e) { onMove(e.touches[0].clientX);  }, { passive: true });
    viewport.addEventListener('touchend',   function (e) { onEnd(e.changedTouches[0].clientX); }, { passive: true });

    viewport.addEventListener('mousedown', function (e) { onStart(e.clientX); e.preventDefault(); });
    document.addEventListener('mousemove', function (e) { onMove(e.clientX); });
    document.addEventListener('mouseup',   function (e) { onEnd(e.clientX); });

    snapTo(0);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEventsCarousel);
  } else {
    initEventsCarousel();
  }
})();
</script>

