{% comment %}
  PLAYMATE LABS — PRODUCT PAGE v4
  File: templates/product.liquid
  Full reference build: product.html (The Velvet Hour detail)
  Schema-driven colours throughout. Supports:
    - Images gallery (main + thumbnails)
    - Variants (quantity, subscription toggle)
    - What's included list
    - Ritual steps
    - Trust badges
    - Urgency (limited stock)
    - Delivery/returns accordion
    - Reviews section
    - Related products
{% endcomment %}

{{ 'global.css' | asset_url | stylesheet_tag }}
{{ 'components.css' | asset_url | stylesheet_tag }}
{{ 'product.css' | asset_url | stylesheet_tag }}

<style>
  :root {
    --prod-bg:          {{ settings.product_page_bg             | default: '#FFFFFF' }};
    --prod-title:       {{ settings.product_title_color         | default: 'var(--espresso)' }};
    --prod-price:       {{ settings.product_price_color         | default: 'var(--burgundy)' }};
    --prod-compare:     {{ settings.product_compare_price_color | default: 'var(--text-light)' }};
    --prod-rating:      {{ settings.product_rating_color        | default: 'var(--gold)' }};
    --prod-tag-bg:      {{ settings.product_tag_bg              | default: 'var(--cream)' }};
    --prod-tag-tx:      {{ settings.product_tag_text            | default: 'var(--burgundy)' }};
    --prod-tag-bd:      {{ settings.product_tag_border          | default: 'var(--border-light)' }};
    --prod-desc-h:      {{ settings.product_desc_heading_color  | default: 'var(--espresso)' }};
    --prod-desc-tx:     {{ settings.product_desc_text_color     | default: 'var(--text-muted)' }};
    --prod-incl-bg:     {{ settings.product_includes_bg         | default: 'var(--ivory)' }};
    --prod-incl-bd:     {{ settings.product_includes_border     | default: 'var(--border-light)' }};
    --prod-incl-icon:   {{ settings.product_includes_icon_color | default: 'var(--gold)' }};
    --prod-incl-name:   {{ settings.product_includes_name_color | default: 'var(--espresso)' }};
    --prod-incl-detail: {{ settings.product_includes_detail_color | default: 'var(--text-muted)' }};
    --prod-ritual-bg:   {{ settings.product_ritual_bg           | default: 'var(--espresso)' }};
    --prod-ritual-step: {{ settings.product_ritual_step_bg      | default: 'rgba(255,255,255,0.05)' }};
    --prod-ritual-num:  {{ settings.product_ritual_step_number_color | default: 'var(--gold)' }};
    --prod-ritual-tx:   {{ settings.product_ritual_step_text_color  | default: 'var(--cream)' }};
    --prod-sub-bg:      {{ settings.product_sub_bg              | default: 'var(--ivory)' }};
    --prod-sub-bd:      {{ settings.product_sub_border          | default: 'var(--gold)' }};
    --prod-trust-bg:    {{ settings.product_trust_bg            | default: 'var(--ivory)' }};
    --prod-trust-icon:  {{ settings.product_trust_icon_color    | default: 'var(--gold)' }};
    --prod-trust-tx:    {{ settings.product_trust_text_color    | default: 'var(--text-muted)' }};
    --prod-review-bg:   {{ settings.product_review_bg           | default: 'var(--ivory)' }};
    --prod-review-card: {{ settings.product_review_card_bg      | default: '#FFFFFF' }};
    --prod-review-star: {{ settings.product_review_star_color   | default: 'var(--gold)' }};
    --prod-review-tx:   {{ settings.product_review_text_color   | default: 'var(--espresso)' }};
    --prod-review-name: {{ settings.product_review_name_color   | default: 'var(--burgundy)' }};
  }

  /* ── Layout ── */
  .product-main { background: var(--prod-bg); }
  .product-grid { display: grid; grid-template-columns: 55fr 45fr; gap: 4rem; align-items: start; max-width: 1200px; }

  /* ── Gallery ── */
  .product-gallery { position: sticky; top: calc(var(--nav-height) + 1.5rem); }
  .product-main-img { border-radius: var(--radius-xl); overflow: hidden; background: var(--ivory); aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; cursor: zoom-in; }
  .product-main-img img { width: 100%; height: 100%; object-fit: cover; }
  .product-main-img .img-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg,var(--espresso),#3D1A2E); display:flex;align-items:center;justify-content:center;font-size:6rem; }
  .product-thumbs { display: flex; gap: 0.625rem; flex-wrap: wrap; }
  .product-thumb { width: 72px; height: 72px; border-radius: var(--radius-md); overflow: hidden; cursor: pointer; border: 2px solid transparent; transition: all 0.2s; flex-shrink: 0; }
  .product-thumb.active, .product-thumb:hover { border-color: var(--burgundy); }
  .product-thumb img { width: 100%; height: 100%; object-fit: cover; }

  /* ── Product info ── */
  .product-info { padding-top: 0; }
  .product-breadcrumb { margin-bottom: 1.25rem; }
  .product-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
  .product-tag { padding: 0.25rem 0.75rem; background: var(--prod-tag-bg); color: var(--prod-tag-tx); border: 1px solid var(--prod-tag-bd); border-radius: 100px; font-size: 0.75rem; font-weight: 600; }
  .product-title { font-family: var(--font-serif); font-size: clamp(1.75rem,3vw,2.5rem); color: var(--prod-title); margin-bottom: 0.5rem; line-height: 1.2; }
  .product-subtitle { font-size: 0.9375rem; color: var(--prod-desc-tx); margin-bottom: 1rem; }
  .product-rating-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.25rem; }
  .product-stars { color: var(--prod-rating); font-size: 0.9375rem; }
  .product-rating-num { font-weight: 600; font-size: 0.9375rem; }
  .product-review-count { font-size: 0.875rem; color: var(--prod-desc-tx); text-decoration: underline; cursor: pointer; }
  .product-price-row { display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 1.5rem; }
  .product-price { font-family: var(--font-display); font-size: 2rem; font-weight: 300; color: var(--prod-price); }
  .product-compare-price { font-size: 1.25rem; color: var(--prod-compare); text-decoration: line-through; }
  .product-save-badge { padding: 0.25rem 0.625rem; background: rgba(107,30,58,0.1); color: var(--burgundy); border-radius: 100px; font-size: 0.75rem; font-weight: 700; }

  /* ── Subscription toggle ── */
  .product-purchase-options { margin-bottom: 1.5rem; }
  .product-purchase-option { display: flex; align-items: flex-start; gap: 0.875rem; padding: 1rem 1.25rem; border-radius: var(--radius-lg); border: 2px solid var(--prod-tag-bd); cursor: pointer; transition: all 0.2s; margin-bottom: 0.625rem; background: var(--prod-bg); }
  .product-purchase-option.selected { border-color: var(--prod-sub-bd); background: var(--prod-sub-bg); }
  .product-purchase-option input[type="radio"] { accent-color: var(--burgundy); margin-top: 0.125rem; flex-shrink: 0; }
  .product-purchase-option-label { font-size: 0.9375rem; font-weight: 600; color: var(--prod-title); }
  .product-purchase-option-sub { font-size: 0.8125rem; color: var(--prod-desc-tx); margin-top: 0.125rem; }
  .product-sub-discount { display: inline-block; padding: 0.125rem 0.5rem; background: {{ settings.product_sub_discount_color | default: 'var(--burgundy)' }}; color: white; border-radius: 100px; font-size: 0.625rem; font-weight: 700; margin-left: 0.375rem; }

  /* ── Quantity & ATC ── */
  .product-qty-row { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.25rem; }
  .product-qty { display: flex; align-items: center; border: 1px solid var(--border-light); border-radius: var(--radius-md); overflow: hidden; }
  .product-qty button { width: 40px; height: 48px; background: var(--ivory); border: none; font-size: 1.25rem; cursor: pointer; color: var(--espresso); transition: background 0.15s; }
  .product-qty button:hover { background: var(--cream); }
  .product-qty input { width: 56px; height: 48px; text-align: center; border: none; border-left: 1px solid var(--border-light); border-right: 1px solid var(--border-light); font-size: 1rem; background: white; }
  .product-atc-btn { flex: 1; padding: 0 2rem; height: 56px; font-size: 1rem; font-weight: 600; border-radius: var(--radius-lg); background: var(--burgundy); color: var(--cream); border: none; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 0.625rem; }
  .product-atc-btn:hover { background: var(--burgundy-dark); transform: translateY(-1px); box-shadow: 0 4px 20px rgba(107,30,58,0.3); }
  .product-atc-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  /* ── Limited stock warning ── */
  .product-urgency { display: flex; align-items: center; gap: 0.625rem; padding: 0.75rem 1rem; background: rgba(201,169,110,0.1); border: 1px solid rgba(201,169,110,0.3); border-radius: var(--radius-md); font-size: 0.8125rem; color: var(--espresso); margin-bottom: 1.25rem; }
  .product-urgency-dot { width: 8px; height: 8px; background: #e63946; border-radius: 50%; flex-shrink: 0; animation: pulse 1.5s infinite; }
  @keyframes pulse { 0%,100%{opacity:1}50%{opacity:0.4} }

  /* ── Trust badges ── */
  .product-trust { display: grid; grid-template-columns: repeat(4,1fr); gap: 0.75rem; padding: 1.25rem; background: var(--prod-trust-bg); border-radius: var(--radius-lg); margin-bottom: 1.25rem; }
  .product-trust-item { text-align: center; }
  .product-trust-icon { font-size: 1.25rem; color: var(--prod-trust-icon); margin-bottom: 0.25rem; }
  .product-trust-label { font-size: 0.6875rem; font-weight: 600; color: var(--prod-trust-tx); line-height: 1.3; }

  /* ── Delivery accordion ── */
  .product-accordion { border-top: 1px solid var(--border-light); }
  .product-accordion-item { border-bottom: 1px solid var(--border-light); }
  .product-accordion-btn { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 1rem 0; font-size: 0.9375rem; font-weight: 600; color: var(--prod-title); background: none; border: none; cursor: pointer; text-align: left; }
  .product-accordion-body { padding-bottom: 1rem; font-size: 0.875rem; color: var(--prod-desc-tx); line-height: 1.7; display: none; }
  .product-accordion-body.open { display: block; }
  .product-accordion-btn i { transition: transform 0.2s; }
  .product-accordion-btn.open i { transform: rotate(180deg); }

  /* ── What's included ── */
  .product-includes { background: var(--prod-incl-bg); border-radius: var(--radius-xl); padding: 2rem; margin: 2rem 0; }
  .product-includes-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 1rem; margin-top: 1.25rem; }
  .product-include-item { display: flex; gap: 1rem; align-items: flex-start; padding: 1rem; background: white; border-radius: var(--radius-lg); border: 1px solid var(--prod-incl-bd); }
  .product-include-icon { font-size: 1.5rem; flex-shrink: 0; color: var(--prod-incl-icon); }
  .product-include-name { font-weight: 600; font-size: 0.9375rem; color: var(--prod-incl-name); margin-bottom: 0.125rem; }
  .product-include-detail { font-size: 0.8125rem; color: var(--prod-incl-detail); }

  /* ── Ritual steps ── */
  .product-ritual-section { background: var(--prod-ritual-bg); border-radius: var(--radius-xl); padding: 2rem; margin: 2rem 0; color: var(--cream); }
  .product-ritual-steps { display: flex; flex-direction: column; gap: 0.875rem; margin-top: 1.5rem; }
  .product-ritual-step { display: flex; gap: 1.25rem; align-items: flex-start; padding: 1.25rem; background: var(--prod-ritual-step); border-radius: var(--radius-lg); }
  .product-ritual-step-num { font-family: var(--font-display); font-size: 1.5rem; font-weight: 300; color: var(--prod-ritual-num); line-height: 1; flex-shrink: 0; width: 2rem; text-align: center; }
  .product-ritual-step-title { font-family: var(--font-serif); font-size: 0.9375rem; font-weight: 500; color: var(--prod-ritual-tx); margin-bottom: 0.25rem; }
  .product-ritual-step-text { font-size: 0.8125rem; color: rgba(245,239,230,0.65); line-height: 1.6; }

  /* ── Reviews ── */
  .product-reviews-section { background: var(--prod-review-bg); padding: 4rem 0; }
  .product-reviews-summary { display: flex; align-items: center; gap: 3rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
  .product-reviews-overall { text-align: center; }
  .product-reviews-score { font-family: var(--font-display); font-size: 4rem; font-weight: 300; color: var(--prod-price); line-height: 1; }
  .product-reviews-stars-large { color: var(--prod-review-star); font-size: 1.25rem; margin: 0.5rem 0; }
  .product-reviews-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
  .product-review-card { background: var(--prod-review-card); border-radius: var(--radius-xl); padding: 1.5rem; border: 1px solid var(--border-light); }
  .product-review-stars { color: var(--prod-review-star); font-size: 0.875rem; margin-bottom: 0.75rem; }
  .product-review-text { font-size: 0.875rem; color: var(--prod-review-tx); line-height: 1.65; margin-bottom: 1rem; font-style: italic; }
  .product-review-author { font-size: 0.8125rem; font-weight: 600; color: var(--prod-review-name); }
  .product-review-meta { font-size: 0.75rem; color: var(--prod-desc-tx); }

  /* ── Related products ── */
  .product-related { background: white; }

  /* ── Related products grid ── */
  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.875rem;
    }
  }

  /* ── Responsive ── */
  @media (max-width: 900px) { .product-grid { grid-template-columns: 1fr !important; gap: 2rem; } .product-gallery { position: static; } }
  @media (max-width: 640px) { .product-includes-grid { grid-template-columns: 1fr !important; } .product-reviews-grid { grid-template-columns: 1fr !important; } .product-trust { grid-template-columns: repeat(2,1fr) !important; } }
</style>

<!-- ══════════ BREADCRUMB ══════════ -->
<div style="padding:calc(var(--nav-height) + 1.25rem) 0 0;background:var(--prod-bg);">
  <div class="container">
    <div class="breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="breadcrumb-sep">›</span>
      {%- if product.collections.size > 0 -%}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
        <span class="breadcrumb-sep">›</span>
      {%- endif -%}
      <span>{{ product.title }}</span>
    </div>
  </div>
</div>

<!-- ══════════ PRODUCT MAIN ══════════ -->
<section class="product-main" style="padding-bottom:0;">
  <div class="container" style="padding-top:2rem;padding-bottom:4rem;">
    <div class="product-grid">

      <!-- ── GALLERY ── -->
      <div class="product-gallery">
        <!-- Main image -->
        <div class="product-main-img" id="product-main-image" onclick="openLightbox()">
          {%- if product.featured_image -%}
            {{ product.featured_image | image_url: width: 800 | image_tag: id: 'main-product-img', loading: 'eager', alt: product.title }}
          {%- else -%}
            <div class="img-placeholder"><span>💫</span></div>
          {%- endif -%}
        </div>
        <!-- Thumbnails -->
        {%- if product.images.size > 1 -%}
          <div class="product-thumbs">
            {%- for image in product.images limit: 8 -%}
              <div class="product-thumb{% if forloop.first %} active{% endif %}" onclick="switchImage('{{ image | image_url: width: 800 }}', this)">
                {{ image | image_url: width: 150 | image_tag: loading: 'lazy', alt: product.title }}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- ── PRODUCT INFO ── -->
      <div class="product-info">

        <!-- Tags / badges -->
        {%- assign is_limited = false -%}
        {%- assign is_bestseller = false -%}
        {%- for tag in product.tags -%}
          {%- if tag == 'limited' -%}{%- assign is_limited = true -%}{%- endif -%}
          {%- if tag == 'bestseller' -%}{%- assign is_bestseller = true -%}{%- endif -%}
        {%- endfor -%}
        <div class="product-tags">
          {%- if is_bestseller -%}<span class="product-tag" style="background:{{ settings.badge_bestseller_bg | default: 'var(--burgundy)' }};color:{{ settings.badge_bestseller_text | default: 'var(--cream)' }};border-color:transparent;">Bestseller</span>{%- endif -%}
          {%- if is_limited -%}<span class="product-tag" style="background:{{ settings.badge_limited_bg | default: 'var(--gold)' }};color:{{ settings.badge_limited_text | default: 'var(--espresso)' }};border-color:transparent;">Limited</span>{%- endif -%}
          {%- if product.compare_at_price > product.price -%}<span class="product-tag" style="background:{{ settings.badge_sale_bg | default: '#8B2E4F' }};color:{{ settings.badge_sale_text | default: '#FFFFFF' }};border-color:transparent;">Sale</span>{%- endif -%}
        </div>

        <h1 class="product-title">{{ product.title }}</h1>
        {%- if product.metafields.custom.subtitle != blank -%}
          <p class="product-subtitle">{{ product.metafields.custom.subtitle }}</p>
        {%- endif -%}

        {%- comment -%} Value proposition — visible above the fold {%- endcomment -%}
        {%- if product.handle == 'playmate-chocolate' -%}
          <p class="product-subtitle" style="color:var(--espresso);font-weight:500;font-size:1rem;line-height:1.6;margin-bottom:1.25rem;">
            A structured date night ritual in a box. Dark chocolate infused with maca &amp; ashwagandha, conversation cards, soy candle and a step-by-step ritual guide. Everything you need — nothing to plan.
          </p>
        {%- endif -%}

        <!-- Rating -->
        <div class="product-rating-row">
          <div class="product-stars">★★★★★</div>
          <span class="product-rating-num">4.9</span>
          <a href="#product-reviews" class="product-review-count">{{ product.metafields.reviews.rating_count | default: '2,400+' }} reviews</a>
        </div>

        <!-- Price -->
        <div class="product-price-row">
          <span class="product-price">{{ product.selected_or_first_available_variant.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="product-compare-price">{{ product.compare_at_price | money }}</span>
            <span class="product-save-badge">Save {{ product.compare_at_price | minus: product.price | money }}</span>
          {%- endif -%}
        </div>

        <!-- Purchase options: one-time / subscription (Shopify Selling Plans) -->
        {%- assign has_selling_plans = false -%}
        {%- for variant in product.variants -%}
          {%- if variant.selling_plan_allocations.size > 0 -%}
            {%- assign has_selling_plans = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if has_selling_plans -%}
        <div class="product-purchase-options" id="purchase-options-block">
          {%- comment -%} One-time option {%- endcomment -%}
          <label class="product-purchase-option selected" id="purchase-onetime">
            <input type="radio" name="purchase_type" value="onetime" checked id="purchase-onetime-radio">
            <div>
              <div class="product-purchase-option-label">One-time purchase</div>
              <div class="product-purchase-option-sub">
                <span id="onetime-price">{{ product.selected_or_first_available_variant.price | money }}</span> · Ships in 2–4 days
              </div>
            </div>
          </label>

          {%- comment -%} Subscription option – uses first selling plan allocation {%- endcomment -%}
          {%- assign first_plan_alloc = product.selected_or_first_available_variant.selling_plan_allocations.first -%}
          {%- unless first_plan_alloc == blank -%}
          <label class="product-purchase-option" id="purchase-subscription">
            <input type="radio" name="purchase_type" value="subscription" id="purchase-subscription-radio">
            <div style="flex:1;">
              <div class="product-purchase-option-label">
                Subscribe &amp; Save
                <span class="product-sub-discount">15% OFF</span>
              </div>
              <div class="product-purchase-option-sub">
                <span id="sub-price">{{ first_plan_alloc.per_delivery_price | money }}</span> / delivery · Cancel anytime · Priority access
              </div>
              {%- comment -%} Frequency selector shown only when subscription is selected {%- endcomment -%}
              <div id="sub-frequency-wrap" style="display:none;margin-top:0.75rem;">
                <label style="font-size:0.8125rem;font-weight:600;display:block;margin-bottom:0.375rem;">Delivery frequency</label>
                <select id="sub-selling-plan" class="sub-frequency-select" style="padding:0.4rem 0.75rem;border-radius:var(--radius-md);border:1.5px solid var(--border-light);font-size:0.875rem;background:white;width:100%;">
                  {%- for alloc in product.selected_or_first_available_variant.selling_plan_allocations -%}
                    <option value="{{ alloc.selling_plan.id }}">{{ alloc.selling_plan.name }} — {{ alloc.per_delivery_price | money }}</option>
                  {%- endfor -%}
                </select>
              </div>
            </div>
          </label>
          {%- endunless -%}
        </div>
        {%- endif -%}

        <!-- Variants (size, scent etc.) -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div style="margin-bottom:1rem;">
              <p style="font-size:0.8125rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.625rem;">{{ option.name }}</p>
              <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
                {%- for value in option.values -%}
                  <button class="variant-btn" data-option="{{ option.position }}" data-value="{{ value }}" style="padding:0.5rem 1rem;border-radius:var(--radius-md);border:2px solid var(--border-light);font-size:0.875rem;cursor:pointer;background:white;transition:all 0.2s;">{{ value }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <!-- Limited stock -->
        {%- if product.selected_or_first_available_variant.inventory_quantity > 0 and product.selected_or_first_available_variant.inventory_quantity < 20 -%}
          <div class="product-urgency">
            <div class="product-urgency-dot"></div>
            <span>Only <strong>{{ product.selected_or_first_available_variant.inventory_quantity }}</strong> left — order soon</span>
          </div>
        {%- elsif is_limited -%}
          <div class="product-urgency">
            <div class="product-urgency-dot"></div>
            <span>Limited edition — <strong>47 of 200</strong> kits remaining</span>
          </div>
        {%- endif -%}

        <!-- Quantity + ATC -->
        <div class="product-qty-row">
          <div class="product-qty">
            <button onclick="adjustQty(-1)" type="button">−</button>
            <input type="number" id="quantity" value="1" min="1" max="10">
            <button onclick="adjustQty(1)" type="button">+</button>
          </div>
          <form method="post" action="{{ routes.cart_add_url }}" style="flex:1;" id="add-to-cart-form">
            <input type="hidden" name="form_type" value="product">
            <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">
            <input type="hidden" name="quantity" id="cart-qty" value="1">
            <input type="hidden" name="selling_plan" id="selling-plan-id" value="">
            <button type="submit" class="product-atc-btn" id="atc-btn"
              {% unless product.available %}disabled{% endunless %}>
              <i class="fas fa-shopping-bag"></i>
              {%- if product.available -%}<span id="atc-label">Add to Cart — {{ product.selected_or_first_available_variant.price | money }}</span>{%- else -%}Sold Out{%- endif -%}
            </button>
          </form>
        </div>

        <!-- ── Customise Your Box ── -->
        {%- if section.settings.pcb_enabled -%}
        <div class="pcb-wrap" id="pcb-wrap"
          data-addon-variant="{{ section.settings.pcb_variant_id | default: '56527296692604' }}"
          data-surcharge="{{ section.settings.pcb_surcharge_pence | default: 499 }}">

          <label class="pcb-toggle-label" for="pcb-toggle">
            <div class="pcb-toggle-left">
              <div class="pcb-toggle-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7H4C2.9 7 2 7.9 2 9v10c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2z"/><polyline points="16 2 12 7 8 2"/></svg>
              </div>
              <div class="pcb-toggle-text">
                <span class="pcb-toggle-title">{{ section.settings.pcb_toggle_label | default: 'Customise your box' }}</span>
                <span class="pcb-toggle-sub">{{ section.settings.pcb_toggle_sub | default: 'Add a personal message &amp; photo' }}</span>
              </div>
            </div>
            <div class="pcb-toggle-right">
              <span class="pcb-price-badge">+£{{ section.settings.pcb_surcharge_display | default: '4.99' }}</span>
              <div class="pcb-switch" id="pcb-switch" aria-hidden="true">
                <div class="pcb-switch-thumb"></div>
              </div>
              <input type="checkbox" id="pcb-toggle" class="pcb-toggle-input" aria-expanded="false">
            </div>
          </label>

          <div class="pcb-fields" id="pcb-fields" aria-hidden="true">

            <div class="pcb-field-group">
              <label class="pcb-field-label" for="pcb-message">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                {{ section.settings.pcb_message_label | default: 'Your personal message' }}
              </label>
              <textarea id="pcb-message" class="pcb-textarea" rows="3"
                maxlength="{{ section.settings.pcb_message_max | default: 200 }}"
                placeholder="{{ section.settings.pcb_message_placeholder | default: 'Write something meaningful\u2026' }}"
                aria-describedby="pcb-message-hint"></textarea>
              <div class="pcb-field-footer">
                <span class="pcb-hint" id="pcb-message-hint">{{ section.settings.pcb_message_hint | default: 'Printed on a card inside your box.' }}</span>
                <span class="pcb-char-count" id="pcb-char-count">0 / {{ section.settings.pcb_message_max | default: 200 }}</span>
              </div>
            </div>

            <div class="pcb-field-group">
              <label class="pcb-field-label" for="pcb-file">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                {{ section.settings.pcb_upload_label | default: 'Upload a photo or file' }}
                <span class="pcb-optional">(optional)</span>
              </label>
              <div class="pcb-dropzone" id="pcb-dropzone" role="button" tabindex="0" aria-label="Upload file">
                <div class="pcb-dropzone-idle" id="pcb-dropzone-idle">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(90,20,50,0.4)" stroke-width="1.5" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  <span class="pcb-dropzone-text">{{ section.settings.pcb_upload_hint | default: 'Drop a photo here or click to browse' }}</span>
                  <span class="pcb-dropzone-sub">JPG, PNG, PDF — max 10 MB</span>
                </div>
                <div class="pcb-dropzone-preview" id="pcb-dropzone-preview" style="display:none;">
                  <img id="pcb-preview-img" src="" alt="Preview" style="display:none;">
                  <div class="pcb-file-info" id="pcb-file-info">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--gold,#C9A84C)" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <span id="pcb-file-name-display" class="pcb-file-name">filename.jpg</span>
                    <span id="pcb-file-size-display" class="pcb-file-size"></span>
                    <button type="button" class="pcb-file-remove" id="pcb-file-remove" aria-label="Remove file">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                  </div>
                </div>
                <input type="file" id="pcb-file" class="pcb-file-input" accept=".jpg,.jpeg,.png,.gif,.webp,.pdf,.heic" aria-label="Upload file">
              </div>
            </div>

            <div class="pcb-summary">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold,#C9A84C)" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
              <span>Box customisation <strong>+£{{ section.settings.pcb_surcharge_display | default: '4.99' }}</strong> will be added as a separate line in your cart.</span>
            </div>

          </div>
        </div>

        <style>
          .pcb-wrap{margin:20px 0;border:1.5px solid var(--border-light,rgba(90,20,50,0.15));border-radius:12px;overflow:hidden;background:var(--ivory,#F5EFE6);transition:border-color 0.25s}
          .pcb-wrap.is-active{border-color:var(--burgundy,#5a1432)}
          .pcb-toggle-label{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:16px 18px;cursor:pointer;user-select:none}
          .pcb-toggle-left{display:flex;align-items:center;gap:12px;flex:1;min-width:0}
          .pcb-toggle-icon{width:36px;height:36px;border-radius:8px;background:rgba(90,20,50,0.08);display:flex;align-items:center;justify-content:center;color:var(--burgundy,#5a1432);flex-shrink:0;transition:background 0.25s}
          .pcb-wrap.is-active .pcb-toggle-icon{background:var(--burgundy,#5a1432);color:var(--ivory,#F5EFE6)}
          .pcb-toggle-text{display:flex;flex-direction:column;gap:2px}
          .pcb-toggle-title{font-size:0.88rem;font-weight:700;color:var(--espresso,#1a0a05);letter-spacing:-0.01em}
          .pcb-toggle-sub{font-size:0.73rem;color:var(--text-muted,rgba(26,10,5,0.5))}
          .pcb-toggle-right{display:flex;align-items:center;gap:10px;flex-shrink:0}
          .pcb-price-badge{font-size:0.72rem;font-weight:700;letter-spacing:0.04em;background:rgba(201,168,76,0.15);color:var(--espresso,#1a0a05);border:1px solid rgba(201,168,76,0.4);border-radius:20px;padding:3px 9px;white-space:nowrap}
          .pcb-toggle-input{position:absolute;opacity:0;pointer-events:none;width:1px;height:1px}
          .pcb-switch{width:40px;height:22px;border-radius:11px;background:rgba(90,20,50,0.18);position:relative;transition:background 0.25s;flex-shrink:0}
          .pcb-wrap.is-active .pcb-switch{background:var(--burgundy,#5a1432)}
          .pcb-switch-thumb{position:absolute;top:3px;left:3px;width:16px;height:16px;border-radius:50%;background:#fff;transition:transform 0.25s cubic-bezier(0.34,1.56,0.64,1);box-shadow:0 1px 4px rgba(0,0,0,0.2)}
          .pcb-wrap.is-active .pcb-switch-thumb{transform:translateX(18px)}
          .pcb-fields{max-height:0;overflow:hidden;transition:max-height 0.45s cubic-bezier(0.4,0,0.2,1),padding 0.3s;padding:0 18px;border-top:0px solid var(--border-light,rgba(90,20,50,0.12))}
          .pcb-wrap.is-active .pcb-fields{max-height:700px;padding:18px 18px 20px;border-top-width:1px}
          .pcb-field-group{margin-bottom:16px}
          .pcb-field-label{display:flex;align-items:center;gap:6px;font-size:0.72rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;color:var(--espresso,#1a0a05);margin-bottom:8px}
          .pcb-optional{font-weight:400;text-transform:none;letter-spacing:0;color:rgba(26,10,5,0.45);font-size:0.70rem}
          .pcb-textarea{width:100%;background:#fff;border:1.5px solid var(--border-light,rgba(90,20,50,0.15));border-radius:8px;padding:12px 14px;font-family:var(--font-sans,'Inter',sans-serif);font-size:0.875rem;color:var(--espresso,#1a0a05);resize:vertical;min-height:80px;outline:none;transition:border-color 0.2s;box-sizing:border-box;line-height:1.55}
          .pcb-textarea:focus{border-color:var(--burgundy,#5a1432)}
          .pcb-textarea::placeholder{color:rgba(26,10,5,0.35)}
          .pcb-field-footer{display:flex;justify-content:space-between;align-items:center;margin-top:5px;gap:8px}
          .pcb-hint{font-size:0.70rem;color:rgba(26,10,5,0.45)}
          .pcb-char-count{font-size:0.68rem;color:rgba(26,10,5,0.4);white-space:nowrap;flex-shrink:0}
          .pcb-dropzone{border:1.5px dashed rgba(90,20,50,0.2);border-radius:8px;background:#fff;padding:20px 16px;text-align:center;cursor:pointer;transition:border-color 0.2s,background 0.2s;position:relative}
          .pcb-dropzone:hover,.pcb-dropzone.is-over{border-color:var(--burgundy,#5a1432);background:rgba(90,20,50,0.03)}
          .pcb-file-input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
          .pcb-dropzone-idle{display:flex;flex-direction:column;align-items:center;gap:6px;pointer-events:none}
          .pcb-dropzone-text{font-size:0.82rem;color:var(--espresso,#1a0a05);font-weight:500}
          .pcb-dropzone-sub{font-size:0.68rem;color:rgba(26,10,5,0.4)}
          .pcb-dropzone-preview{display:flex;align-items:center;justify-content:center;flex-direction:column;gap:10px}
          .pcb-dropzone-preview img{max-width:120px;max-height:90px;border-radius:6px;object-fit:cover;border:1px solid rgba(90,20,50,0.12)}
          .pcb-file-info{display:flex;align-items:center;gap:8px;background:rgba(201,168,76,0.10);border:1px solid rgba(201,168,76,0.3);border-radius:6px;padding:6px 12px}
          .pcb-file-name{font-size:0.78rem;font-weight:600;color:var(--espresso,#1a0a05);max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
          .pcb-file-size{font-size:0.68rem;color:rgba(26,10,5,0.4)}
          .pcb-file-remove{background:none;border:none;cursor:pointer;color:rgba(26,10,5,0.4);padding:2px;line-height:1;display:flex;transition:color 0.2s;position:relative;z-index:2}
          .pcb-file-remove:hover{color:#c0392b}
          .pcb-summary{display:flex;align-items:flex-start;gap:8px;background:rgba(201,168,76,0.08);border:1px solid rgba(201,168,76,0.25);border-radius:8px;padding:10px 14px;font-size:0.77rem;color:rgba(26,10,5,0.6);line-height:1.45;margin-top:4px}
          .pcb-summary svg{flex-shrink:0;margin-top:1px}
          .pcb-summary strong{color:var(--espresso,#1a0a05)}
          @keyframes pcb-spin{to{transform:rotate(360deg)}}
          .pcb-spin{animation:pcb-spin 0.8s linear infinite}
        </style>

        <script>
        (function(){
          'use strict';
          var MAX_CHARS        = {{ section.settings.pcb_message_max | default: 200 }};
          var ADDON_VARIANT_ID = '{{ section.settings.pcb_variant_id | default: '56527296692604' }}';
          var SURCHARGE_PENCE  = {{ section.settings.pcb_surcharge_pence | default: 499 }};

          var wrap      = document.getElementById('pcb-wrap');
          var toggle    = document.getElementById('pcb-toggle');
          var textarea  = document.getElementById('pcb-message');
          var charCount = document.getElementById('pcb-char-count');
          var fileInput = document.getElementById('pcb-file');
          var dropzone  = document.getElementById('pcb-dropzone');
          var dzIdle    = document.getElementById('pcb-dropzone-idle');
          var dzPreview = document.getElementById('pcb-dropzone-preview');
          var previewImg= document.getElementById('pcb-preview-img');
          var fileNameD = document.getElementById('pcb-file-name-display');
          var fileSizeD = document.getElementById('pcb-file-size-display');
          var fileRemove= document.getElementById('pcb-file-remove');
          var atcForm   = document.getElementById('add-to-cart-form');
          var atcLabel  = document.getElementById('atc-label');

          if(!wrap||!toggle) return;

          var state = { enabled:false, message:'', fileDataUrl:'', fileName:'', fileSizeStr:'' };

          function fmtSize(b){ if(b<1024) return b+' B'; if(b<1048576) return (b/1024).toFixed(1)+' KB'; return (b/1048576).toFixed(1)+' MB'; }

          function updateAtcLabel(){
            if(!atcLabel) return;
            if(!atcLabel.dataset.base) atcLabel.dataset.base = atcLabel.textContent;
            if(state.enabled){
              var m = atcLabel.dataset.base.match(/£([\d.,]+)/);
              if(m){ var t=(parseFloat(m[1].replace(',',''))+(SURCHARGE_PENCE/100)).toFixed(2); atcLabel.textContent=atcLabel.dataset.base.replace('£'+m[1],'£'+t)+' (incl. personalisation)'; }
              else { atcLabel.textContent=atcLabel.dataset.base+' + £'+(SURCHARGE_PENCE/100).toFixed(2)+' personalisation'; }
            } else { atcLabel.textContent=atcLabel.dataset.base; }
          }

          toggle.addEventListener('change', function(){
            state.enabled = toggle.checked;
            wrap.classList.toggle('is-active', state.enabled);
            document.getElementById('pcb-fields').setAttribute('aria-hidden', state.enabled?'false':'true');
            toggle.setAttribute('aria-expanded', state.enabled?'true':'false');
            updateAtcLabel();
          });

          if(textarea){
            textarea.addEventListener('input', function(){
              state.message = textarea.value;
              var c = state.message.length;
              charCount.textContent = c+' / '+MAX_CHARS;
              charCount.style.color = c > MAX_CHARS*0.9 ? 'var(--burgundy,#5a1432)' : 'rgba(26,10,5,0.4)';
            });
          }

          function handleFile(file){
            if(!file) return;
            if(file.size > 10*1024*1024){ alert('File too large. Please upload under 10 MB.'); return; }
            state.fileName = file.name; state.fileSizeStr = fmtSize(file.size);
            dzIdle.style.display='none'; dzPreview.style.display='flex';
            if(fileNameD) fileNameD.textContent = file.name;
            if(fileSizeD) fileSizeD.textContent = state.fileSizeStr;
            var reader = new FileReader();
            reader.onload = function(e){
              state.fileDataUrl = e.target.result;
              if(file.type.startsWith('image/')) { previewImg.src=e.target.result; previewImg.style.display='block'; }
              else { previewImg.style.display='none'; }
            };
            reader.readAsDataURL(file);
          }

          function clearFile(){
            state.fileDataUrl=''; state.fileName=''; state.fileSizeStr='';
            if(fileInput) fileInput.value='';
            dzIdle.style.display='flex'; dzPreview.style.display='none';
            if(previewImg){ previewImg.src=''; previewImg.style.display='none'; }
          }

          if(fileInput) fileInput.addEventListener('change', function(){ handleFile(fileInput.files[0]); });
          if(fileRemove) fileRemove.addEventListener('click', function(e){ e.stopPropagation(); clearFile(); });
          if(dropzone){
            dropzone.addEventListener('dragover', function(e){ e.preventDefault(); dropzone.classList.add('is-over'); });
            dropzone.addEventListener('dragleave', function(){ dropzone.classList.remove('is-over'); });
            dropzone.addEventListener('drop', function(e){
              e.preventDefault(); dropzone.classList.remove('is-over');
              var f = e.dataTransfer.files[0]; if(f){ fileInput.files=e.dataTransfer.files; handleFile(f); }
            });
            dropzone.addEventListener('keydown', function(e){ if(e.key==='Enter'||e.key===' ') fileInput.click(); });
          }

          if(atcForm){
            atcForm.addEventListener('submit', function(e){
              if(!state.enabled) return;
              e.preventDefault(); e.stopImmediatePropagation();
              var variantId   = (document.getElementById('variant-id')||{}).value||null;
              var quantity    = parseInt((document.getElementById('cart-qty')||{}).value,10)||1;
              var sellingPlan = (document.getElementById('selling-plan-id')||{}).value||'';
              var productTitle = (document.querySelector('.product-title,h1.product__title,#product-title')||{}).textContent||document.title||'Product';

              var mainProps = { '_customisation':'yes', 'Message':state.message.trim()||'(no message)', '_file_name':state.fileName||'', '_file_size':state.fileSizeStr||'', '_addon_variant':ADDON_VARIANT_ID };
              var addonProps = { '_customisation':'yes', '_addon_for_product':productTitle.trim(), '_addon_for_variant':variantId||'', 'Message':state.message.trim()||'(no message)', '_file_name':state.fileName||'' };

              var atcBtn = document.getElementById('atc-btn');
              if(atcBtn){ atcBtn.disabled=true; atcBtn.innerHTML='<span style="display:inline-flex;align-items:center;gap:6px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="animation:pcb-spin 0.8s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Adding to cart…</span>'; }

              var mainItem = { id:variantId, quantity:quantity, properties:mainProps };
              if(sellingPlan) mainItem.selling_plan = sellingPlan;

              fetch('/cart/add.json',{ method:'POST', headers:{'Content-Type':'application/json','Accept':'application/json'}, body:JSON.stringify({items:[mainItem]}) })
              .then(function(r){ return r.ok?r.json():r.json().then(function(d){throw d;}); })
              .then(function(){
                return fetch('/cart/add.json',{ method:'POST', headers:{'Content-Type':'application/json','Accept':'application/json'}, body:JSON.stringify({items:[{id:ADDON_VARIANT_ID,quantity:1,properties:addonProps}]}) });
              })
              .then(function(r){ return r.ok?r.json():r.json().then(function(d){throw d;}); })
              .then(function(){
                var attrs = { '_pcb_customisation':'yes', '_pcb_message':state.message.trim()||'', '_pcb_file_name':state.fileName||'', '_pcb_file_size':state.fileSizeStr||'', '_pcb_product':productTitle.trim(), '_pcb_ts':new Date().toISOString() };
                if(state.fileDataUrl){ attrs['_pcb_file_data_1']=state.fileDataUrl.substring(0,5000); if(state.fileDataUrl.length>5000) attrs['_pcb_file_data_2']=state.fileDataUrl.substring(5000,10000); }
                var note = ['=== BOX CUSTOMISATION ===','Product: '+productTitle.trim(),'Message: '+(state.message.trim()||'(none)'),'File: '+(state.fileName||'(none)'),'Surcharge: \u00a3'+(SURCHARGE_PENCE/100).toFixed(2),'Tag: customisation'].join('\n');
                return fetch('/cart/update.json',{ method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({attributes:attrs,note:note}) });
              })
              .then(function(){
                if(typeof PLCart!=='undefined'&&PLCart.refresh) PLCart.refresh();
                else if(typeof window.Shopify!=='undefined'&&window.Shopify.onCartUpdate) window.Shopify.onCartUpdate();
                else window.location.href='/cart';
              })
              .catch(function(err){
                var msg=(err&&err.description)?err.description:'Something went wrong. Please try again.';
                if(atcBtn){ atcBtn.disabled=false; atcBtn.innerHTML='<i class="fas fa-shopping-bag"></i> Add to Cart'; }
                alert(msg);
              });
            }, true);
          }
        })();
        </script>
        {%- endif -%}

        <!-- Trust badges -->
        <div class="product-trust">
          <div class="product-trust-item"><div class="product-trust-icon" style="font-size:1rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.75"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div><div class="product-trust-label">Free UK over £60</div></div>
          <div class="product-trust-item"><div class="product-trust-icon" style="font-size:1rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.75"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          </div><div class="product-trust-label">Secure checkout</div></div>
          <div class="product-trust-item"><div class="product-trust-icon" style="font-size:1rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.75"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>
          </div><div class="product-trust-label">30-day returns</div></div>
          <div class="product-trust-item"><div class="product-trust-icon" style="font-size:1rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          </div><div class="product-trust-label">Eco packaging</div></div>
        </div>

        <!-- 30-Day Happiness Guarantee -->
        <div style="margin-top:1rem;padding:1rem 1.25rem;border:1px solid var(--border-light);border-radius:12px;background:var(--ivory);text-align:center;">
          <p style="font-family:var(--font-serif);font-size:1rem;font-weight:600;margin-bottom:0.25rem;color:var(--espresso);">30-Day Happiness Guarantee</p>
          <p style="font-size:0.8125rem;color:var(--text-muted);margin:0;">Not in love with it? Full refund, no questions asked.</p>
        </div>

        <!-- Accordion: Description, Delivery, Ingredients -->
        <div class="product-accordion">
          <div class="product-accordion-item">
            <button class="product-accordion-btn open" onclick="toggleAccordion(this)">
              About this product <i class="fas fa-chevron-up"></i>
            </button>
            <div class="product-accordion-body open">
              {{ product.description }}
            </div>
          </div>
          <div class="product-accordion-item">
