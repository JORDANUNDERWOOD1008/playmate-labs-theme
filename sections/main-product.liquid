<script>
  // Gallery switcher
  function switchImage(src, thumb) {
    var img = document.getElementById('main-product-img');
    if (img) img.src = src;
    document.querySelectorAll('.product-thumb').forEach(function(t) { t.classList.remove('active'); });
    if (thumb) thumb.classList.add('active');
  }

  // Quantity adjuster
  function adjustQty(delta) {
    var input = document.getElementById('quantity');
    var cartQty = document.getElementById('cart-qty');
    var val = parseInt(input.value) + delta;
    if (val < 1) val = 1;
    if (val > 10) val = 10;
    input.value = val;
    if (cartQty) cartQty.value = val;
  }
  document.getElementById('quantity').addEventListener('change', function() {
    var v = parseInt(this.value) || 1;
    this.value = Math.max(1, Math.min(10, v));
    var cq = document.getElementById('cart-qty');
    if (cq) cq.value = this.value;
  });

  // Accordion
  function toggleAccordion(btn) {
    var body = btn.nextElementSibling;
    var icon = btn.querySelector('i');
    body.classList.toggle('open');
    btn.classList.toggle('open');
    if (icon) {
      icon.classList.toggle('fa-chevron-down');
      icon.classList.toggle('fa-chevron-up');
    }
  }

  // ── Selling Plans: Purchase options toggle ──────────────────────────────
  (function() {
    var onetimeRadio   = document.getElementById('purchase-onetime-radio');
    var subRadio       = document.getElementById('purchase-subscription-radio');
    var freqWrap       = document.getElementById('sub-frequency-wrap');
    var freqSelect     = document.getElementById('sub-selling-plan');
    var planIdInput    = document.getElementById('selling-plan-id');
    var atcLabelEl     = document.getElementById('atc-label');
    var onetimePriceEl = document.getElementById('onetime-price');
    var subPriceEl     = document.getElementById('sub-price');

    // Selling plan prices keyed by plan ID (populated by Liquid JSON below)
    var planPrices = {};
    try { planPrices = JSON.parse(document.getElementById('selling-plan-prices').textContent || '{}'); } catch(e) {}

    function updatePurchaseUI() {
      var isSubscription = subRadio && subRadio.checked;
      // Toggle selected class
      document.querySelectorAll('.product-purchase-option').forEach(function(o) { o.classList.remove('selected'); });
      if (isSubscription && subRadio) {
        subRadio.closest('.product-purchase-option').classList.add('selected');
      } else if (onetimeRadio) {
        onetimeRadio.closest('.product-purchase-option').classList.add('selected');
      }
      // Show/hide frequency selector
      if (freqWrap) freqWrap.style.display = isSubscription ? 'block' : 'none';
      // Set/clear selling_plan hidden input
      if (planIdInput) {
        if (isSubscription && freqSelect && freqSelect.value) {
          planIdInput.value = freqSelect.value;
        } else {
          planIdInput.value = '';
        }
      }
      // Update ATC button label price
      if (atcLabelEl) {
        if (isSubscription && freqSelect && planPrices[freqSelect.value]) {
          atcLabelEl.textContent = 'Subscribe — ' + planPrices[freqSelect.value] + ' / delivery';
        } else if (onetimePriceEl) {
          atcLabelEl.textContent = 'Add to Cart — ' + onetimePriceEl.textContent;
        }
      }
    }

    if (onetimeRadio) onetimeRadio.addEventListener('change', updatePurchaseUI);
    if (subRadio)     subRadio.addEventListener('change', updatePurchaseUI);
    if (freqSelect) {
      freqSelect.addEventListener('change', function() {
        // Update sub-price display
        if (subPriceEl && planPrices[this.value]) subPriceEl.textContent = planPrices[this.value];
        if (planIdInput && subRadio && subRadio.checked) planIdInput.value = this.value;
        updatePurchaseUI();
      });
    }
  })();

  // Sticky ATC bar
  var atcBtn = document.getElementById('atc-btn');
  var stickyAtc = document.getElementById('sticky-atc');
  if (atcBtn && stickyAtc) {
    var obs = new IntersectionObserver(function(e) {
      stickyAtc.style.display = e[0].isIntersecting ? 'none' : 'flex';
    }, { threshold: 0 });
    obs.observe(atcBtn);
  }

  // ATC form submit is handled by PLProductPage in cart-api.js (v2).
  // Do NOT add a duplicate submit listener here.
  // ── Selling plan price map (injected by Liquid) ─────────────────────────
</script>
