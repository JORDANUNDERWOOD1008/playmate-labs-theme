{% comment %}
  PLAYMATE LABS — EMAIL/SMS CAPTURE SECTION
  File: sections/email-capture.liquid
{% endcomment %}

<section class="section email-capture-section" id="{{ section.settings.section_id | default: 'email-capture' }}"
  style="background:{% if section.settings.dark_bg %}var(--espresso){% else %}var(--cream){% endif %};">
  <div class="container">
    <div class="email-capture-inner reveal">
      <div class="email-capture-content">
        <span class="section-eyebrow" style="color:var(--gold);">
          {{ section.settings.eyebrow | default: 'Something Special For You' }}
        </span>
        <h2 style="font-family:var(--font-serif);font-size:clamp(1.75rem,3vw,2.5rem);
          color:{% if section.settings.dark_bg %}var(--cream){% else %}var(--espresso){% endif %};
          margin:0.75rem 0 1rem;line-height:1.15;">
          {{ section.settings.heading | default: 'Unlock Your Free Virtual Sensory Experience' }}
        </h2>
        <p style="font-size:0.9375rem;color:{% if section.settings.dark_bg %}rgba(245,239,230,0.65){% else %}var(--text-muted){% endif %};
          max-width:520px;margin-bottom:2rem;">
          {{ section.settings.subtext | default: 'Plus early access to limited drops, exclusive events and rituals designed for modern relationships.' }}
        </p>
      </div>

      {%- form 'customer', id: 'section-email-capture-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,lead-magnet">
        <div class="email-capture-form">
          <input type="email"
                 name="contact[email]"
                 placeholder="{{ section.settings.email_placeholder | default: 'Your email address' }}"
                 class="form-input{% if section.settings.dark_bg %} form-input-dark{% endif %}"
                 required
                 autocomplete="email">
          {%- if section.settings.show_phone -%}
            <input type="tel"
                   name="contact[phone]"
                   placeholder="{{ section.settings.phone_placeholder | default: 'Phone (for SMS drops — optional)' }}"
                   class="form-input{% if section.settings.dark_bg %} form-input-dark{% endif %}"
                   autocomplete="tel">
          {%- endif -%}
          <button type="submit" class="btn btn-gold btn-lg" style="margin-top:1.25rem;">
            {{ section.settings.cta_text | default: 'Unlock Free Experience' }}
          </button>
        </div>
        <p style="font-size:0.75rem;color:{% if section.settings.dark_bg %}rgba(245,239,230,0.35){% else %}var(--text-muted){% endif %};margin-top:0.75rem;">
          {{ section.settings.disclaimer | default: 'No spam. Unsubscribe anytime.' }}
        </p>
        {%- if form.posted_successfully? -%}
          <div class="form-success">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2.5">
              <path d="M20 6L9 17l-5-5"/>
            </svg>
            {{ section.settings.success_message | default: "You're in! Check your inbox for your free experience." }}
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Email / SMS Capture",
  "settings": [
    {
      "type": "checkbox",
      "id": "dark_bg",
      "label": "Dark background",
      "default": true
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Section HTML ID",
      "default": "email-capture"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Something Special For You"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Unlock Your Free Virtual Sensory Experience"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show phone / SMS field",
      "default": true
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "phone_placeholder",
      "label": "Phone placeholder",
      "default": "Phone (for SMS drops — optional)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Unlock Free Experience"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer text",
      "default": "No spam. Unsubscribe anytime."
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You're in! Check your inbox for your free experience."
    }
  ],
  "presets": [
    {
      "name": "Email / SMS Capture"
    }
  ]
}
{% endschema %}
