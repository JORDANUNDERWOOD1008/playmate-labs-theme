{%- if section.settings.section_hidden == false -%}
{% comment %}
  PLAYMATE LABS — HOMEPAGE HERO SECTION
  File: sections/home-hero.liquid
  Mobile:  tall product photo fills full viewport; copy pinned top, CTAs pinned bottom
  Desktop: landscape product photo as right-side visual; text on left
{% endcomment %}

{{ 'home.css' | asset_url | stylesheet_tag }}

<section class="hero-section" id="hero">

  {%- comment -%} ── BACKGROUND LAYERS ── {%- endcomment -%}
  <div class="hero-bg" aria-hidden="true">
    {%- comment -%} Desktop bg: landscape photo or fallback gradient {%- endcomment -%}
    <div class="hero-bg-desktop">
      {%- if section.settings.hero_bg_image != blank -%}
        <div class="hero-bg-img" style="background-image:url('{{ section.settings.hero_bg_image | image_url: width: 2400 }}');"></div>
      {%- else -%}
        <img class="hero-bg-img-desktop"
             src="{{ 'hero-desktop-product.jpg' | asset_url }}"
             alt="" width="1800" loading="eager" fetchpriority="high">
      {%- endif -%}
    </div>
    {%- comment -%} Mobile bg: tall portrait photo fills viewport {%- endcomment -%}
    <div class="hero-bg-mobile">
      {%- if section.settings.mobile_hero_image != blank -%}
        <img class="hero-bg-img-mobile"
             src="{{ section.settings.mobile_hero_image | image_url: width: 900 }}"
             alt="" width="900" loading="eager" fetchpriority="high">
      {%- else -%}
        <img class="hero-bg-img-mobile"
             src="{{ 'hero-mobile-product-xtall.jpg' | asset_url }}"
             alt="" width="900" loading="eager" fetchpriority="high">
      {%- endif -%}
    </div>
    {%- comment -%} Gradient overlays {%- endcomment -%}
    <div class="hero-gradient"></div>
    <div class="hero-particle hero-particle-1"></div>
    <div class="hero-particle hero-particle-2"></div>
    <div class="hero-particle hero-particle-3"></div>
  </div>

  {%- comment -%} ── CONTENT ── {%- endcomment -%}
  <div class="hero-content-wrap">
    <div class="container hero-inner">

      {%- comment -%} LEFT / TOP: All text copy {%- endcomment -%}
      <div class="hero-text">

        {%- comment -%} TOP COPY — eyebrow, headline, description {%- endcomment -%}
        <div class="hero-copy-top animate-fadeInUp">
          <p class="hero-eyebrow animate-fadeInUp animate-delay-1">
            {{ section.settings.eyebrow | default: 'A new culture of connection' }}
          </p>
          <h1 class="hero-headline animate-fadeInUp animate-delay-2">
            {{ section.settings.headline | default: 'Rewriting how <em>couples</em> do date night.' }}
          </h1>
          <p class="hero-sub animate-fadeInUp animate-delay-3">
            {{ section.settings.subheadline | default: 'Novel intimate sensory experiences, monthly date night drops, immersive events and playful rituals for modern relationships.' }}
          </p>
        </div>

        {%- comment -%} BOTTOM COPY — buttons + trust {%- endcomment -%}
        <div class="hero-copy-bottom animate-fadeInUp animate-delay-4">
          <div class="hero-actions">
            <button type="button" class="btn btn-gold btn-xl" id="heroExpBtn"
                    onclick="document.getElementById('expSignupModal').classList.add('exp-modal--open')">
              {{ section.settings.cta_primary_text | default: 'Start the 5-Day Experience' }}
            </button>
            <a href="{{ section.settings.cta_secondary_url | default: '/collections/monthly-drops' }}"
               class="btn btn-ghost btn-xl">
              {{ section.settings.cta_secondary_text | default: 'Shop the Latest Drop' }}
            </a>
          </div>
          <div class="hero-trust animate-fadeInUp animate-delay-5">
            <div class="hero-trust-item">
              <div class="star-rating">★★★★★</div>
              <span>{{ section.settings.trust_rating | default: '4.9 / 5 — 2,400+ couples' }}</span>
            </div>
            <span class="hero-trust-dot">·</span>
            <div class="hero-trust-item">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
              </svg>
              <span>{{ section.settings.trust_shipping | default: 'Free shipping over £60' }}</span>
            </div>
          </div>
        </div>

      </div>{%- comment -%}/.hero-text{%- endcomment -%}



    </div>
  </div>

  <div class="hero-scroll-hint">
    <div class="scroll-dot"></div>
  </div>
</section>

<!-- ── 5-Day Experience Sign-Up Modal ─────────────────────────────── -->
<div class="exp-modal" id="expSignupModal" role="dialog" aria-modal="true" aria-label="Start the 5-Day Experience">
  <div class="exp-modal__backdrop" onclick="document.getElementById('expSignupModal').classList.remove('exp-modal--open')"></div>
  <div class="exp-modal__box">
    <button class="exp-modal__close" aria-label="Close"
            onclick="document.getElementById('expSignupModal').classList.remove('exp-modal--open')">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>

    <p class="label" style="color:var(--gold);margin-bottom:0.5rem;">It's Free. It's For You.</p>
    <h3 style="font-family:var(--font-serif);font-size:1.75rem;color:var(--cream);margin-bottom:0.25rem;">Unlock the<br>5-Day Experience</h3>
    <p style="font-size:0.875rem;color:rgba(245,239,230,0.6);margin-bottom:1.5rem;">Join 14,000+ couples who've already started.</p>

    <form class="exp-form" data-form="experience-modal">
      <div class="form-group" style="margin-bottom:0.75rem;">
        <input class="form-input form-input-dark" type="email" name="email" placeholder="Your email address" required>
      </div>
      <div class="form-group" style="margin-bottom:0.75rem;">
        <input class="form-input form-input-dark" type="tel" name="phone" placeholder="Phone number (optional SMS drops)">
      </div>
      <div class="form-group" style="margin-bottom:1.25rem;">
        <select class="form-input form-input-dark form-select" name="status">
          <option value="">I am joining as... (optional)</option>
          <option>A couple looking for novelty</option>
          <option>Dating and exploring</option>
          <option>Buying as a gift for someone</option>
        </select>
      </div>
      <button type="submit" class="btn btn-gold btn-lg" style="width:100%;justify-content:center;">
        <i class="fas fa-unlock-alt" style="margin-right:0.5rem;"></i>
        Unlock Free Experience
      </button>
    </form>

    <div class="form-success" style="display:none;text-align:center;padding:2rem 0;">
      <div style="font-size:2.5rem;margin-bottom:1rem;">🎉</div>
      <h4 style="font-family:var(--font-serif);font-size:1.25rem;color:var(--cream);margin-bottom:0.5rem;">You're in!</h4>
      <p style="font-size:0.875rem;color:rgba(245,239,230,0.65);">Day 1: Curiosity arrives in your inbox tomorrow morning.</p>
    </div>

    <p style="font-size:0.6875rem;color:rgba(245,239,230,0.3);text-align:center;margin-top:1rem;">
      No spam. Unsubscribe anytime. We respect your inbox.
    </p>
  </div>
</div>

<style>
/* ── Experience sign-up modal ── */
.exp-modal {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 9999;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}
.exp-modal--open {
  display: flex;
}
.exp-modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(10,3,8,0.75);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}
.exp-modal__box {
  position: relative;
  z-index: 1;
  background: linear-gradient(145deg, #2D1020 0%, #1a0a14 100%);
  border: 1px solid rgba(201,169,110,0.2);
  border-radius: var(--radius-xl, 1.25rem);
  padding: 2.5rem 2rem 2rem;
  width: 100%;
  max-width: 440px;
  box-shadow: 0 24px 64px rgba(0,0,0,0.55);
  animation: modalSlideUp 0.32s cubic-bezier(0.25,0.46,0.45,0.94);
}
@keyframes modalSlideUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0);    }
}
.exp-modal__close {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 50%;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(245,239,230,0.7);
  cursor: pointer;
  transition: background 0.2s;
}
.exp-modal__close:hover {
  background: rgba(255,255,255,0.12);
  color: var(--cream, #f5efe6);
}
</style>

<script>
(function(){
  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape') {
      document.getElementById('expSignupModal').classList.remove('exp-modal--open');
    }
  });
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "⚙️ Section Visibility"
    },
    {
      "type": "checkbox",
      "id": "section_hidden",
      "label": "Hide this section",
      "default": false,
      "info": "Tick to hide this section from the live site. Untick to show it again."
    },
    {
      "type": "header",
      "content": "Background Images"
    },
    {
      "type": "image_picker",
      "id": "hero_bg_image",
      "label": "Desktop background image (landscape, optional override)"
    },
    {
      "type": "image_picker",
      "id": "mobile_hero_image",
      "label": "Mobile background image (portrait, optional override)"
    },
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "A new culture of connection"
    },
    {
      "type": "richtext",
      "id": "headline",
      "label": "Headline (supports em for italic)",
      "default": "<p>Rewriting how <em>couples</em> do date night.</p>"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Novel intimate sensory experiences, monthly date night drops, immersive events and playful rituals for modern relationships."
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary CTA text",
      "default": "Start the 5-Day Experience"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary CTA text",
      "default": "Shop the Latest Drop"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA URL"
    },
    {
      "type": "text",
      "id": "trust_rating",
      "label": "Trust signal — rating",
      "default": "4.9 / 5 — 2,400+ couples"
    },
    {
      "type": "text",
      "id": "trust_shipping",
      "label": "Trust signal — shipping",
      "default": "Free shipping over £60"
    },
    {
      "type": "header",
      "content": "Schema End"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
