{% comment %}
  PLAYMATE LABS — HEADER SECTION
  File: sections/header.liquid
{% endcomment %}

{{ 'global.css' | asset_url | stylesheet_tag }}

<nav class="site-nav{% if section.settings.dark_style %} nav-dark{% endif %}" id="main-nav" role="navigation" aria-label="Main navigation">
  <div class="nav-inner">

    {%- comment -%} Logo {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="nav-logo" aria-label="{{ shop.name }} Home">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: height: 40 }}"
             alt="{{ shop.name }}"
             height="40"
             loading="eager"
             style="width:auto;height:40px;object-fit:contain;">
      {%- else -%}
        <img src="{{ 'playmate-logo.png' | asset_url }}"
             alt="{{ shop.name }}"
             height="40"
             loading="eager"
             style="width:auto;height:40px;object-fit:contain;">
      {%- endif -%}
    </a>

    {%- comment -%} Desktop Navigation {%- endcomment -%}
    <ul class="nav-links" role="list">
      {%- for link in linklists[section.settings.menu].links -%}
        {%- if link.links != blank -%}
          <li class="nav-item nav-item--has-dropdown">
            <button class="nav-link nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
              {{ link.title }}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-left:0.25rem;">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </button>
            <ul class="nav-dropdown" role="list">
              {%- for childlink in link.links -%}
                <li><a href="{{ childlink.url }}" class="nav-dropdown-link"{% if childlink.current %} aria-current="page"{% endif %}>{{ childlink.title }}</a></li>
              {%- endfor -%}
            </ul>
          </li>
        {%- else -%}
          <li class="nav-item">
            <a href="{{ link.url }}"
               class="nav-link"
               {% if link.current %}aria-current="page"{% endif %}>
              {{ link.title }}
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

    {%- comment -%} Nav Actions {%- endcomment -%}
    <div class="nav-actions">
      {%- if section.settings.show_experience_cta -%}
        <a href="{{ section.settings.url_experience | default: '/pages/5-day-experience' }}"
           class="nav-cta"
           data-show-on-scroll>
          Unlock Free Experience
        </a>
      {%- endif -%}

      {%- comment -%} Search {%- endcomment -%}
      <button class="nav-icon-btn" id="search-toggle" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>

      {%- comment -%} Cart {%- endcomment -%}
      <button class="nav-icon-btn" data-cart-open aria-label="Open cart ({{ cart.item_count }} items)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="cart-count" {% if cart.item_count == 0 %}style="display:none;"{% endif %}>
          {{ cart.item_count }}
        </span>
      </button>

      {%- comment -%} Account {%- endcomment -%}
      {%- if customer -%}
        <a href="{{ routes.account_url }}" class="nav-icon-btn" aria-label="My Account">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>
      {%- else -%}
        <a href="{{ routes.account_login_url }}" class="nav-icon-btn" aria-label="Sign In">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>
      {%- endif -%}

      {%- comment -%} Mobile Hamburger {%- endcomment -%}
      <button class="nav-toggle" aria-label="Toggle mobile menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

{%- comment -%} Mobile Overlay {%- endcomment -%}
<div class="mobile-menu-overlay" id="mobile-overlay"></div>

{%- comment -%} Mobile Menu {%- endcomment -%}
<nav class="mobile-menu" id="mobile-menu" aria-label="Mobile navigation">
  <ul class="mobile-nav-links">
    {%- for link in linklists[section.settings.mobile_menu].links -%}
      <li>
        <a href="{{ link.url }}"
           class="mobile-nav-link"
           {% if link.current %}aria-current="page"{% endif %}>
          {{ link.title }} <span>→</span>
        </a>
      </li>
    {%- endfor -%}
  </ul>
  <div class="mobile-menu-footer">
    <a href="{{ section.settings.url_experience | default: '/pages/5-day-experience' }}"
       class="btn btn-primary"
       style="width:100%;justify-content:center;margin-bottom:0.75rem;">
      Unlock Free 5-Day Experience
    </a>
    <a href="{{ section.settings.url_monthly_drops | default: '/collections/monthly-drops' }}"
       class="btn btn-ghost"
       style="width:100%;justify-content:center;">
      Shop the Latest Drop
    </a>
    <div style="margin-top:1.5rem;display:flex;gap:1rem;justify-content:center;">
      {%- if settings.social_instagram_link != blank -%}
        <a href="{{ settings.social_instagram_link }}" class="footer-social-link" aria-label="Instagram" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
      {%- endif -%}
      {%- if settings.social_tiktok_link != blank -%}
        <a href="{{ settings.social_tiktok_link }}" class="footer-social-link" aria-label="TikTok" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.83a8.24 8.24 0 004.82 1.55V6.93a4.85 4.85 0 01-1.05-.24z"/></svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</nav>

{%- comment -%} Search Bar (slide-down) {%- endcomment -%}
<div class="search-bar" id="search-bar" aria-hidden="true">
  <div class="container">
    <form action="/search" method="get">
      <input type="search" name="q" placeholder="Search products, drops, rituals…" class="search-input" aria-label="Search">
      <button type="submit" class="btn btn-primary btn-sm">Search</button>
      <button type="button" id="search-close" class="nav-icon-btn" aria-label="Close search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "class": "playmate-header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 250,
      "step": 10,
      "default": 120,
      "unit": "px",
      "label": "Logo width"
    },
    {
      "type": "checkbox",
      "id": "dark_style",
      "label": "Dark navigation style",
      "default": true
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Desktop navigation menu"
    },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "default": "main-menu",
      "label": "Mobile navigation menu"
    },
    {
      "type": "checkbox",
      "id": "show_experience_cta",
      "label": "Show 'Unlock Free Experience' CTA in nav",
      "default": true
    },

    {"type": "header", "content": "🔗 Button URLs (editable in customiser)"},
    {"type": "url", "id": "url_experience", "label": "Experience Page (Nav CTA)"},
    {"type": "url", "id": "url_monthly_drops", "label": "Monthly Drops (Mobile Menu)"}
  ]
}
{% endschema %}
