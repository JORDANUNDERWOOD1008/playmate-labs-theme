<!-- HOW IT WORKS -->
<section class="section how-it-works" id="how-it-works">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">How It Works</span>
      <h2 class="heading-xl">Your world of date night,<br>designed beautifully.</h2>
      <div class="section-divider"></div>
    </div>

    <div class="hiw-steps reveal">
      <div class="step-card">
        <span class="step-emoji">✦</span>
        <div class="step-number">1</div>
        <h3>Discover</h3>
        <p>Browse our curated sensory products, monthly drops and upcoming events — all designed for modern couples.</p>
      </div>

      <div class="hiw-arrow">→</div>

      <div class="step-card">
        <span class="step-emoji">📦</span>
        <div class="step-number">2</div>
        <h3>Receive</h3>
        <p>Your kit arrives beautifully packaged, with a ritual guide and everything needed for an extraordinary evening.</p>
      </div>

      <div class="hiw-arrow">→</div>

      <div class="step-card">
        <span class="step-emoji">🌹</span>
        <div class="step-number">3</div>
        <h3>Experience</h3>
        <p>Follow the sensory ritual, play the games, attend the events. Feel the difference intentional intimacy makes.</p>
      </div>

      <div class="hiw-arrow">→</div>

      <div class="step-card">
        <span class="step-emoji">🏆</span>
        <div class="step-number">4</div>
        <h3>Belong</h3>
        <p>Join a community of couples rewriting date night. Earn rewards, get early access and help shape what comes next.</p>
      </div>
    </div>

    <!-- Stats Strip -->
    <div class="stats-strip bg-dark" style="border-radius:16px;margin-top:var(--space-xl);padding:var(--space-xl);">
      <div class="stats-inner">
        <div class="stat-item reveal" data-delay="0">
          <span class="stat-number">14k+</span>
          <span class="stat-label">Couples Joined</span>
        </div>
        <div class="stat-item reveal" data-delay="1">
          <span class="stat-number">4.9</span>
          <span class="stat-label">Average Rating</span>
        </div>
        <div class="stat-item reveal" data-delay="2">
          <span class="stat-number">08</span>
          <span class="stat-label">Monthly Drops</span>
        </div>
        <div class="stat-item reveal" data-delay="3">
          <span class="stat-number">30+</span>
          <span class="stat-label">Events Hosted</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "settings": [],
  "presets": [{ "name": "How It Works", "category": "Content" }]
}
{% endschema %}
