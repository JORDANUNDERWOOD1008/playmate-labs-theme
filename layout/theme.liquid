<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#6B1E3A">

  {%- comment -%} ═══ GOOGLE CONSENT MODE v2 — must be FIRST script ═══ {%- endcomment -%}
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', {
      'analytics_storage': 'denied',
      'ad_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'functionality_storage': 'granted',
      'security_storage': 'granted',
      'wait_for_update': 500
    });
  </script>

  {%- comment -%} ═══ DATA LAYER ═══ {%- endcomment -%}
  {% render 'datalayer' %}

  {%- comment -%} ═══ GOOGLE TAG MANAGER — head ═══
       Replace GTM-NXMGJ6W7 with your container ID
       Create at: https://tagmanager.google.com
  {%- endcomment -%}
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-NXMGJ6W7');</script>
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
  {%- endunless -%}

  {%- assign formatted_initial_value = cart.total_price | money_with_currency -%}

  <title>
    {%- if template == 'index' -%}
      Playmate Labs &mdash; Date Night Experiences, Monthly Drops &amp; Couples Rituals
    {%- else -%}
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    {%- endif -%}
  </title>

  {% if template == 'index' %}
    <meta name="description" content="Novel sensory experiences, monthly date night drops and immersive events for modern couples. Rewriting how couples do date night. Join 14,000+ couples.">
  {% elsif page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'meta-tags' %}

  {{ content_for_header }}

  {%- liquid
    assign body_font_bold = settings.type_body_font | font_modify: 'weight', 'bold'
    assign body_font_italic = settings.type_body_font | font_modify: 'style', 'italic'
    assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
  %}

  {%- comment -%} Preload critical fonts {%- endcomment -%}
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" as="style">

  {%- comment -%} Google Fonts — Playmate Labs design system {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap" rel="stylesheet">

  {%- comment -%} Minimal icon styles — replaces full Font Awesome CDN (~70KB saved) {%- endcomment -%}
  <style>
    .fas,.fab{display:inline-block;font-style:normal;font-variant:normal;text-rendering:auto;-webkit-font-smoothing:antialiased}
    .fa-shopping-bag::before{content:"🛍"}
    .fa-chevron-down::before{content:"▾"}
    .fa-chevron-up::before{content:"▴"}
    .fa-check::before{content:"✓"}
    .fa-star::before{content:"★"}
    .fa-arrow-right::before{content:"→"}
    .fa-times::before{content:"✕"}
    .fa-bars::before{content:"☰"}
    .fa-heart::before{content:"♥"}
    .fa-instagram::before,.fa-tiktok::before,.fa-linkedin::before{content:""}
  </style>

  {%- comment -%} Playmate Labs Stylesheets {%- endcomment -%}
  {{ 'global.css' | asset_url | stylesheet_tag }}
  {{ 'components.css' | asset_url | stylesheet_tag }}
  {{ 'theme-extra.css' | asset_url | stylesheet_tag }}

  {%- comment -%} Header overlap fix — neutralise Shopify's section wrapper {%- endcomment -%}
  <style>
    /*
     * ============================================================
     * PLAYMATE LABS — HEADER OVERLAP FIX
     * ============================================================
     * Our nav (#main-nav.site-nav) is position:fixed at the top.
     * Shopify wraps sections in <div class="shopify-section">,
     * which must NOT be fixed itself — only the inner .site-nav is.
     *
     * CRITICAL: <main id="MainContent"> needs padding-top equal to
     * the nav height so content is never hidden behind the fixed bar.
     * ============================================================
     */

    /* 1. Neutralise the Shopify section wrapper — must be static */
    #shopify-section-header,
    .shopify-section.site-header,
    .playmate-header-section {
      position: static !important;
      height: auto !important;
      z-index: auto !important;
    }

    /* 2. Only the inner nav element is fixed */
    #main-nav.site-nav {
      position: fixed !important;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      height: var(--nav-height, 72px);
    }

    /* 3. Announcement bar — fixed, sitting flush under the nav */
    .announcement-bar {
      position: fixed !important;
      top: var(--nav-height, 72px);
      left: 0;
      right: 0;
      z-index: 999;   /* just below nav (1000) but above page content */
      /* height is ~38px — captured in --bar-height below */
    }

    /* 4. No global padding on MainContent — each hero handles its own
          top offset via calc(var(--nav-height) + var(--bar-height) + Xrem).
          Adding padding here causes a double-gap above full-bleed heroes. */
    :root { --bar-height: 38px; }
    #MainContent {
      padding-top: 0;
    }

    /* 5. Non-hero pages (legal, contact, faq etc.) that have no full-bleed
          hero get a simple spacer pushed onto their first section instead */
    #MainContent > .shopify-section:first-child > .page-hero-minimal,
    #MainContent > .shopify-section:first-child > .contact-hero,
    #MainContent > .shopify-section:first-child > .faq-hero,
    #MainContent > .shopify-section:first-child > .page-hero {
      padding-top: calc(var(--nav-height, 72px) + var(--bar-height, 38px) + 2rem);
    }

    /* 6. Mobile */
    @media (max-width: 768px) {
      #MainContent {
        padding-top: 0;
      }
      #MainContent > .shopify-section:first-child > .page-hero-minimal,
      #MainContent > .shopify-section:first-child > .contact-hero,
      #MainContent > .shopify-section:first-child > .faq-hero,
      #MainContent > .shopify-section:first-child > .page-hero {
        padding-top: calc(var(--nav-height, 64px) + var(--bar-height, 38px) + 1.5rem);
      }
    }
  </style>

  {%- comment -%} Page-specific stylesheets {%- endcomment -%}
  {%- case template.name -%}
    {%- when 'index' -%}
      {{ 'home.css' | asset_url | stylesheet_tag }}
    {%- when 'collection' -%}
      {{ 'shop.css' | asset_url | stylesheet_tag }}
    {%- when 'product' -%}
      {{ 'product.css' | asset_url | stylesheet_tag }}
    {%- when 'blog' -%}
      {{ 'journal.css' | asset_url | stylesheet_tag }}
    {%- when 'article' -%}
      {{ 'journal.css' | asset_url | stylesheet_tag }}
    {%- when 'search' -%}
      {{ 'search.css' | asset_url | stylesheet_tag }}
    {%- when 'customers/account' -%}
      {{ 'account.css' | asset_url | stylesheet_tag }}
    {%- when 'page' -%}
      {%- case template.suffix -%}
        {%- when 'experience', '5-day-experience' -%}
          {{ 'experience.css' | asset_url | stylesheet_tag }}
        {%- when 'drops', 'monthly-drops' -%}
          {{ 'drops.css' | asset_url | stylesheet_tag }}
        {%- when 'events' -%}
          {{ 'events.css' | asset_url | stylesheet_tag }}
        {%- when 'event-detail' -%}
          {{ 'event-detail.css' | asset_url | stylesheet_tag }}
        {%- when 'faq' -%}
          {{ 'faq.css' | asset_url | stylesheet_tag }}
        {%- when 'contact' -%}
          {{ 'contact.css' | asset_url | stylesheet_tag }}
        {%- when 'about', 'community' -%}
          {%- comment -%} Shared page styles covered by components.css {%- endcomment -%}
      {%- endcase -%}
  {%- endcase -%}

  <script>
    // Theme feature flags
    window.Shopify = window.Shopify || {};
    window.playmatelabs = {
      currency: {{ cart.currency.iso_code | json }},
      moneyFormat: {{ shop.money_format | json }},
      cartToken: {{ cart.token | json }},
      customerId: {{ customer.id | default: 'null' | json }},
      shopName: {{ shop.name | json }}
    };
  </script>

  {%- comment -%} ═══ STRUCTURED DATA / SCHEMA MARKUP ═══ {%- endcomment -%}

  {%- comment -%} ── HOMEPAGE: Organization + WebSite ── {%- endcomment -%}
  {%- if template == ‘index’ -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://playmatelabs.com/#organization",
        "name": "Playmate Labs",
        "url": "https://playmatelabs.com",
        "logo": {
          "@type": "ImageObject",
          "url": "https://playmatelabs.com/cdn/shop/files/playmate-logo.png"
        },
        "description": "The cultural platform for modern relationships. Sensory products, monthly drops, immersive events and digital rituals for couples.",
        "foundingDate": "2024",
        "foundingLocation": {
          "@type": "Place",
          "addressLocality": "London",
          "addressCountry": "GB"
        },
        "sameAs": [
          "https://www.instagram.com/playmatelabs",
          "https://www.tiktok.com/@playmatelabs"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "info@playmatelabs.com",
          "contactType": "customer service"
        }
      },
      {
        "@type": "WebSite",
        "@id": "https://playmatelabs.com/#website",
        "name": "Playmate Labs",
        "url": "https://playmatelabs.com",
        "publisher": { "@id": "https://playmatelabs.com/#organization" },
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://playmatelabs.com/search?q={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }
    ]
  }
  </script>
  {%- endif -%}

  {%- comment -%} ── PRODUCT PAGE: BreadcrumbList + FAQPage (Product schema auto-generated by Shopify) ── {%- endcomment -%}
  {%- if template == ‘product’ -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://playmatelabs.com" },
          { "@type": "ListItem", "position": 2, "name": "Shop", "item": "https://playmatelabs.com/collections/all" },
          { "@type": "ListItem", "position": 3, "name": {{ product.title | json }} }
        ]
      }
      {%- if product.handle == ‘playmate-chocolate’ -%}
      ,{
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Do aphrodisiac chocolates actually work?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, with the right ingredients and consistent use. Maca root has been studied in multiple double-blind clinical trials and shown to significantly increase self-reported sexual desire. Ashwagandha has robust evidence for reducing stress-related libido suppression. Dark chocolate’s mood-lifting effects are well established. These ingredients are backed by peer-reviewed research and work best as part of a sensory ritual."
            }
          },
          {
            "@type": "Question",
            "name": "How many aphrodisiac chocolates should I eat?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "One to two pieces each, around 30–60 minutes before you want to feel the effects. Consistency over time matters too—most adaptogens show stronger results with regular use over several weeks."
            }
          },
          {
            "@type": "Question",
            "name": "Are Playmate Chocolates suitable for vegans?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. All Playmate Chocolates are plant-based, vegan, and gluten-free. Made without dairy or artificial additives."
            }
          },
          {
            "@type": "Question",
            "name": "How long does delivery take?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Standard UK delivery within 3–5 working days. Free delivery on orders over £60. We ship across the UK and internationally."
            }
          },
          {
            "@type": "Question",
            "name": "Can I gift Playmate Chocolates?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Absolutely. The packaging is designed to be gifted. Add a personalised note at checkout for birthdays, anniversaries, Valentine’s Day, or any occasion."
            }
          }
        ]
      }
      {%- endif -%}
    ]
  }
  </script>
  {%- endif -%}

  {%- comment -%} ── AUTHOR PAGE: Person ── {%- endcomment -%}
  {%- if template == ‘page’ and page.handle == ‘jordan-underwood’ -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "https://playmatelabs.com/pages/jordan-underwood#person",
        "name": "Jordan Underwood",
        "url": "https://playmatelabs.com/pages/jordan-underwood",
        "jobTitle": "Founder & Creative Director",
        "worksFor": {
          "@type": "Organization",
          "@id": "https://playmatelabs.com/#organization",
          "name": "Playmate Labs"
        },
        "description": "Founder of Playmate Labs. Writer on relationship psychology, long-term desire, sensory rituals, and modern intimacy. Worked with 14,000+ couples through the Playmate experience.",
        "sameAs": [
          "https://www.linkedin.com/in/jordanunderwood"
        ],
        "knowsAbout": [
          "Relationship psychology",
          "Long-term intimacy",
          "Aphrodisiac ingredients",
          "Sensory experiences for couples",
          "Couples date night ideas",
          "Modern relationships"
        ]
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://playmatelabs.com" },
          { "@type": "ListItem", "position": 2, "name": "Jordan Underwood" }
        ]
      }
    ]
  }
  </script>
  {%- endif -%}

  {%- comment -%} ── ARTICLES: Article + BreadcrumbList ── {%- endcomment -%}
  {%- if template contains ‘article’ -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Article",
        "headline": {{ article.title | json }},
        "description": {{ article.excerpt_or_content | strip_html | truncate: 160 | json }},
        "datePublished": {{ article.published_at | date: ‘%Y-%m-%dT%H:%M:%S’ | json }},
        "dateModified": {{ article.updated_at | date: ‘%Y-%m-%dT%H:%M:%S’ | json }},
        {%- if article.image -%}
        "image": {
          "@type": "ImageObject",
          "url": "{{ article.image | image_url: width: 1200 }}",
          "width": 1200,
          "height": 630
        },
        {%- endif -%}
        "author": {
          "@type": "Person",
          "@id": "https://playmatelabs.com/pages/jordan-underwood#person",
          "name": "Jordan Underwood",
          "url": "https://playmatelabs.com/pages/jordan-underwood"
        },
        "publisher": {
          "@type": "Organization",
          "@id": "https://playmatelabs.com/#organization",
          "name": "Playmate Labs",
          "logo": {
            "@type": "ImageObject",
            "url": "https://playmatelabs.com/cdn/shop/files/playmate-logo.png"
          }
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": {{ canonical_url | json }}
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://playmatelabs.com" },
          { "@type": "ListItem", "position": 2, "name": "The Playmate Journal", "item": "https://playmatelabs.com/blogs/the-playmate-journal" },
          { "@type": "ListItem", "position": 3, "name": {{ article.title | json }} }
        ]
      }
    ]
  }
  </script>
  {%- endif -%}

  {%- comment -%} ── BLOG INDEX: BreadcrumbList ── {%- endcomment -%}
  {%- if template == ‘blog’ -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://playmatelabs.com" },
      { "@type": "ListItem", "position": 2, "name": {{ blog.title | json }} }
    ]
  }
  </script>
  {%- endif -%}

  {%- comment -%} ── GENERIC PAGES: BreadcrumbList ── {%- endcomment -%}
  {%- if template == ‘page’ and page.handle != ‘jordan-underwood’ -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://playmatelabs.com" },
      { "@type": "ListItem", "position": 2, "name": {{ page.title | json }} }
    ]
  }
  </script>
  {%- endif -%}

  {%- comment -%} ── COLLECTION PAGES: BreadcrumbList ── {%- endcomment -%}
  {%- if template == ‘collection’ -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://playmatelabs.com" },
      { "@type": "ListItem", "position": 2, "name": {{ collection.title | json }} }
    ]
  }
  </script>
  {%- endif -%}
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}--{{ template.suffix }}{% endif %}">

  {%- comment -%} Google Tag Manager — noscript fallback {%- endcomment -%}
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NXMGJ6W7" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  <a class="skip-to-content-link button visually-hidden" href="#MainContent">
    {{ 'accessibility.skip_to_text' | t }}
  </a>

  {%- comment -%} Header / Nav (fixed — sits above content) {%- endcomment -%}
  {% section 'header' %}

  {%- comment -%} Announcement Bar rendered inside normal flow so nav overlay is clean {%- endcomment -%}
  {% render 'announcement-bar' %}

  {%- comment -%} Cart Drawer {%- endcomment -%}
  {% render 'cart-drawer' %}

  {%- comment -%} Newsletter Popup {%- endcomment -%}
  {% render 'newsletter-popup' %}

  {%- comment -%} Toast Notification {%- endcomment -%}
  <div id="toast-container" class="toast-container" aria-live="polite"></div>

  <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- comment -%} Footer {%- endcomment -%}
  {% section 'footer' %}

  {%- comment -%} Scroll to top {%- endcomment -%}
  <button class="scroll-top-btn" id="scroll-top" aria-label="Scroll to top">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M18 15l-6-6-6 6"/>
    </svg>
  </button>

  {%- comment -%} Global JS {%- endcomment -%}
  <script src="{{ 'main.js' | asset_url }}" defer></script>
  <script src="{{ 'cart-api.js' | asset_url }}" defer></script>

  {%- comment -%} Cookie Consent Banner {%- endcomment -%}
  {% render 'consent-banner' %}

</body>
</html>

