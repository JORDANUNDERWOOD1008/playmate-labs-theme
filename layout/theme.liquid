<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#6B1E3A">
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
  {%- endunless -%}

  {%- assign formatted_initial_value = cart.total_price | money_with_currency -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'meta-tags' %}

  {{ content_for_header }}

  {%- liquid
    assign body_font_bold = settings.type_body_font | font_modify: 'weight', 'bold'
    assign body_font_italic = settings.type_body_font | font_modify: 'style', 'italic'
    assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
  %}

  {%- comment -%} Google Fonts — Playmate Labs design system {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap" rel="stylesheet">

  {%- comment -%} Font Awesome {%- endcomment -%}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css">

  {%- comment -%} Playmate Labs Stylesheets {%- endcomment -%}
  {{ 'global.css' | asset_url | stylesheet_tag }}
  {{ 'components.css' | asset_url | stylesheet_tag }}
  {{ 'theme-extra.css' | asset_url | stylesheet_tag }}

  {%- comment -%} Header overlap fix — neutralise Shopify's section wrapper {%- endcomment -%}
  <style>
    /*
     * FIX: Shopify wraps {% section 'header' %} in:
     *   <div id="shopify-section-header" class="shopify-section site-header">
     * The old navigation.css defined .site-header { position:fixed }
     * which created a DOUBLE fixed wrapper around our .site-nav.
     * Solution: the wrapper is reset to static; only .site-nav itself is fixed.
     */
    #shopify-section-header,
    .shopify-section.site-header,
    .playmate-header-section {
      position: static !important;
      height: auto !important;
      z-index: auto !important;
    }

    /* Ensure our actual nav element is the only fixed layer */
    #main-nav.site-nav {
      position: fixed !important;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      height: var(--nav-height);
    }

    /* Announcement bar renders above the fixed nav in the DOM
       but visually the nav sits on top — keep announcement accessible */
    #shopify-section-announcement-bar {
      position: relative;
      z-index: 1001;
    }
  </style>

  {%- comment -%} Page-specific stylesheets {%- endcomment -%}
  {%- case template.name -%}
    {%- when 'index' -%}
      {{ 'home.css' | asset_url | stylesheet_tag }}
    {%- when 'collection' -%}
      {{ 'shop.css' | asset_url | stylesheet_tag }}
    {%- when 'product' -%}
      {{ 'product.css' | asset_url | stylesheet_tag }}
    {%- when 'blog' -%}
      {{ 'journal.css' | asset_url | stylesheet_tag }}
    {%- when 'article' -%}
      {{ 'journal.css' | asset_url | stylesheet_tag }}
    {%- when 'search' -%}
      {{ 'search.css' | asset_url | stylesheet_tag }}
    {%- when 'customers/account' -%}
      {{ 'account.css' | asset_url | stylesheet_tag }}
    {%- when 'page' -%}
      {%- case template.suffix -%}
        {%- when 'experience', '5-day-experience' -%}
          {{ 'experience.css' | asset_url | stylesheet_tag }}
        {%- when 'drops', 'monthly-drops' -%}
          {{ 'drops.css' | asset_url | stylesheet_tag }}
        {%- when 'events' -%}
          {{ 'events.css' | asset_url | stylesheet_tag }}
        {%- when 'event-detail' -%}
          {{ 'event-detail.css' | asset_url | stylesheet_tag }}
        {%- when 'faq' -%}
          {{ 'faq.css' | asset_url | stylesheet_tag }}
        {%- when 'contact' -%}
          {{ 'contact.css' | asset_url | stylesheet_tag }}
        {%- when 'about', 'community' -%}
          {%- comment -%} Shared page styles covered by components.css {%- endcomment -%}
      {%- endcase -%}
  {%- endcase -%}

  <script>
    // Theme feature flags
    window.Shopify = window.Shopify || {};
    window.playmatelabs = {
      currency: {{ cart.currency.iso_code | json }},
      moneyFormat: {{ shop.money_format | json }},
      cartToken: {{ cart.token | json }},
      customerId: {{ customer.id | default: 'null' | json }},
      shopName: {{ shop.name | json }}
    };
  </script>
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}--{{ template.suffix }}{% endif %}">

  <a class="skip-to-content-link button visually-hidden" href="#MainContent">
    {{ 'accessibility.skip_to_text' | t }}
  </a>

  {%- comment -%} Header / Nav (fixed — sits above content) {%- endcomment -%}
  {% section 'header' %}

  {%- comment -%} Announcement Bar rendered inside normal flow so nav overlay is clean {%- endcomment -%}
  {% render 'announcement-bar' %}

  {%- comment -%} Cart Drawer {%- endcomment -%}
  {% render 'cart-drawer' %}

  {%- comment -%} Newsletter Popup {%- endcomment -%}
  {% render 'newsletter-popup' %}

  {%- comment -%} Toast Notification {%- endcomment -%}
  <div id="toast-container" class="toast-container" aria-live="polite"></div>

  <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- comment -%} Footer {%- endcomment -%}
  {% section 'footer' %}

  {%- comment -%} Scroll to top {%- endcomment -%}
  <button class="scroll-top-btn" id="scroll-top" aria-label="Scroll to top">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M18 15l-6-6-6 6"/>
    </svg>
  </button>

  {%- comment -%} Global JS {%- endcomment -%}
  <script src="{{ 'main.js' | asset_url }}" defer></script>
  <script src="{{ 'cart-api.js' | asset_url }}" defer></script>



</body>
</html>
