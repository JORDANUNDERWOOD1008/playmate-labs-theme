{%- comment -%}
  PLAYMATE LABS — CART DRAWER SNIPPET
  File: snippets/cart-drawer.liquid
  Uses Shopify AJAX Cart API (cart-api.js handles fetch calls)
{%- endcomment -%}

<div class="cart-drawer-overlay" id="cart-overlay"></div>
<div class="cart-drawer" id="cart-drawer" role="dialog" aria-modal="true" aria-label="Shopping cart">
  <div class="cart-drawer-header">
    <div>
      <h3 style="font-family:var(--font-serif);font-size:1.25rem;">Your Cart</h3>
      <p style="font-size:0.8125rem;color:var(--text-muted);" id="cart-item-count">
        {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}
      </p>
    </div>
    <button class="nav-icon-btn" id="cart-close" aria-label="Close cart">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="cart-drawer-body" id="cart-body">
    {%- if cart.item_count == 0 -%}
      <div class="cart-empty">
        <div style="font-size:2.5rem;">🛒</div>
        <p style="font-family:var(--font-serif);font-size:1.125rem;">Your cart is empty</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary btn-sm" style="margin-top:1rem;">
          Shop Now
        </a>
      </div>
    {%- else -%}
      {%- for item in cart.items -%}
        <div class="cart-item" data-key="{{ item.key }}">
          <div class="cart-item-img">
            {%- if item.image -%}
              <img src="{{ item.image | image_url: width: 100 }}" alt="{{ item.title | escape }}" width="80" height="80" loading="lazy">
            {%- else -%}
              <div class="img-placeholder" style="width:80px;height:80px;border-radius:8px;font-size:1.5rem;">🌹</div>
            {%- endif -%}
          </div>
          <div class="cart-item-info">
            <p class="cart-item-name">{{ item.product.title }}</p>
            {%- unless item.product.has_only_default_variant -%}
              <p class="cart-item-variant">{{ item.variant.title }}</p>
            {%- endunless -%}
            <p class="cart-item-price">{{ item.final_line_price | money }}</p>
          </div>
          <div class="cart-item-actions">
            <div class="qty-selector qty-sm">
              <button class="qty-btn cart-qty-dec" data-key="{{ item.key }}" aria-label="Decrease quantity">−</button>
              <span class="qty-value">{{ item.quantity }}</span>
              <button class="qty-btn cart-qty-inc" data-key="{{ item.key }}" aria-label="Increase quantity">+</button>
            </div>
            <button class="cart-item-remove" data-key="{{ item.key }}" aria-label="Remove {{ item.title }}">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </button>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if cart.item_count > 0 -%}
  <div class="cart-drawer-footer" id="cart-footer">
    <div class="cart-subtotal">
      <span>Subtotal</span>
      <span id="cart-total">{{ cart.total_price | money }}</span>
    </div>
    <p style="font-size:0.75rem;color:var(--text-muted);margin-bottom:1rem;">Shipping &amp; taxes calculated at checkout</p>
    <a href="{{ routes.cart_url }}" class="btn btn-ghost btn-lg" style="width:100%;justify-content:center;margin-bottom:0.75rem;">
      View Cart
    </a>
    <a href="{{ routes.cart_url }}/checkout" class="btn btn-primary btn-lg" style="width:100%;justify-content:center;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:0.5rem;">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      Checkout Securely
    </a>
    {%- if settings.cart_cross_sell_enable -%}
      <div class="cart-cross-sells">
        <p class="label" style="color:var(--gold);margin:1.25rem 0 0.75rem;">Complete Your Ritual</p>
        {%- assign cross_sell_collection = collections['ritual-add-ons'] -%}
        {%- if cross_sell_collection -%}
          {%- for product in cross_sell_collection.products limit: 2 -%}
            <div class="cart-cross-sell-item">
              <div class="cart-cross-sell-img">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 80 }}" alt="{{ product.title | escape }}" width="60" height="60" loading="lazy">
                {%- else -%}
                  <div class="img-placeholder" style="width:60px;height:60px;border-radius:8px;font-size:1.25rem;">✨</div>
                {%- endif -%}
              </div>
              <div>
                <p style="font-size:0.8125rem;font-weight:500;">{{ product.title }}</p>
                <p style="font-size:0.75rem;color:var(--text-muted);">{{ product.price | money }}</p>
              </div>
              <button class="btn btn-ghost btn-sm quick-add-to-cart"
                data-variant-id="{{ product.first_available_variant.id }}"
                style="white-space:nowrap;">
                + Add
              </button>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
  {%- endif -%}
</div>
