{%- comment -%}
  PLAYMATE LABS — ANNOUNCEMENT BAR SNIPPET
  File: snippets/announcement-bar.liquid
{%- endcomment -%}

{%- if settings.announcement_bar_enable -%}
<div class="announcement-bar" id="announcement-bar">
  {{ settings.announcement_bar_text }}
  {%- if settings.announcement_bar_link != blank -%}
    &nbsp;<a href="{{ settings.announcement_bar_link }}">{{ settings.announcement_bar_link_text }} →</a>
  {%- endif -%}
</div>
{%- else -%}
<div class="announcement-bar">
  ✦ New Drop: The Velvet Hour — Limited to 200 kits. &nbsp;<a href="{{ routes.collections_url }}/monthly-drops">Shop Now →</a>
</div>
{%- endif -%}
