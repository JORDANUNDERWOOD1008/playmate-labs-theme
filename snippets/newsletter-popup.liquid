{%- comment -%}
  PLAYMATE LABS — NEWSLETTER POPUP SNIPPET
  File: snippets/newsletter-popup.liquid
  Klaviyo Integration:
    - If settings.klaviyo_popup_list_id is set, POSTs to Klaviyo's /client/subscriptions/ endpoint via JS
    - Falls back to Shopify customer form if no Klaviyo list ID configured
    - Always tags the contact in Shopify for data retention
{%- endcomment -%}

{%- if settings.newsletter_popup_enable -%}
<div class="newsletter-popup" id="newsletter-popup" role="dialog" aria-label="Newsletter signup" aria-modal="true">
  <div class="newsletter-popup-overlay" id="newsletter-popup-overlay"></div>
  <div class="newsletter-popup-inner">
    <button class="newsletter-popup-close" id="newsletter-popup-close" aria-label="Close">✕</button>
    <div style="font-size:2rem;margin-bottom:1rem;">🌹</div>
    <p class="label" style="color:var(--gold);margin-bottom:0.5rem;">Something Special For You</p>
    <h2 style="font-family:var(--font-serif);font-size:1.75rem;margin-bottom:0.75rem;color:var(--cream);">
      {{ settings.newsletter_popup_heading | default: 'Unlock Your Free Virtual Sensory Experience' }}
    </h2>
    <p style="font-size:0.875rem;color:rgba(245,239,230,0.65);margin-bottom:1.75rem;">
      {{ settings.newsletter_popup_subtext | default: 'Plus early access to drops, exclusive events and rituals designed for modern relationships.' }}
    </p>

    {%- comment -%} Klaviyo-powered form {%- endcomment -%}
    <div id="newsletter-popup-form-wrap">
      <div id="newsletter-popup-fields" style="display:flex;flex-direction:column;gap:0.75rem;">
        <input class="form-input form-input-dark"
          type="email"
          id="popup-email"
          placeholder="Your email address"
          required
          autocomplete="email">
        <input class="form-input form-input-dark"
          type="tel"
          id="popup-phone"
          placeholder="Phone number (for SMS drops)"
          autocomplete="tel">
        <select class="form-input form-input-dark" id="popup-who" style="cursor:pointer;">
          <option value="couple" selected>A couple looking for novelty</option>
          <option value="dating">Dating / exploring</option>
          <option value="gift">Buying as a gift</option>
          <option value="single">Single / curious</option>
        </select>
        <button type="button" class="btn btn-gold btn-lg" id="popup-submit-btn" style="width:100%;justify-content:center;">
          {{ settings.newsletter_popup_cta | default: 'Unlock Free Experience' }}
        </button>
      </div>
      <div id="newsletter-popup-success" style="display:none;margin-top:1rem;color:var(--gold);font-size:0.875rem;text-align:center;">
        <span style="font-size:1.5rem;display:block;margin-bottom:0.5rem;">✓</span>
        Welcome to the community! Check your inbox.
      </div>
      <div id="newsletter-popup-error" style="display:none;margin-top:0.75rem;color:#ff6b6b;font-size:0.8125rem;text-align:center;">
        Something went wrong. Please try again.
      </div>
    </div>

    <p style="font-size:0.6875rem;color:rgba(245,239,230,0.3);margin-top:1rem;">
      No spam. Unsubscribe anytime. Your details are safe with us.
    </p>
  </div>
</div>

<script>
(function() {
  var KLAVIYO_LIST_ID = {{ settings.klaviyo_popup_list_id | default: '' | json }};
  var KLAVIYO_PUBLIC_KEY = {{ settings.klaviyo_public_api_key | default: '' | json }};

  var KLAVIYO_SMS_LIST_ID = {{ settings.klaviyo_sms_list_id | default: '' | json }};

  function subscribeKlaviyo(email, phone, who) {
    if (!KLAVIYO_LIST_ID || !KLAVIYO_PUBLIC_KEY) return false;

    var payload = {
      data: {
        type: "subscription",
        attributes: {
          list_id: KLAVIYO_LIST_ID,
          email: email,
          custom_source: "Popup — Playmate Labs",
          properties: {
            source: "newsletter_popup",
            who_are_you: who || null
          }
        }
      }
    };

    // If phone provided, include it on the email subscription for profile enrichment
    if (phone) {
      payload.data.attributes.phone_number = phone;
    }

    fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + KLAVIYO_PUBLIC_KEY, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'revision': '2023-10-15'
      },
      body: JSON.stringify(payload)
    })
    .then(function(res) {
      if (res.ok || res.status === 202) {
        // If phone was provided, also subscribe to SMS list
        if (phone && KLAVIYO_SMS_LIST_ID) {
          subscribeSMS(email, phone);
        }
        showSuccess();
      } else {
        submitShopifyForm(email, phone, who);
      }
    })
    .catch(function() {
      submitShopifyForm(email, phone, who);
    });

    return true;
  }

  function subscribeSMS(email, phone) {
    var smsPayload = {
      data: {
        type: "subscription",
        attributes: {
          list_id: KLAVIYO_SMS_LIST_ID,
          phone_number: phone,
          email: email,
          custom_source: "Popup SMS Opt-in — Playmate Labs"
        }
      }
    };
    fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + KLAVIYO_PUBLIC_KEY, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'revision': '2023-10-15'
      },
      body: JSON.stringify(smsPayload)
    }).catch(function() { /* SMS subscription is best-effort */ });
  }

  function submitShopifyForm(email, phone, who) {
    var f = document.createElement('form');
    f.method = 'POST';
    f.action = '/contact';
    f.style.display = 'none';
    f.innerHTML = '<input name="form_type" value="customer">'
      + '<input name="contact[email]" value="' + escHtml(email) + '">'
      + '<input name="contact[tags]" value="newsletter,popup-signup">'
      + (phone ? '<input name="contact[phone]" value="' + escHtml(phone) + '">' : '')
      + (who ? '<input name="contact[note]" value="who_are_you:' + escHtml(who) + '">' : '');
    document.body.appendChild(f);
    f.submit();
  }

  function escHtml(s) {
    return String(s).replace(/[&<>"']/g, function(c) {
      return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
    });
  }

  function showSuccess() {
    var fields = document.getElementById('newsletter-popup-fields');
    var success = document.getElementById('newsletter-popup-success');
    if (fields) fields.style.display = 'none';
    if (success) success.style.display = 'block';
    // Store in session so popup doesn't re-show
    try { sessionStorage.setItem('pl_popup_done', '1'); } catch(e) {}
    // Auto-close after 3s
    setTimeout(function() {
      var popup = document.getElementById('newsletter-popup');
      if (popup) popup.classList.remove('visible');
    }, 3000);
  }

  function showError() {
    var err = document.getElementById('newsletter-popup-error');
    if (err) {
      err.style.display = 'block';
      setTimeout(function() { err.style.display = 'none'; }, 4000);
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    var btn = document.getElementById('popup-submit-btn');
    if (btn) {
      btn.addEventListener('click', function() {
        var emailEl = document.getElementById('popup-email');
        var phoneEl = document.getElementById('popup-phone');
        var whoEl = document.getElementById('popup-who');
        var email = emailEl ? emailEl.value.trim() : '';
        var phone = phoneEl ? phoneEl.value.trim() : '';
        var who = whoEl ? whoEl.value : '';
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          emailEl && emailEl.focus();
          return;
        }
        btn.disabled = true;
        btn.textContent = '…';
        var handled = subscribeKlaviyo(email, phone, who);
        if (!handled) {
          // No Klaviyo keys — use Shopify form
          submitShopifyForm(email, phone, who);
        }
      });
    }
  });
})();
</script>
{%- comment -%} Exit Intent Popup — Discount Offer {%- endcomment -%}
<div class="newsletter-popup" id="exit-intent-popup" role="dialog" aria-label="Special offer" aria-modal="true">
  <div class="newsletter-popup-overlay" id="exit-popup-overlay"></div>
  <div class="newsletter-popup-inner" style="max-width:420px;">
    <button class="newsletter-popup-close" id="exit-popup-close" aria-label="Close">✕</button>
    <p class="label" style="color:var(--gold);margin-bottom:0.5rem;">Before You Go</p>
    <h2 style="font-family:var(--font-serif);font-size:1.5rem;margin-bottom:0.75rem;color:var(--cream);">
      Take 10% Off Your First Order
    </h2>
    <p style="font-size:0.875rem;color:rgba(245,239,230,0.65);margin-bottom:1.25rem;">
      Use code <strong style="color:var(--gold);letter-spacing:0.05em;">FIRSTDATE</strong> at checkout.
    </p>
    <div style="display:flex;flex-direction:column;gap:0.75rem;">
      <a href="/collections/all" class="btn btn-gold btn-lg" style="width:100%;justify-content:center;text-decoration:none;" onclick="try{localStorage.setItem('pl_popup_subscribed','1')}catch(e){}">
        Shop Now — 10% Off
      </a>
      <button type="button" class="btn btn-ghost btn-sm" style="width:100%;justify-content:center;opacity:0.6;" onclick="document.getElementById('exit-intent-popup').classList.remove('visible');document.body.style.overflow='';try{localStorage.setItem('pl_exit_dismissed',String(Date.now()))}catch(e){}">
        No thanks
      </button>
    </div>
    <p style="font-size:0.6875rem;color:rgba(245,239,230,0.3);margin-top:1rem;">
      Valid on your first order. Cannot be combined with other offers.
    </p>
  </div>
</div>

{%- endif -%}